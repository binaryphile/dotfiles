#!/usr/bin/env bash

# rotate-digi-passwords -- chain-rotate the Digi AD passwords on all four
# environment bastions per Confluence 235039326252 ("Change operations
# passwords and never expire").
#
# Per-environment 1Password items hold current + new fields:
#   op://Personal/digi-ad-pa1/{password,password_new}
#   op://Personal/digi-ad-pvt01/{password,password_new}
#   op://Personal/digi-ad-cnc/{password,password_new}
#   op://Personal/digi-ad-om1/{password,password_new}
#
# Caller supplies the new password ONCE (prompted at start); the script
# applies it to all four, then writes the new value back to each 1P item
# and rotates current -> previous, new -> current for audit.
#
# Prerequisites (operator-side, one-time):
#   - SSH key in authorized_keys on each bastion (key auth, no password
#     to log in; the password is for the `passwd` command inside)
#   - 1Password CLI authenticated (op signin done in current shell)
#   - GlobalProtect VPN UP on US Central gateway
#   - `expect` on PATH (nix-shell nixpkgs#expect or system pkg)
#
# Anchors: era memory 2583fa55600b (CNC AD rotation procedure verified
# 2026-06-16 against Confluence 235039326252). VPN-must-be-US-Central
# detail per the same doc.

IFS=$'\n'     # default to newline word-splitting per bash style guide
set -o noglob # globs only when explicitly enabled
set -u        # unset vars are errors

# shellcheck disable=SC2128 # BASH_SOURCE always has at least one element
Here=$(dirname "$BASH_SOURCE")

# Bastion table -- one row per environment.
#   Field 1: 1Password item name (op://Personal/<name>/...)
#   Field 2: bastion IP (per Confluence 235039326252)
#   Field 3: passwd command on the bastion (cnc/pa1/pvt01 use passwd; om1 uses adpasswd)
#   Field 4: human label for status output
Bastions_=(
  "digi-ad-pa1    107.20.83.0   passwd     pa1 (prod)"
  "digi-ad-pvt01  54.156.241.97 passwd     pvt01 (NYCDOT)"
  "digi-ad-cnc    3.16.193.243  passwd     cnc (RM CI / gitlab / splunk)"
  "digi-ad-om1    10.10.235.17  adpasswd   om1 (dev/test)"
)

# AD policy per the Confluence doc:
#   8 chars min, 3 of 4 character classes, no name parts, no last 24 reused
PasswordMinChars_=8

main() {
  precheck-tools
  precheck-vpn
  precheck-op-signin

  local newPassword_ confirmPassword_
  read-new-password newPassword_ confirmPassword_

  local row_ failures_=()
  for row_ in ${Bastions_[@]}; do
    rotate-one "$row_" "$newPassword_" || failures_+=("$row_")
  done

  if (( ${#failures_[@]} == 0 )); then
    echo
    echo "✓ All four environments rotated. Next expiry: $(date -d '+90 days' '+%Y-%m-%d')."
    echo "Set a calendar reminder for $(date -d '+75 days' '+%Y-%m-%d') (15-day pre-expiry buffer)."
  else
    echo
    echo "⚠ ${#failures_[@]} environment(s) failed; re-run after fixing each manually:" >&2
    local f_
    for f_ in ${failures_[@]}; { echo "  - $f_" >&2; }
    exit 1
  fi
}

# precheck-tools verifies expect + op are reachable.
precheck-tools() {
  type -P expect >/dev/null || die "expect not on PATH; install via 'nix shell nixpkgs#expect' or add to your nix profile"
  type -P op     >/dev/null || die "1Password CLI 'op' not on PATH"
}

# precheck-vpn verifies GlobalProtect is up via the route check (gpd0 should
# be the egress dev for the cnc bastion's public IP).
precheck-vpn() {
  local egressDev_
  egressDev_=$(ip route get 3.16.193.243 2>/dev/null | grep -oE 'dev [^ ]+' | head -1 | awk '{print $2}')
  if [[ $egressDev_ != gpd0 ]]; then
    die "VPN check failed: route to cnc bastion (3.16.193.243) egresses '$egressDev_', expected gpd0. Bring GlobalProtect up on US Central gateway."
  fi
}

# precheck-op-signin verifies the 1Password CLI is authenticated by listing
# one item from the Personal vault. Re-prompts via 'op signin' if unauth'd.
precheck-op-signin() {
  op item list --vault Personal --limit 1 >/dev/null 2>&1 || \
    die "1Password CLI not authenticated; run 'eval \$(op signin)' first"
}

# read-new-password prompts twice without echo, validates against AD policy,
# and assigns the result to the two name-ref out params.
read-new-password() {
  local -n newRef_=$1
  local -n confirmRef_=$2
  echo "New AD password will be applied to all 4 Digi environments." >&2
  echo "Policy: $PasswordMinChars_+ chars, 3 of 4 classes (upper/lower/digit/symbol)," >&2
  echo "no name parts, no reuse of last 24." >&2
  while true; do
    read -rsp "New password: "         newRef_     ; echo >&2
    read -rsp "Confirm new password: " confirmRef_ ; echo >&2
    if [[ $newRef_ != $confirmRef_ ]]; then
      echo "Mismatch; try again." >&2
      continue
    fi
    if validate-policy "$newRef_"; then
      break
    fi
  done
}

# validate-policy applies the AD complexity rule locally so failures surface
# before the SSH round-trip. Conservative -- the bastion's passwd will do the
# authoritative check too.
validate-policy() {
  local pw_=$1
  (( ${#pw_} >= PasswordMinChars_ )) || { echo "Too short (need ≥ $PasswordMinChars_ chars)." >&2; return 1; }
  local classes_=0
  [[ $pw_ == *[A-Z]* ]] && classes_=$((classes_ + 1))
  [[ $pw_ == *[a-z]* ]] && classes_=$((classes_ + 1))
  [[ $pw_ == *[0-9]* ]] && classes_=$((classes_ + 1))
  [[ $pw_ == *[^A-Za-z0-9]* ]] && classes_=$((classes_ + 1))
  (( classes_ >= 3 )) || { echo "Need at least 3 of 4 character classes (saw $classes_)." >&2; return 1; }
}

# rotate-one drives the passwd ritual on ONE bastion via expect, then writes
# the new value to 1P. Returns 1 on any failure (caller appends to failures_).
rotate-one() {
  local row_=$1 newPassword_=$2
  local item_ ip_ cmd_ label_
  read -r item_ ip_ cmd_ label_ <<< "$row_"

  echo
  echo "── Rotating $label_ ($item_ @ $ip_) ──"

  local oldPassword_
  oldPassword_=$(op read "op://Personal/$item_/password" 2>/dev/null) || \
    { echo "  ✗ failed to read current password from op://Personal/$item_" >&2; return 1; }

  # Drive ssh + passwd via expect. Heredoc-with-quoted-EOF means literal
  # bash content (no expansion); the passwords get into expect's environment
  # via the env-var pass-through so they never appear in the script body.
  OLD_PW=$oldPassword_ NEW_PW=$newPassword_ \
    expect <<'EXPECT' "$ip_" "$cmd_"
    set timeout 30
    set ip   [lindex $argv 0]
    set cmd  [lindex $argv 1]
    set old  $env(OLD_PW)
    set new  $env(NEW_PW)

    log_user 0
    spawn ssh -o BatchMode=yes -o StrictHostKeyChecking=accept-new tlilley@$ip $cmd

    expect {
      -re "(?i)current.*password:" { send "$old\r" }
      -re "(?i)\\(current\\) UNIX password:" { send "$old\r" }
      timeout { puts stderr "  ✗ no current-password prompt"; exit 1 }
      eof     { puts stderr "  ✗ ssh closed before prompt"; exit 1 }
    }

    expect {
      -re "(?i)new.*password:" { send "$new\r" }
      timeout { puts stderr "  ✗ no new-password prompt"; exit 1 }
      eof     { puts stderr "  ✗ ssh closed mid-rotation"; exit 1 }
    }

    expect {
      -re "(?i)retype.*password:|(?i)re-?enter.*password:|(?i)confirm.*password:" { send "$new\r" }
      timeout { puts stderr "  ✗ no confirm-password prompt"; exit 1 }
    }

    expect {
      -re "(?i)password (changed|updated) successfully" { puts "  ✓ passwd succeeded"; exit 0 }
      -re "(?i)bad password|too (short|simple)|reuse" { puts stderr "  ✗ server-side policy rejected password"; exit 2 }
      timeout { puts stderr "  ✗ no success/failure message"; exit 1 }
      eof     { exit 0 }
    }
EXPECT
  local expectRc_=$?
  if (( expectRc_ != 0 )); then
    echo "  ✗ rotation failed (expect rc=$expectRc_); current password in 1P NOT rotated" >&2
    return 1
  fi

  # Rotation succeeded on this bastion. Update 1P:
  #   - move current -> previous (audit trail; lets you fall back ONE step)
  #   - set current = new
  #   - update an expires_at hint for the next rotation
  op item edit "$item_" --vault Personal \
    "password_previous=$oldPassword_" \
    "password=$newPassword_" \
    "expires_at=$(date -d '+90 days' '+%Y-%m-%d')" >/dev/null
  echo "  ✓ 1Password updated; expires_at $(date -d '+90 days' '+%Y-%m-%d')"
}

# die exits with rc=1 and prints args to stderr.
die() {
  local arg_
  for arg_; { echo "$arg_" >&2; }
  exit 1
}

main $@
