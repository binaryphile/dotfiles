#!/usr/bin/env bash

# vpn-connect - connect to Digi work VPN with split tunnel
#
# SAML auth happens in your default browser via gpauth, then gpclient
# (from globalprotect-openconnect) runs the tunnel with vpn-slice for
# split-horizon DNS. Auto-reconnects on session expiry. Ctrl-C exits cleanly.

Interrupted=false

fatal() {
  local msg=$1 rc=${2:-$?}
  echo "fatal: $msg" >&2
  exit $rc
}

onInterrupt() {
  Interrupted=true
}

connect() {
  gpauth access.digi.com --browser xdg-open |
    sudo @gpclient@ connect access.digi.com \
      --cookie-on-stdin \
      --user "$USER" \
      --os Windows \
      --gateway 'US East' \
      --script '@vpn-slice@ 10.0.0.0/8 172.26.0.0/16 dm1.devdevicecloud.com gitlab.drm.ninja 3.16.193.243 --domains-vpn-dns digi.com'
}

main() {
  trap onInterrupt INT

  while true; do
    connect && rc=$? || rc=$?
    $Interrupted && break
    echo "VPN disconnected (exit $rc). Reconnecting..." >&2
    sleep 2
  done
}

return 2>/dev/null
IFS=$'\n'
set -euo pipefail
set -o noglob
main "$@"
