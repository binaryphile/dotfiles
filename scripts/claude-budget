#!/usr/bin/env bash

[[ ${__CLAUDE_BUDGET_TESTING:-} ]] && return 2>/dev/null

set -euo pipefail

StateDir=${CLAUDE_BUDGET_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-budget}
ConfigFile=${CLAUDE_BUDGET_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-budget/config.json}

main() {
  local hook_json
  hook_json=$(cat)

  local event
  event=$(printf '%s' "$hook_json" | jq -r '.hook_event_name // empty')

  case $event in
    Stop)         handleStop "$hook_json" ;;
    SessionEnd)   handleSessionEnd ;;
    SessionStart | UserPromptSubmit) handleWarning "$event" "$hook_json" ;;
    *)            exit 0 ;;
  esac
}

handleStop() {
  local hook_json=$1

  local session_id transcript
  session_id=$(printf '%s' "$hook_json" | jq -r '.session_id // empty')
  transcript=$(printf '%s' "$hook_json" | jq -r '.transcript_path // empty')

  [[ -n $session_id && -n $transcript && -r $transcript ]] || exit 0

  local day cutoff_epoch sleep_gap_min sleep_gap_sec
  day=$(date -d '3 hours ago' +%Y-%m-%d)
  # Budget day = 03:00 of day-name through 03:00 of next day. Filter messages to
  # this window so a session living across calendar days doesn't double-count
  # prior days' transcript content into today's bucket. The 03:00 cutoff is a
  # heuristic for "operator's working day has actually wound down by then" —
  # tightening from the prior 02:00 to capture more late-night-into-this-day
  # work in the previous bucket.
  cutoff_epoch=$(date -d "$day 03:00" +%s)

  # Sleep-aware day attribution: within today's filtered window, walk messages
  # in timestamp order and detect the most-recent idle gap >= threshold. Drop
  # all messages BEFORE that gap — they belong to the prior day's work-block
  # that happened to run past the 02:00 cutoff before the operator slept.
  # Post-gap messages are today's true operator-intent work.
  #
  # No retro-write to yesterday's file (already closed at rollover); pre-gap
  # tokens are intentionally lost from accounting under the assumption that
  # they were already approximately captured by yesterday's last Stop.
  sleep_gap_min=${CLAUDE_BUDGET_SLEEP_GAP_MIN:-120}
  sleep_gap_sec=$((sleep_gap_min * 60))

  # Token weights as input-equivalent units approximating Anthropic billing
  # shape (output ~5x base; cache_creation ~1.25x; cache_read ~0.1x). These
  # are an OPERATOR POLICY choice, not a verified pricing fact — re-tune the
  # multipliers (and daily_tokens cap) if rate-card pricing changes. Scaled
  # x100 for integer-safe jq arithmetic; final /100 returns to token units.
  #
  # Timestamp parse: claude-code transcripts use ISO-8601 Z-suffixed UTC with
  # microseconds (e.g. "2026-06-23T15:57:57.655Z"). jq's fromdateiso8601
  # rejects fractional seconds; strip them. Offset-form timestamps
  # ("...-04:00") are not normalized and fall out via the // 0 guards —
  # acceptable today because claude-code emits Z form; revisit if upstream
  # ever switches to offset form.
  local tokens
  tokens=$(head -n -1 "$transcript" | jq -sc \
    --argjson cutoff "$cutoff_epoch" \
    --argjson sleepgap "$sleep_gap_sec" '
    def parse_ts: sub("\\.[0-9]+"; "") | fromdateiso8601? // 0;

    [.[] | select(.message? and .message.id? and .message.usage?
                  and .timestamp?
                  and (.timestamp | parse_ts) >= $cutoff)
         | {id: .message.id, ts: (.timestamp | parse_ts), u: .message.usage}]
    | sort_by(.ts)
    | . as $msgs
    | (if ($msgs | length) <= 1 then 0
       else
         ([range(1; $msgs | length) as $i
           | select(($msgs[$i].ts - $msgs[$i-1].ts) >= $sleepgap)
           | $i] | last) // 0
       end) as $cut
    | $msgs[$cut:]
    | unique_by(.id)
    | map(
        ((.u.input_tokens // 0) * 100)
        + ((.u.output_tokens // 0) * 500)
        + ((.u.cache_creation_input_tokens // 0) * 125)
        + ((.u.cache_read_input_tokens // 0) * 10)
      )
    | (add // 0) / 100
    | floor
  ' 2>/dev/null) || exit 0

  [[ ${tokens:-0} -gt 0 ]] || exit 0

  mkdir -p "$StateDir/sessions"
  printf '%s\n' "$tokens" > "$StateDir/sessions/${day}-${session_id}.tokens"
}

handleSessionEnd() {
  local sessions_dir="$StateDir/sessions"
  [[ -d $sessions_dir ]] || exit 0
  find "$sessions_dir" -name '*.tokens' -mtime +7 -delete
}

handleWarning() {
  local event=$1

  [[ -r $ConfigFile ]] || exit 0

  local limit
  limit=$(jq -r '.daily_tokens // 0' "$ConfigFile")
  [[ ${limit:-0} -gt 0 ]] || exit 0

  local day
  day=$(date -d '3 hours ago' +%Y-%m-%d)

  local total=0
  local sessions_dir="$StateDir/sessions"
  if [[ -d $sessions_dir ]]; then
    local f n
    for f in "$sessions_dir/${day}"-*.tokens; do
      [[ -f $f ]] || continue
      n=$(< "$f")
      total=$(( total + ${n:-0} ))
    done
  fi

  local pct_remaining
  pct_remaining=$(( (limit - total) * 100 / limit ))
  if (( pct_remaining < 0 )); then pct_remaining=0; fi
  if (( pct_remaining > 100 )); then pct_remaining=100; fi

  if [[ $event == UserPromptSubmit ]]; then
    local enforce
    enforce=$(jq -r '.enforce_at_pct // 0' "$ConfigFile")
    if [[ ${enforce:-0} -gt 0 && $pct_remaining -le $enforce ]]; then
      local used_k limit_k
      used_k=$(( total / 1000 ))
      limit_k=$(( limit / 1000 ))
      printf '{"decision":"block","reason":"[Claude Budget] Budget floor reached: %d%% remaining (%dk/%dk tokens). Adjust daily_tokens or close sessions."}\n' \
        "$pct_remaining" "$used_k" "$limit_k"
      exit 0
    fi
  fi

  local session_count=0
  if [[ -d $sessions_dir ]]; then
    local f
    for f in "$sessions_dir/${day}"-*.tokens; do
      [[ -f $f ]] || continue
      session_count=$(( session_count + 1 ))
    done
  fi

  local used_k limit_k
  used_k=$(( total / 1000 ))
  limit_k=$(( limit / 1000 ))

  local warned_file="$StateDir/warned/${day}"
  local lock_file="$StateDir/warned/${day}.lock"
  mkdir -p "$StateDir/warned"

  local threshold warned_this
  for threshold in 25 10 5 1; do
    (( pct_remaining <= threshold )) || continue

    warned_this=false
    {
      flock -x 9

      local warned_content=''
      [[ -f $warned_file ]] && warned_content=$(< "$warned_file")

      if ! printf '%s\n' "$warned_content" | grep -qxF "$threshold"; then
        printf '%d\n' "$threshold" >> "$warned_file"
        warned_this=true
      fi
    } 9>"$lock_file"

    if [[ $warned_this == true ]]; then
      local action
      case $threshold in
        25) action='Consider closing idle parallel sessions.' ;;
        10) action='Close all but one session.' ;;
        5)  action='Finish current work only.' ;;
        1)  action='Stop after this prompt.' ;;
      esac

      printf '[Claude Budget] %d%% remaining (%dk/%dk tokens, %d sessions today). %s\n' \
        "$pct_remaining" "$used_k" "$limit_k" "$session_count" "$action"

      exit 0
    fi
  done
}

main