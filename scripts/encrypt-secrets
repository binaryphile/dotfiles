#!/usr/bin/env bash

# encrypt-secrets -- encrypt ~/secrets/ to secrets/<hostname>.tar.age in the repo.
# Uses age passphrase mode. Atomic write via temp+mv.
# Filename policy: same as restoreSecrets (validSecretName).

set -euo pipefail

source ~/dotfiles/scripts/lib.bash

age=${age:-age}
tar=${tar:-tar}

hostname=$(machineHostname)
validateHostname "$hostname"

secretsDir="$HOME/secrets"
repoDir="$HOME/dotfiles/secrets"
bundle="$repoDir/${hostname}.tar.age"

[[ -d "$secretsDir" ]] || { echo "No ~/secrets/ directory."; exit 1; }
command -v -- "$age" >/dev/null 2>&1 || { echo "$age not found."; exit 1; }

# Collect valid secret files and warn about excluded ones
valid=()
excluded=()
for f in "$secretsDir"/* "$secretsDir"/.*; do
  [[ -e "$f" ]] || continue
  base=$(basename "$f")
  [[ $base == . || $base == .. || $base == .bundle-hash ]] && continue
  if [[ -f "$f" ]] && validSecretName "$base"; then
    valid+=("$base")
  else
    excluded+=("$base")
  fi
done

if (( ${#valid[@]} == 0 )); then
  if (( ${#excluded[@]} > 0 )); then
    echo "ERROR: ~/secrets/ contains only excluded files: ${excluded[*]}"
    echo "  Only files matching [a-zA-Z0-9][a-zA-Z0-9._-]* are bundled."
    echo "  Rename files or manage excluded ones separately."
  else
    echo "~/secrets/ is empty."
  fi
  exit 1
fi

if (( ${#excluded[@]} > 0 )); then
  echo "WARNING: these files will NOT be bundled: ${excluded[*]}"
  echo "  Manage them separately or rename to match the filename policy."
fi

mkdir -p "$repoDir"

tmp=$(mktemp "$bundle.XXXXXX")
echo "(Repo encryption passphrase)"
# Build tar with only valid files (no dotfiles, no directories, no invalid names)
if printf '%s\n' "${valid[@]}" | $tar cf - -C "$secretsDir" -T - | $age -p -o "$tmp"; then
  mv "$tmp" "$bundle"
  echo "Written: $bundle (${#valid[@]} files)"
  echo "Commit and push."
else
  rm -f "$tmp"
  echo "Encryption failed."
  exit 1
fi
