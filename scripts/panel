#!/usr/bin/env bash

# panel — tmux status bar widgets, ported from waybar custom/* modules
# in nixos-config/home/sway/waybar.nix.
#
# Usage:
#   panel <module>           print a single fixed-width status segment
#   panel click <module>     click handler (called from tmux mouse bind)
#   panel poll               refresh all module state files (one-shot)
#
# Modules:
#   era       era-mcp systemd service status         (click: toggle service)
#   vpn       gpclient connect process state         (click: toggle vpn)
#   dm1            dm1.devdevicecloud.com health (VPN)    (click: open url)
#   stash          stash.digi.com ssh probe       (VPN)   (click: open url)
#   gitlab         gitlab.drm.ninja health        (VPN)   (click: open url)
#   nexus          nexus.digi.com health          (VPN)   (click: open url)
#   remotemanager  remotemanager.digi.com health          (click: open url)
#   codeberg       codeberg ssh status (status API)       (click: open url)
#   bitbucket      bitbucket ssh status (status API)      (click: open url)
#   teams          teams.microsoft.com health              (click: open url)
#   ntfy           ntfy.sh health                          (click: open url)
#   ssh       inbound ssh connection count            (click: ss popup)
#   load      1/5/15-min loadavg sparkline            (click: btop popup)
#
# Each module emits a fixed-width segment so the bar doesn't reflow.
# Slow probes (curl, ssh, ping) are dispatched to background subshells
# and tmux always reads from a cached state file. The first read after
# startup may show "?" until the first poll completes.

set -uo pipefail

State=${XDG_RUNTIME_DIR:-/tmp}/panel

# Source the shared probe library. State/probes/refresh/etc. live here
# so the same logic can be reused by waybar's widget-status script on
# the NixOS side. Path is identical on both machines (~/dotfiles).
# probe-lib creates $State if missing and fails fast if it can't.
# shellcheck source=./probe-lib.bash
source "$HOME/dotfiles/scripts/probe-lib.bash"

# fg colorizes text using a tmux inline format code.
fg() { printf '#[fg=%s]%s#[default]' "$1" "$2"; }

# Color palette mirrors waybar.css from nixos-config:
#   on       white       (#ffffff) — healthy / default
#   partial  colour250   (#bcbcbc) — degraded
#   off      colour244   (#808080) — down
#   unknown  colour130   (#af5f00) — amber, no data yet
ColorOn=white
ColorPartial=colour250
ColorOff=colour244
ColorUnknown=colour130

# segment renders a 3-char text label colored by state. Hidden when
# state is "on" — healthy widgets vanish so the bar is quiet by default,
# surfacing only when something needs attention. Partial and off states
# render in the customary mid-gray/dark-gray. Plain text so it works
# in ChromeOS Terminal's font set (no Nerd Font required).
segment() {
  local label=$1
  local cls=${2:-unknown}
  local color
  case $cls in
    on)      return ;;
    partial) color=$ColorPartial ;;
    off)     color=$ColorOff     ;;
    *)       color=$ColorUnknown ;;
  esac
  printf ' '
  fg "$color" "$label"
}

# thresholdSegment renders a cpu/mem/disk segment ONLY when usage is at
# 90% or higher. Below threshold, prints nothing — the segment vanishes
# from the bar entirely. At/above threshold, prints label + percent in
# white (default text color) — threshold-gated visibility, not a warning.
thresholdSegment() {
  local label=$1
  local pct=$2
  if (( pct >= 90 )); then
    printf ' '
    fg "$ColorOn" "$(printf '%s %d%%' "$label" "$pct")"
  fi
}

# pollAll forces a synchronous poll of every health module by simply
# rendering each one — that runs the same refresh-if-stale logic the
# normal status bar uses, but synchronously waits for all the spawned
# probes via `wait`. Used by `panel poll` for initial warm-up.
pollAll() {
  local m
  for m in vpn dm1 stash gitlab nexus remotemanager codeberg bitbucket teams ntfy era; do
    "${m}Module" > /dev/null
  done
  wait
}

# Local probes — each prints exactly one of "on" "partial" "off" on
# stdout. Network probes (sshHost, pingHost, vendor APIs) come from
# probe-lib.bash.

eraProbe() {
  systemctl --user is-active --quiet era-mcp && echo on || echo off
}

vpnProbe() {
  ip link show tun0 >/dev/null 2>&1 && echo on || echo off
}

# Module rendering — fast: read cached state, kick off async refresh,
# emit a 3-char text segment colored by state. VPN-gated modules
# (dm1, stash, gitlab, nexus) return empty when VPN is down — without
# a tun0 interface there's nothing to probe and no useful state to
# show, so the segment vanishes from the bar entirely.
#
# Two cadences for reachability widgets:
#   - SSH probe: every 600s (10 min). Authoritative reachability check.
#     Skipped for hosts in WidgetNoSsh (dm1, nexus, remotemanager).
#   - ping probe: every 30s. Fast keepalive between SSH probes; on ping
#     failure invalidates the cached SSH success so the widget cannot
#     return to "active" without a fresh successful SSH probe.
#
# API-based widgets (bitbucket, codeberg, dm1, remotemanager) additionally
# poll a vendor status JSON API every 30s; the widget renders the
# worst-tier across (api, ssh, ping).

# Modules: each calls into probe-lib via probeReachability for the
# combined state, then renders a tmux segment. VPN-gated widgets
# return early (empty output) when tun0 is down.

# alwaysSegment renders like segment but is always visible, including
# when state is "on". Used for service toggles (era, vpn) where the
# widget is an interactive control, not a passive health monitor.
alwaysSegment() {
  local label=$1
  local cls=${2:-unknown}
  local color
  case $cls in
    on)      color=$ColorOn      ;;
    partial) color=$ColorPartial ;;
    off)     color=$ColorOff     ;;
    *)       color=$ColorUnknown ;;
  esac
  printf ' '
  fg "$color" "$label"
}

eraModule() { refresh era 30 eraProbe; alwaysSegment era "$(readState era)"; }
vpnModule() { refresh vpn  5 vpnProbe; alwaysSegment vpn "$(readState vpn)"; }

dm1Module()       { vpnUp || return; segment dm1 "$(probeWidget dm1)"; }
stashModule()     { vpnUp || return; segment sta "$(probeWidget stash)"; }
gitlabModule()    { vpnUp || return; segment glb "$(probeWidget gitlab)"; }
nexusModule()     { vpnUp || return; segment nex "$(probeWidget nexus)"; }
remotemanagerModule() { segment drm "$(probeWidget remotemanager)"; }
codebergModule()  { segment cbg "$(probeWidget codeberg)"; }
bitbucketModule() { segment bbk "$(probeWidget bitbucket)"; }
teamsModule()     { segment tms "$(probePing teams "$(widgetHost teams)" 300)"; }
ntfyModule()      { segment nfy "$(probePing ntfy  "$(widgetHost ntfy)"  300)"; }

# cachedHealthState reads the cached sub-states (ssh, ping, api) for a
# health widget and combines them WITHOUT triggering new probes. Used by
# healthSep and layoutCmd to check visibility without side effects.
cachedHealthState() {
  local key=$1
  local ssh ping api
  if [[ ${WidgetNoSsh[$key]:-no} == yes ]]; then
    ssh=skip
  else
    ssh=$(readState "${key}-ssh")
  fi
  ping=$(readState "${key}-ping")
  if [[ -n ${WidgetApiFn[$key]:-} ]]; then
    api=$(readState "${key}-api")
  else
    api=on
  fi
  combine "$ssh" "$ping" "$api"
}

# cachedPingState reads the cached ping state for a ping-only widget
# and maps it to on/off/unknown. Used by healthSep and layoutCmd.
cachedPingState() {
  local ping
  ping=$(readState "${1}-ping")
  case $ping in
    ok)   echo on ;;
    fail) echo off ;;
    *)    echo unknown ;;
  esac
}

# healthSep emits a pipe separator only if any health monitor widget
# is currently visible (state != on). Prevents two adjacent separators
# with nothing between them when all health monitors are healthy.
healthSep() {
  local state widget
  for widget in remotemanager codeberg bitbucket; do
    state=$(cachedHealthState $widget)
    [[ $state != on ]] && { printf ' '; fg colour240 '|'; return; }
  done
  for widget in teams ntfy; do
    state=$(cachedPingState $widget)
    [[ $state != on ]] && { printf ' '; fg colour240 '|'; return; }
  done
  if vpnUp; then
    for widget in dm1 stash gitlab nexus; do
      state=$(cachedHealthState $widget)
      [[ $state != on ]] && { printf ' '; fg colour240 '|'; return; }
    done
  fi
}

# ssh: shows inbound SSH connection count, but ONLY when there are
# any. Crostini doesn't run sshd by default so this is normally empty
# and the segment vanishes from the bar. Useful as a passive indicator
# for the rare host that does receive SSH.
sshModule() {
  local conns
  conns=$(ss -tn sport = :22 2>/dev/null | grep -c ESTAB || true)
  conns=${conns:-0}
  (( conns > 9 )) && conns=9
  if (( conns > 0 )); then
    printf ' '
    fg cyan "ssh ${conns}"
  fi
}

loadModule() {
  # /proc/loadavg has three values left-to-right: 1m, 5m, 15m. Render
  # bars in the same left-to-right order so the widget matches the
  # uptime/top convention.
  #
  # Normalization: bar 6 = 2 * nproc (the "2 processes waiting per
  # CPU, time to be concerned" threshold). Bars 7 and 8 give headroom
  # past that — bar 8 saturates at 2.8 * nproc. Linear from 0:
  #   idx = 1 + floor(load * 5 / (2 * nproc))
  # Below that line the bar is mostly empty; once you're past it,
  # things are getting crazy and the bar fills up fast.
  [[ -r /proc/loadavg ]] || return
  local nCpu
  nCpu=$(nproc)
  printf ' '
  awk -v nCpu="$nCpu" '{
    bars[1]="▁"; bars[2]="▂"; bars[3]="▃"; bars[4]="▄";
    bars[5]="▅"; bars[6]="▆"; bars[7]="▇"; bars[8]="█";
    text="";
    scale = 2 * nCpu;
    for (i=1; i<=3; i++) {
      idx = int($i * 5 / scale) + 1;
      if (idx > 8) idx = 8;
      if (idx < 1) idx = 1;
      text = text bars[idx];
    }
    print text;
  }' /proc/loadavg
}

# cpu uses /proc/stat with delta caching. The first call returns 0% since
# there's no baseline. Subsequent calls (every status-interval seconds)
# return the average CPU usage between samples.
cpuModule() {
  local stateFile=$State/cpu-stat
  # /proc/stat first line: "cpu user nice system idle iowait irq
  # softirq steal guest guest_nice". Read the whole row into an
  # indexed array so we don't have to spell out throwaway names —
  # the project bash style guide forbids leading-underscore locals.
  [[ -r /proc/stat ]] || return
  local fields
  read -ra fields < /proc/stat
  local user=${fields[1]} nice=${fields[2]} system=${fields[3]}
  local idle=${fields[4]} iowait=${fields[5]} irq=${fields[6]} softirq=${fields[7]} steal=${fields[8]}
  local active=$((user + nice + system + irq + softirq + steal))
  local total=$((active + idle + iowait))
  local pct=0
  if [[ -e $stateFile ]]; then
    local prevActive prevTotal
    read -r prevActive prevTotal < "$stateFile"
    local diffTotal=$((total - prevTotal))
    if (( diffTotal > 0 )); then
      pct=$(( (active - prevActive) * 100 / diffTotal ))
    fi
  fi
  printf '%s %s' "$active" "$total" > "$stateFile"
  thresholdSegment cpu "$pct"
}

memModule() {
  [[ -r /proc/meminfo ]] || return
  local total avail
  total=$(awk '/^MemTotal:/{print $2}'     /proc/meminfo)
  avail=$(awk '/^MemAvailable:/{print $2}' /proc/meminfo)
  local pct=$(( (total - avail) * 100 / total ))
  thresholdSegment mem "$pct"
}

diskModule() {
  local pct
  pct=$(df --output=pcent / 2>/dev/null | tail -n1 | tr -d ' %')
  thresholdSegment dsk "${pct:-0}"
}

# batModule shows battery state when discharging in warning/critical range.
# Hidden when: charging, full, unknown, or capacity > 10%.
# Warning [10,5%): "H:MM bat" in partial color (dimmer than clock).
# Critical [5,0%]: percentage in white.
# Matches nixos-config UC-1b battery thresholds.
# Supports Crostini (/sys/class/power_supply/battery/) and standard
# Linux laptops (/sys/class/power_supply/BAT0/).
batModule() {
  local sysfs=${BatSysfs:-/sys/class/power_supply}
  local base
  if [[ -r $sysfs/battery/status ]]; then
    base=$sysfs/battery
  elif [[ -r $sysfs/BAT0/status ]]; then
    base=$sysfs/BAT0
  else
    return
  fi

  local status
  read -r status < "$base/status"
  [[ $status == Discharging ]] || return

  local capacity
  read -r capacity < "$base/capacity"
  (( capacity <= 10 )) || return

  # Critical: [5,0%] — show "N% bat" in white
  if (( capacity <= 5 )); then
    printf ' '
    fg "$ColorOn" "${capacity}%% bat"
    return
  fi

  # Warning: (10,5%] — show "H:MM" in partial color
  # Time remaining: charge_now/current_now (µAh/µA, standard ACPI),
  # charge_counter/current_now (µAh/µA, Crostini Android bridge), or
  # energy_now/power_now (µWh/µW, energy-based laptops). Same formula.
  local current=0 charge=0
  if [[ -r $base/charge_now && -r $base/current_now ]]; then
    read -r current < "$base/current_now"
    read -r charge  < "$base/charge_now"
  elif [[ -r $base/current_now && -r $base/charge_counter ]]; then
    read -r current < "$base/current_now"
    read -r charge  < "$base/charge_counter"
  elif [[ -r $base/power_now && -r $base/energy_now ]]; then
    read -r current < "$base/power_now"
    read -r charge  < "$base/energy_now"
  fi
  (( current > 0 && charge > 0 )) || return

  local mins=$(( charge * 60 / current ))
  local hours=$(( mins / 60 ))
  local m=$(( mins % 60 ))
  printf ' '
  fg "$ColorPartial" "$(printf '%d:%02d' "$hours" "$m")"
}

# hostnameCmd prints a human-friendly hostname. On Crostini, reads from
# ~/crostini/hostname (the real machine name) since the container hostname
# is always "penguin".
hostnameCmd() {
  if [[ -r ~/crostini/hostname ]]; then
    cat ~/crostini/hostname
  else
    hostname
  fi
}

# canLoadCmd checks whether the current tmux session should load the
# panel. True when SSH_CONNECTION is set (non-empty) and WAYLAND_DISPLAY
# is absent — i.e., an SSH session without a desktop. Reads session env
# via tmux show-env (populated by update-environment from the client).
canLoadCmd() {
  tmux show-env SSH_CONNECTION 2>/dev/null | grep -q '=.' &&
    ! tmux show-env WAYLAND_DISPLAY 2>/dev/null | grep -q '=.'
}

# Click handlers. Toggling services for era and vpn matches the waybar
# on-click bindings. URL-bound widgets open the URL in the default
# browser via xdg-open (which on Crostini routes to ChromeOS Chrome).

clickModule() {
  local m=${1:-}
  case $m in
    era)
      if systemctl --user is-active --quiet era-mcp; then
        systemctl --user stop era-mcp
      else
        systemctl --user start era-mcp
      fi
      ;;
    vpn)
      if ip link show tun0 >/dev/null 2>&1; then
        vpn down
      else
        vpn up
      fi
      ;;
    dm1)       xdg-open https://dm1.devdevicecloud.com/ui/ ;;
    stash)     xdg-open https://stash.digi.com/ ;;
    gitlab)    xdg-open https://gitlab.drm.ninja/ ;;
    nexus)     xdg-open https://nexus.digi.com/ ;;
    remotemanager) xdg-open https://remotemanager.digi.com/ ;;
    codeberg)  xdg-open https://codeberg.org/ ;;
    bitbucket) xdg-open https://bitbucket.org/ ;;
    teams)     xdg-open https://teams.microsoft.com/ ;;
    ntfy)      xdg-open https://ntfy.sh/ ;;
    ssh)       tmux display-popup -E -h 60% -w 80% 'ss -tn sport = :22; echo; read -n1 -p "press any key "' ;;
    load)      tmux display-popup -E -h 90% -w 90% btop ;;
    *)         tmux display-message "panel: unknown click target '${m}'" ;;
  esac
}

# layoutCmd toggles tmux between 1-line and 2-line status bar based on
# whether the window list + right-side content fits the terminal width.
# Called silently from the status format every refresh (5s) and from
# tmux hooks on resize/window changes. Idempotent — skips if already
# in the correct mode.
layoutCmd() {
  local width session
  IFS=$'\t' read -r width session < <(tmux display-message -p '#{client_width}	#S')
  local hostname
  hostname=$(hostnameCmd)

  # Window list display width: session name in brackets + window tabs.
  local winWidth
  winWidth=$(tmux list-windows -F '#I:#W#{window_flags}' \
    | awk -v base="$(( ${#session} + 3 ))" '{s+=length+1} END {print s+base}')

  # Right-side display width: count actually-visible widgets by checking
  # cached state. Always-visible: vpn, era, load (3). Health widgets only
  # count when their combined state != on.
  local nWidgets=3  # vpn era load
  local healthVisible=0
  local widget state
  for widget in remotemanager codeberg bitbucket; do
    state=$(cachedHealthState $widget)
    if [[ $state != on ]]; then
      nWidgets=$(( nWidgets + 1 ))
      healthVisible=1
    fi
  done
  for widget in teams ntfy; do
    state=$(cachedPingState $widget)
    if [[ $state != on ]]; then
      nWidgets=$(( nWidgets + 1 ))
      healthVisible=1
    fi
  done
  if vpnUp; then
    for widget in dm1 stash gitlab nexus; do
      state=$(cachedHealthState $widget)
      if [[ $state != on ]]; then
        nWidgets=$(( nWidgets + 1 ))
        healthVisible=1
      fi
    done
  fi
  local nSeps=$(( healthVisible ? 3 : 2 ))
  # clock: " MM/DD HH:MM" = 12, hostname: " name" = 1 + length
  local rightWidth=$(( nWidgets * 4 + nSeps * 2 + 12 + ${#hostname} + 1 ))

  local current
  current=$(tmux show-option -v status 2>/dev/null)
  # Fall back to global if no session override yet.
  [[ -z $current ]] && current=$(tmux show-option -gv status 2>/dev/null)

  if (( winWidth + rightWidth < width )); then
    [[ $current == on ]] && return
    tmux set status on
    tmux set status-right '#{E:#{@panel-right}}'
  else
    [[ $current == 2 ]] && return
    tmux set status 2
    tmux set status-right ''
  fi
}

main() {
  local cmd=${1:-}
  shift || true
  case $cmd in
    era)        eraModule ;;
    vpn)        vpnModule ;;
    dm1)        dm1Module ;;
    stash)      stashModule ;;
    gitlab)     gitlabModule ;;
    nexus)      nexusModule ;;
    remotemanager) remotemanagerModule ;;
    codeberg)   codebergModule ;;
    bitbucket)  bitbucketModule ;;
    teams)      teamsModule ;;
    ntfy)       ntfyModule ;;
    ssh)        sshModule ;;
    load)       loadModule ;;
    cpu)        cpuModule ;;
    mem)        memModule ;;
    disk)       diskModule ;;
    bat)        batModule ;;
    healthsep)  healthSep ;;
    hostname)   hostnameCmd ;;
    can-load)   canLoadCmd ;;
    poll)       pollAll ;;
    click)      clickModule "$@" ;;
    layout)     layoutCmd ;;
    *)
      echo "usage: panel {era|vpn|dm1|stash|gitlab|nexus|remotemanager|codeberg|bitbucket|teams|ntfy|ssh|load|cpu|mem|disk|bat|healthsep|hostname|can-load|poll|layout|click <m>}" >&2
      exit 1
      ;;
  esac
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  main "$@"
fi
