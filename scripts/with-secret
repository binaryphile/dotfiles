#!/usr/bin/env bash

# with-secret VAR FILE CMD [ARGS...] — run CMD with secret from FILE as VAR.
# Secret is in child env only, not exported to the calling shell.
# Use as a last-resort compatibility shim when the tool requires an env var.
# Prefer tools that read secrets from files directly.

[[ $# -ge 3 ]] || { echo "usage: with-secret VAR FILE CMD [ARGS...]" >&2; exit 1; }
var=$1 file=$2; shift 2
[[ -f "$file" ]] || { echo "with-secret: secret not found: $file" >&2; exit 1; }
exec env "$var=$(< "$file")" "$@"
