#!/usr/bin/env bash
# pre-commit guard: refuse if staged flake.lock has nixpkgs.locked.rev
# different from era's canonical rev (~/projects/era/flake.lock).
#
# Installed into each managed dir's .git/hooks/pre-commit by
# flakeLockHookTask in update-env. Pairs with flakeLockPinTask which
# repairs drift; this script catches drift at commit time so the user
# can re-pin before the bad lock propagates.
#
# Exit 0: no problem (no staged flake.lock, or rev matches, or canonical
#         not available).
# Exit 1: staged flake.lock disagrees with canonical -- commit refused.

set -u

canonical=$HOME/projects/era/flake.lock
[[ -f $canonical ]] || exit 0  # canonical not present -- cannot enforce

# Only act if flake.lock is in this commit's index.
git diff --cached --name-only -- flake.lock | grep -qxF flake.lock || exit 0

canonicalRev=$(jq -r '.nodes.nixpkgs.locked.rev // empty' "$canonical")
[[ -n $canonicalRev ]] || exit 0  # canonical lacks nixpkgs node -- skip

stagedRev=$(git show :flake.lock 2>/dev/null | jq -r '.nodes.nixpkgs.locked.rev // empty')

[[ $stagedRev == "$canonicalRev" ]] && exit 0

cat >&2 <<EOF
error: flake.lock nixpkgs rev does not match era canonical
  staged:    ${stagedRev:-<missing or unparsable>}
  canonical: $canonicalRev  (from ~/projects/era/flake.lock)
fix:        run \`update-env\` to re-pin all managed flake.lock files
            OR \`git restore flake.lock\` to discard the drift
override:   git commit --no-verify (audit-visible; only use when you
            intend to advance the canonical pin -- update era first)
EOF
exit 1
