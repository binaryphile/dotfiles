#!/usr/bin/env bash
# scaffold - create a new project with nix-wrapper, .envrc, and flake.nix
#
# Usage: scaffold <project-dir> [packages...]
# Default packages: bash coreutils git
#
# Can also be sourced as a library.  Set ProjectDirW before calling task functions.

# Naming Policy:
#
# All function and variable names are camelCased.
#
# Private function names begin with lowercase letters.
# Public function names begin with uppercase letters.
# Function names are prefixed with "scaffold." (always lowercase) so they are namespaced.
#
# Local variable names begin with lowercase letters, e.g. localVariable.
#
# Global variable names begin with uppercase letters, e.g. GlobalVariable.
# Since this is a library, global variable names are also namespaced by suffixing them with
# the randomly-generated letter W, e.g. GlobalVariableW.
# Global variables are not public.  Library consumers should not be aware of them.
# If users need to interact with them, create accessor functions for the purpose.
#
# Variable declarations that are name references borrow the environment namespace, e.g.
# "local -n ARRAY=$1".

main() {
  set -euo pipefail

  [[ $# -ge 1 ]] || { echo "usage: scaffold <project-dir> [packages...]" >&2; exit 1; }

  ProjectDirW=$1
  shift

  if [[ $# -eq 0 ]]; then
    PackagesW=(bash coreutils git)
  else
    PackagesW=("$@")
  fi

  section scaffold
  scaffold.MkdirTask "$ProjectDirW/bin"
  scaffold.NixWrapperTask
  scaffold.GitExcludeBinTask
  task.Ln nix-wrapper "$ProjectDirW/bin/claude"
  scaffold.EnvrcTask
  scaffold.DirenvAllowTask
  scaffold.FlakeNixTask

  task.Summarize
}

## task definitions

scaffold.MkdirTask() {
  local dir=$1
  desc  "create $dir"
  exist "$dir"
  cmd   "mkdir -p '$dir'"
}

scaffold.NixWrapperTask() {
  local path=$ProjectDirW/bin/nix-wrapper
  desc 'install bin/nix-wrapper'

  scaffold.nixWrapperUpToDate() { [[ -f $path ]] && diff -q "$path" <(scaffold.NixWrapperContent) >/dev/null 2>&1; }
  ok scaffold.nixWrapperUpToDate

  scaffold.installNixWrapper() {
    scaffold.NixWrapperContent > "$path"
    chmod +x "$path"
  }
  cmd scaffold.installNixWrapper
}

scaffold.EnvrcTask() {
  local path=$ProjectDirW/.envrc
  desc 'install .envrc'

  scaffold.envrcUpToDate() { [[ -f $path ]] && diff -q "$path" <(scaffold.EnvrcContent) >/dev/null 2>&1; }
  ok scaffold.envrcUpToDate

  scaffold.installEnvrc() { scaffold.EnvrcContent > "$path"; }
  cmd scaffold.installEnvrc
}

scaffold.GitExcludeBinTask() {
  local excludeFile=$ProjectDirW/.git/info/exclude
  desc "git exclude /bin in $ProjectDirW"
  check "[[ -d '$ProjectDirW/.git' ]]"
  ok "git -C '$ProjectDirW' ls-files --error-unmatch bin/ &>/dev/null || grep -qxF /bin '$excludeFile' 2>/dev/null"

  cmd "echo /bin >> '$excludeFile'"
}

scaffold.DirenvAllowTask() {
  local path=$ProjectDirW/.envrc
  desc "direnv allow $ProjectDirW"
  check "diff -q '$path' <(scaffold.EnvrcContent) >/dev/null 2>&1"
  ok "grep -rq '$path' ~/.local/share/direnv/allow/ 2>/dev/null"

  cmd "direnv allow '$ProjectDirW'"
}

scaffold.FlakeNixTask() {
  local path=$ProjectDirW/flake.nix
  desc 'install flake.nix'

  scaffold.flakeUpToDate() { [[ -f $path ]] && diff -q "$path" <(scaffold.FlakeNixContent) >/dev/null 2>&1; }
  ok scaffold.flakeUpToDate

  scaffold.installFlake() { scaffold.FlakeNixContent > "$path"; }
  cmd scaffold.installFlake
}

## content generators

scaffold.NixWrapperContent() {
  cat << 'EOF'
#!/usr/bin/env bash
# Generic wrapper for running commands inside nix develop.
# Symlink to this file with the name of the command you want to wrap.
# Example: ln -s nix-wrapper node

set -eu

# Check if flake.nix exists in current directory or any ancestor
has_flake() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    [[ -f "$dir/flake.nix" ]] && return 0
    dir=$(dirname "$dir")
  done
  return 1
}

main() {
  local asCalled folder prog
  asCalled=$(basename "$0")
  folder=$(cd "$(dirname "$0")"; pwd)

  # Find the real program, excluding our bin/ directory
  # May be empty for commands that only exist inside nix (node, npm)
  prog=$(type -Pa "$asCalled" | grep -v "^$folder/" | head -1)

  # IN_NIX_SHELL is set automatically by nix develop (even with -c)
  # If already in nix develop, or no flake.nix found, run prog directly
  # Otherwise use nix develop to get the right environment
  if [[ ${IN_NIX_SHELL:-} == impure ]] || ! has_flake; then
    exec "$prog" "$@"
  else
    # Use prog if found, otherwise asCalled (nix will provide it)
    exec nix develop -c "${prog:-$asCalled}" "$@"
  fi
}

main "$@"
EOF
}

scaffold.EnvrcContent() {
  cat << 'EOF'
export PROJECT_ROOT=$(cd "$(dirname "$BASH_SOURCE")"; pwd)
export PATH=$PROJECT_ROOT/bin:$PATH
EOF
}

scaffold.FlakeNixContent() {
  local pkgList=""
  local pkg
  for pkg in "${PackagesW[@]}"; do
    pkgList+=$'\n'"            $pkg"
  done

  cat << FLAKE
{
  description = "Development environment";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs";
    flake-utils.url = "github:numtide/flake-utils";
  };

  outputs = { self, nixpkgs, flake-utils }:
    flake-utils.lib.eachDefaultSystem (system:
      let
        pkgs = import nixpkgs {
          inherit system;
        };
      in {
        devShells.default = pkgs.mkShell {
          buildInputs = with pkgs; [$pkgList
          ];
        };
      }
    );
}
FLAKE
}

## boilerplate

declare -F task.Ln >/dev/null ||
  source "${TASK_BASH_LIB:?task.bash not installed -- run home-manager switch}"

return 2>/dev/null    # stop if sourced, for use as library
main "$@"
