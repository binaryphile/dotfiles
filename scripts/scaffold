#!/usr/bin/env bash
# scaffold - create a new project with nix-wrapper, .envrc, and flake.nix
#
# Usage: scaffold <project-dir> [packages...]
# Default packages: bash coreutils git
#
# Can also be sourced to call individual task functions.
# Set ProjectDir before calling them.

# Naming Policy:
#
# This is a standalone script -- no namespace prefix on functions, no suffix on globals.
# Public function names use PascalCase. Private function names use camelCase.
# Local variable names begin with lowercase, e.g. localVariable.
# Global variable names begin with uppercase, e.g. GlobalVariable.
# Name references borrow the environment namespace, e.g. local -n ARRAY=$1.

main() {
  set -euo pipefail

  [[ $# -ge 1 ]] || { echo "usage: scaffold <project-dir> [packages...]" >&2; exit 1; }

  ProjectDir=$1
  shift

  if [[ $# -eq 0 ]]; then
    Packages=(bash coreutils git)
  else
    Packages=("$@")
  fi

  section scaffold
  MkdirTask "$ProjectDir/bin"
  NixWrapperTask
  GitExcludeBinTask
  task.Ln nix-wrapper "$ProjectDir/bin/claude"
  EnvrcTask
  DirenvAllowTask
  FlakeNixTask

  task.Summarize
}

## task definitions

MkdirTask() {
  local dir=$1
  desc  "create $dir"
  exist "$dir"
  cmd   "mkdir -p '$dir'"
}

NixWrapperTask() {
  local path=$ProjectDir/bin/nix-wrapper
  desc 'install bin/nix-wrapper'

  # If the file is git-tracked, it's managed by the repo -- skip scaffolding.
  nixWrapperUpToDate() {
    git -C "$ProjectDir" ls-files --error-unmatch bin/nix-wrapper &>/dev/null ||
      { [[ -f $path ]] && diff -q "$path" <(NixWrapperContent) >/dev/null 2>&1; }
  }
  ok nixWrapperUpToDate

  installNixWrapper() {
    NixWrapperContent > "$path"
    chmod +x "$path"
  }
  cmd installNixWrapper
}

EnvrcTask() {
  local path=$ProjectDir/.envrc
  desc 'install .envrc'

  envrcUpToDate() { [[ -f $path ]] && diff -q "$path" <(EnvrcContent) >/dev/null 2>&1; }
  ok envrcUpToDate

  installEnvrc() { EnvrcContent > "$path"; }
  cmd installEnvrc
}

GitExcludeBinTask() {
  local excludeFile=$ProjectDir/.git/info/exclude
  desc "git exclude /bin in $ProjectDir"
  check "[[ -d '$ProjectDir/.git' ]]"
  ok "git -C '$ProjectDir' ls-files --error-unmatch bin/ &>/dev/null || grep -qxF /bin '$excludeFile' 2>/dev/null"

  cmd "echo /bin >> '$excludeFile'"
}

DirenvAllowTask() {
  local path=$ProjectDir/.envrc
  desc "direnv allow $ProjectDir"
  check "diff -q '$path' <(EnvrcContent) >/dev/null 2>&1"
  ok "grep -rq '$path' ~/.local/share/direnv/allow/ 2>/dev/null"

  cmd "direnv allow '$ProjectDir'"
}

FlakeNixTask() {
  local path=$ProjectDir/flake.nix
  desc 'install flake.nix'

  flakeUpToDate() { [[ -f $path ]] && diff -q "$path" <(FlakeNixContent) >/dev/null 2>&1; }
  ok flakeUpToDate

  installFlake() { FlakeNixContent > "$path"; }
  cmd installFlake
}

## content generators

NixWrapperContent() {
  cat << 'EOF'
#!/usr/bin/env bash
# Generic wrapper for running commands inside nix develop.
# Symlink to this file with the name of the command you want to wrap.
# Example: ln -s nix-wrapper node

set -eu

# Check if flake.nix exists in current directory or any ancestor
has_flake() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    [[ -f "$dir/flake.nix" ]] && return 0
    dir=$(dirname "$dir")
  done
  return 1
}

main() {
  local asCalled folder prog
  asCalled=$(basename "$0")
  folder=$(cd "$(dirname "$0")"; pwd)

  # Find the real program, excluding our bin/ directory
  # May be empty for commands that only exist inside nix (node, npm)
  prog=$(type -Pa "$asCalled" | grep -v "^$folder/" | head -1)

  # IN_NIX_SHELL is set automatically by nix develop (even with -c)
  # If already in nix develop, or no flake.nix found, run prog directly
  # Otherwise use nix develop to get the right environment
  if [[ ${IN_NIX_SHELL:-} == impure ]] || ! has_flake; then
    exec "$prog" "$@"
  else
    # Use prog if found, otherwise asCalled (nix will provide it)
    exec nix develop -c "${prog:-$asCalled}" "$@"
  fi
}

main "$@"
EOF
}

EnvrcContent() {
  cat << 'EOF'
export PROJECT_ROOT=$(cd "$(dirname "$BASH_SOURCE")"; pwd)
export PATH=$PROJECT_ROOT/bin:$PATH
EOF
}

FlakeNixContent() {
  local pkgList=""
  local pkg
  for pkg in "${Packages[@]}"; do
    pkgList+=$'\n'"            $pkg"
  done

  cat << FLAKE
{
  description = "Development environment";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs";
    flake-utils.url = "github:numtide/flake-utils";
  };

  outputs = { self, nixpkgs, flake-utils }:
    flake-utils.lib.eachDefaultSystem (system:
      let
        pkgs = import nixpkgs {
          inherit system;
        };
      in {
        devShells.default = pkgs.mkShell {
          buildInputs = with pkgs; [$pkgList
          ];
        };
      }
    );
}
FLAKE
}

## boilerplate

declare -F task.Ln >/dev/null ||
  source "${TASK_BASH_LIB:?task.bash not installed -- run home-manager switch}"

return 2>/dev/null
main "$@"
