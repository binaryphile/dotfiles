#!/usr/bin/env bash
# claude-agent-identity -- SessionStart hook mechanizing the mux-identity
# export discipline (era docs/evtctl.md "Mux identity contract").
#
# Synchronously writes `export EVTCTL_AGENT="<role>@<host>"` to
# $CLAUDE_ENV_FILE so subsequent Bash tool invocations carry the identity.
# Backgrounds a /session-start interaction event publish so session startup
# does not block on era-serve latency.
#
# Identity resolution (mirrors evtctl's hostnameDerived):
#   host  = ~/crostini/hostname if present, else $(hostname)
#   role  = ~/.claude/agent-role contents if present
#   agent = "claude-${role}@${host}" when role set, else "${USER}@${host}"
#
# See ~/dotfiles/docs/use-cases.md UC-16 and docs/design.md
# "Claude Agent Identity Hook (UC-16)" for full context.

IFS=$'\n'
set -o noglob
set -eufo pipefail

# Sourcing guard for tesht.
[[ ${__CLAUDE_AGENT_IDENTITY_TESTING:-} ]] && return 2>/dev/null

main() {
  local input_ source_ session_id_ model_ version_ cwd_
  local host_ role_ agent_ ts_ payload_

  # Read SessionStart hook stdin (JSON). Defensive: empty body -> {}.
  input_=$(cat || true)
  [[ -n $input_ ]] || input_='{}'

  source_=$(jq -r '.source // "unknown"' <<<"$input_" 2>/dev/null || echo "unknown")
  session_id_=$(jq -r '.session_id // "unknown"' <<<"$input_" 2>/dev/null || echo "unknown")
  model_=$(jq -r '.model // "unknown"' <<<"$input_" 2>/dev/null || echo "unknown")
  version_=$(jq -r '.version // "unknown"' <<<"$input_" 2>/dev/null || echo "unknown")
  cwd_=$(jq -r '.cwd // ""' <<<"$input_" 2>/dev/null || echo "")

  # Resolve hostname (Crostini-aware).
  if [[ -r $HOME/crostini/hostname ]]; then
    host_=$(< $HOME/crostini/hostname)
  else
    host_=$(hostname 2>/dev/null || echo "unknown-host")
  fi

  # Resolve role marker.
  role_=""
  [[ -r $HOME/.claude/agent-role ]] && role_=$(< $HOME/.claude/agent-role)

  # Compose canonical identity.
  if [[ -n $role_ ]]; then
    agent_="claude-${role_}@${host_}"
  else
    agent_="${USER:-anon}@${host_}"
  fi

  # SYNC: write export to $CLAUDE_ENV_FILE so subsequent Bash tool calls
  # inherit EVTCTL_AGENT. Defensive: silently skip if env var unset
  # (direct CLI invocation outside hook context).
  if [[ -n ${CLAUDE_ENV_FILE:-} ]]; then
    printf 'export EVTCTL_AGENT=%q\n' "$agent_" >> $CLAUDE_ENV_FILE
  fi

  # Set EVTCTL_AGENT in this script's process env so the backgrounded
  # evtctl invocation carries metadata.agent attribution.
  export EVTCTL_AGENT="$agent_"

  # ASYNC: publish /session-start event in background; errors swallowed.
  # cd into the session's cwd so evtctl routes to tasks.<basename(cwd)>.
  ts_=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  payload_="/session-start source=$source_ session_id=$session_id_ model=$model_ version=$version_ agent=$agent_ started_at=$ts_"
  if [[ -n $cwd_ && -d $cwd_ ]]; then
    ( cd "$cwd_" && evtctl interaction "$payload_" </dev/null >/dev/null 2>&1 ) &
  else
    ( evtctl interaction "$payload_" </dev/null >/dev/null 2>&1 ) &
  fi
  disown 2>/dev/null || true

  exit 0
}

main "$@"
