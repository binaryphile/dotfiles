#!/usr/bin/env bash
# claude-bash-lint-guard — PreToolUse hook that lints bash via the convention
# plugin (~/projects/shellcheck-convention-plugin) and BLOCKS on errors
# (warnings/notes are reported but not blocking).
#
# Anchor: 2026-06-15 — operator "i want to figure out how to get you to always
# write shell in compliance with the bash style guide in the first place ...
# but until that day, the linter works well. i just need to get you to run
# that reliably instead." Follow-up Q: "does that lint when you save the file
# or when you run it?" → originally only on Bash tool; extended to Write/Edit.
#
# Memory-only enforcement of CLAUDE.md #30533 "Bash author-time conformance"
# failed: the rule existed; the agent ignored it. This guard makes the lint
# pass mandatory at tool-call time.
#
# SCOPE:
#   Bash  — lints the .command field (snippet wrapped with discipline header
#           if not already present)
#   Write — lints .content if .file_path looks like bash (extension OR shebang)
#   Edit  — lints .new_string fragment if .file_path looks like bash. Fragment-
#           only (not full post-edit file) keeps it fast and catches typos /
#           naming / IFS-marker issues in the new code; full-file lint would
#           require literal old/new replacement which bash parameter
#           substitution does not provide (glob chars in old_string would
#           mis-match).
#
# READS: PreToolUse JSON from stdin.
# EXITS: 0 = allow (lint clean OR only notes/warnings); 2 = block (error-severity finding); stderr explains.

IFS=$'\n'
set -o noglob
set -eufo pipefail

input_=$(cat)
tool_=$(jq -r '.tool_name // ""' <<<"$input_")

# Extract per-tool: content to lint + a path hint (for is-bash detection).
content_=""
path_=""
case $tool_ in
  Bash)
    content_=$(jq -r '.tool_input.command // ""' <<<"$input_")
    path_="snippet.bash"  # synthetic — Bash snippets are always bash
    ;;
  Write)
    content_=$(jq -r '.tool_input.content // ""' <<<"$input_")
    path_=$(jq -r '.tool_input.file_path // ""' <<<"$input_")
    ;;
  Edit)
    content_=$(jq -r '.tool_input.new_string // ""' <<<"$input_")
    path_=$(jq -r '.tool_input.file_path // ""' <<<"$input_")
    ;;
  *)
    exit 0
    ;;
esac

[[ -n $content_ ]] || { exit 0; }

# isbash_ predicate: extension match OR shebang match in content/file.
isbash_() {
  local p_=$1 c_=$2
  case $p_ in
    *.bash|*.sh) return 0 ;;
  esac
  # Shebang in the content itself (Write of a new script).
  local first_=${c_%%$'\n'*}
  [[ $first_ == "#!/usr/bin/env bash" || $first_ == "#!/bin/bash" || $first_ == "#!/usr/bin/bash" ]] && return 0
  # Shebang in the existing file on disk (Edit of an existing bash script).
  if [[ -r $p_ ]]; then
    local diskfirst_
    diskfirst_=$(head -1 "$p_" 2>/dev/null)
    [[ $diskfirst_ == "#!/usr/bin/env bash" || $diskfirst_ == "#!/bin/bash" || $diskfirst_ == "#!/usr/bin/bash" ]] && return 0
  fi
  return 1
}

isbash_ "$path_" "$content_" || { exit 0; }

plugin_so_=$HOME/projects/shellcheck-convention-plugin/result/lib/shellcheck/plugins/libconvention-checks.so
if [[ ! -r $plugin_so_ ]]; then
  # Plugin not built on this host. Skip silently rather than blocking every
  # bash-shaped tool call. Once update-env builds the plugin, this branch
  # becomes dead.
  exit 0
fi

# Plugin requires the .so live under a writable plugin-dir to dlopen.
plugin_dir_=${TMPDIR:-/tmp}/claude-bash-lint-plugin
mkdir -p "$plugin_dir_"
if [[ ! -e "$plugin_dir_"/libconvention-checks.so ]] \
   || [[ "$plugin_so_" -nt "$plugin_dir_"/libconvention-checks.so ]]; then
  cp "$plugin_so_" "$plugin_dir_"/ && chmod u+w "$plugin_dir_"/libconvention-checks.so
fi

tmp_=$(mktemp --suffix=.bash)
trap 'rm -f "$tmp_"' EXIT

# Decide whether to wrap with discipline header. Wrap when the snippet
# doesn't already have it (so SC9010 doesn't fire on every snippet).
# Write of a complete file usually has its own header; Bash snippets usually
# don't; Edit fragments rarely do.
if grep -qF 'set -o noglob' <<<"$content_" && grep -qF 'IFS=' <<<"$content_"; then
  printf '%s\n' "$content_" >"$tmp_"
  line_offset_=0
else
  {
    printf '#!/usr/bin/env bash\n'
    printf "IFS=\$'\\\\n'\nset -o noglob\n"
    printf '%s\n' "$content_"
  } >"$tmp_"
  line_offset_=3
fi

lint_out_=$(shellcheck --plugin-dir "$plugin_dir_" -f gcc "$tmp_" 2>&1 || true)
findings_=$(grep -E "^${tmp_}:" <<<"$lint_out_" || true)

[[ -n $findings_ ]] || { exit 0; }

# Filter to error-severity findings. For Edit (fragment lint), drop
# SC1xxx/SC2xxx parse errors — fragments often aren't self-contained
# (mid-function, mid-heredoc) and parse errors there are false positives.
# Convention-plugin errors (SC9xxx) are local checks (naming, quoting, IFS)
# that don't depend on full-file context, so they remain blocking.
errors_=$(grep -E ': error: ' <<<"$findings_" || true)
if [[ $tool_ == "Edit" ]]; then
  errors_=$(grep -E '\[SC9[0-9]{3}\]' <<<"$errors_" || true)
fi

if [[ -z $errors_ ]]; then
  # Warnings/notes only (or fragment parse errors filtered out for Edit) —
  # surface but allow. Blocking on naming-hint notes (SC9003 unneeded quotes)
  # would over-fire on legitimate one-liners.
  printf 'shellcheck (non-blocking, tool=%s):\n%s\n' "$tool_" "$findings_" >&2
  exit 0
fi

cat <<EOF >&2
BLOCKED: $tool_ failed shellcheck-convention-plugin lint.

This guard implements CLAUDE.md #30533 "Bash author-time conformance":
write to convention on the first pass, not lint-discovery after.

Path: $path_
Findings (line numbers offset by $line_offset_ for the wrapped discipline header):
$findings_

Reference: ~/projects/jeeves/guides/bash-style-guide.md
Plugin docs: ~/projects/shellcheck-convention-plugin/docs/
Guard source: ~/dotfiles/claude/claude-bash-lint-guard

To bypass for a known-good snippet, prepend the canonical discipline header
(IFS=\$'\\n'; set -o noglob) and address each finding. If the finding is a
false positive, file an issue against shellcheck-convention-plugin.
EOF
exit 2
