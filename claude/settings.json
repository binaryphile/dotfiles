{
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {"hooks": [{"type": "command", "command": "era-hook", "async": true}]},
      {"hooks": [{"type": "command", "command": "claude-budget"}]},
      {"hooks": [{"type": "command", "command": "claude-agent-identity"}]}
    ],
    "Stop": [
      {"hooks": [{"type": "command", "command": "era-hook", "async": true}]},
      {"hooks": [{"type": "command", "command": "claude-budget", "async": true}]}
    ],
    "UserPromptSubmit": [
      {"hooks": [{"type": "command", "command": "era-hook", "async": true}]}
    ],
    "PermissionRequest": [{"hooks": [{"type": "command", "command": "era-hook"}]}],
    "SubagentStart": [{"hooks": [{"type": "command", "command": "era-hook", "async": true}]}],
    "SubagentStop": [{"hooks": [{"type": "command", "command": "era-hook", "async": true}]}],
    "SessionEnd": [
      {"hooks": [{"type": "command", "command": "era-hook", "async": true}]},
      {"hooks": [{"type": "command", "command": "claude-budget", "async": true}]}
    ],
    "PreCompact": [{"hooks": [{"type": "command", "command": "era-hook", "async": true}]}],
    "PostCompact": [{"hooks": [{"type": "command", "command": "era-hook", "async": true}]}],
    "PreToolUse": [
      {"hooks": [{"type": "command", "command": "claude-bg-bash-guard"}]},
      {"hooks": [{"type": "command", "command": "claude-guide-load-guard"}]},
      {"hooks": [{"type": "command", "command": "claude-bash-lint-guard"}]}
    ]
  }
}
