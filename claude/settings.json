{
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "era": {"type": "http", "url": "http://127.0.0.1:8080/mcp"}
  },
  "hooks": {
    "SessionStart": [{"hooks": [{"type": "command", "command": "era-hook", "async": true}]}],
    "Stop": [{"hooks": [{"type": "command", "command": "era-hook", "async": true}]}],
    "UserPromptSubmit": [{"hooks": [{"type": "command", "command": "era-hook", "async": true}]}],
    "PermissionRequest": [{"hooks": [{"type": "command", "command": "era-hook"}]}]
  }
}
