# Liquidprompt 2.2.1 theme overrides.
#
# Colors use the defaults set by lp_activate() — they match what the
# old vendored theme had. Only marks and layout strings need overrides.
# See: https://liquidprompt.readthedocs.io/en/stable/theme/default.html

# Prompt marks
LP_MARK_DEFAULT=">"
LP_MARK_GIT=">"
LP_MARK_PERM=":"
LP_MARK_BRACKET_OPEN="["
LP_MARK_BRACKET_CLOSE="]"
LP_MARK_PREFIX=" "
LP_MARK_UNTRACKED="*"
LP_MARK_STASH="+"

# vim: set et sts=4 sw=4 tw=120 ft=sh:
