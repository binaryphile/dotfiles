# Liquidprompt 2.2.1 configuration.
#
# Only settings that differ from the upstream defaults are listed.
# See: https://liquidprompt.readthedocs.io/en/stable/config.html

# Theme overrides (marks, layout — colors use defaults).
# Sourced from init.bash AFTER liquidprompt because lp_activate()
# applies the default theme, overriding variables set before it.

# Behavior
LP_USER_ALWAYS=0              # hide user when same as logged-in user (default: 1)
LP_ENABLE_SUDO=1              # show sudo credential cache indicator (default: 0)
LP_ENABLE_SSH_COLORS=1        # color hostname by connection type (default: 0)
LP_ENABLE_VCS_ROOT=1          # show VCS info as root (default: 0)
LP_RUNTIME_THRESHOLD=20       # seconds before showing runtime (default: 2)
LP_DISPLAY_VALUES_AS_PERCENTS=1  # show temp as percentage (default: 0)

# Load shown as percentage of nproc — see liquid.theme override.
LP_ENABLE_LOAD=1

# Disabled features — either unused VCS or not needed on Crostini.
LP_ENABLE_SVN=0
LP_ENABLE_HG=0
LP_ENABLE_FOSSIL=0
LP_ENABLE_BZR=0
LP_ENABLE_RUNTIME=0

# Disabled — /proc/meminfo unreliable on Crostini after ChromeOS
# sleep/resume (division-by-zero). Panel monitors memory instead.
LP_ENABLE_RAM=0

# Disabled — Crostini exposes ChromeOS battery via sysfs but reports
# stale state. Panel has its own battery widget.
LP_ENABLE_BATT=0

# New-in-2.2.1 features disabled for version parity.
# Enable individually as needed.
LP_ENABLE_AWS_PROFILE=0
LP_ENABLE_CHROOT=0
LP_ENABLE_DETACHED_SESSIONS=0
LP_ENABLE_DISK=0
LP_ENABLE_DISPLAY=0
LP_ENABLE_ENV_VARS=0
LP_ENABLE_ERROR=0
LP_ENABLE_MODULES=0
LP_ENABLE_MODULES_VERSIONS=0
LP_ENABLE_MULTIPLEXER=0
LP_ENABLE_OS_KERNEL=0
LP_ENABLE_OS_VERSION=0
LP_ENABLE_PERL_VENV=0
LP_ENABLE_RUBY_VENV=0
LP_ENABLE_SHLVL=0
LP_ENABLE_TITLE_COMMAND=0
LP_ENABLE_TMUX_TITLE_PANES=0

# vim: ft=sh
