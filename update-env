# withCleanupTrap CLEANUP FUNC [ARGS...] -- call FUNC with INT/TERM trap that
# runs CLEANUP then re-raises the signal (preserving abort semantics).
# Saves and restores previous trap handlers. Does NOT suppress set -e inside
# FUNC -- the function runs under normal errexit behavior.
withCleanupTrap() {
  local cleanup=$1 func=$2; shift 2
  local prevInt prevTerm
  prevInt=$(trap -p INT)
  prevTerm=$(trap -p TERM)
  trap "$cleanup; trap - INT; kill -INT \$\$" INT
  trap "$cleanup; trap - TERM; kill -TERM \$\$" TERM
  "$func" "$@"
  local rc=$?
  eval "${prevInt:-trap - INT}"
  eval "${prevTerm:-trap - TERM}"
  return $rc
}

# sshKeyAction -- pure decision function for SSH key restore.
#
# Takes a nameref to an associative array with keys:
#   repoHasAge repoHasPub repoFp localExists localFp
#   cacheExists cacheFp hasTty hasAge
# All values are 0/1 (booleans) or strings (fingerprints, "" if absent).
#
# Returns 0 always. Prints exactly one action from this closed set:
#   present | collision | capture_to_repo
#   backup_then_cache | backup_then_age | backup_then_fail
#   restore_from_cache | restore_from_age | generate
#   missing_noninteractive
#   error_age_without_pub | error_pub_without_age | error_malformed_pub
#   error_age_not_found
#
# Decision table (abbreviated, see tests for full coverage):
#   local exists + repo match       -> present
#   local exists + repo mismatch    -> collision
#   local exists + repo unverifiable -> backup_then_{cache|age|fail}
#   local exists + no repo          -> capture_to_repo
#   cache valid + repo match/absent -> restore_from_cache
#   repo age available + tty + age  -> restore_from_age
#   nothing + tty                   -> generate
#   nothing + no tty                -> missing_noninteractive
sshKeyAction() {
  local -n STATE=$1

  # Pair invariant
  if (( STATE[repoHasAge] && !STATE[repoHasPub] )); then echo error_age_without_pub; return 0; fi
  if (( STATE[repoHasPub] && !STATE[repoHasAge] )); then echo error_pub_without_age; return 0; fi
  if (( STATE[repoHasPub] )) && [[ -z "${STATE[repoFp]}" ]]; then echo error_malformed_pub; return 0; fi

  # Tier 1: local key exists
  if (( STATE[localExists] )); then
    if [[ -n "${STATE[repoFp]}" ]]; then
      if [[ -n "${STATE[localFp]}" && "${STATE[localFp]}" == "${STATE[repoFp]}" ]]; then echo present; return 0; fi
      if [[ -n "${STATE[localFp]}" && "${STATE[localFp]}" != "${STATE[repoFp]}" ]]; then echo collision; return 0; fi
      # localFp empty = unverifiable -- backup, then try cache/age/fail
      if (( STATE[cacheExists] )) && [[ -n "${STATE[cacheFp]}" ]]; then
        if [[ -z "${STATE[repoFp]}" || "${STATE[cacheFp]}" == "${STATE[repoFp]}" ]]; then
          echo backup_then_cache; return 0
        fi
      fi
      if (( STATE[repoHasAge] )); then
        if (( !STATE[hasTty] )); then echo missing_noninteractive; return 0; fi
        if (( !STATE[hasAge] )); then echo error_age_not_found; return 0; fi
        echo backup_then_age; return 0
      fi
      echo backup_then_fail; return 0
    else
      echo capture_to_repo; return 0
    fi
  fi

  # Tier 2: mount cache
  if (( STATE[cacheExists] )) && [[ -n "${STATE[cacheFp]}" ]]; then
    if [[ -n "${STATE[repoFp]}" && "${STATE[cacheFp]}" != "${STATE[repoFp]}" ]]; then
      : # stale, fall through
    else
      echo restore_from_cache; return 0
    fi
  fi

  # Tier 3: age decrypt
  if (( STATE[repoHasAge] )); then
    if (( !STATE[hasTty] )); then echo missing_noninteractive; return 0; fi
    if (( !STATE[hasAge] )); then echo error_age_not_found; return 0; fi
    echo restore_from_age; return 0
  fi

  # Tier 4: generate
  if (( !STATE[hasTty] )); then echo missing_noninteractive; return 0; fi
  echo generate; return 0
}

restoreSshKeyImpl() {
  local hostname
  hostname=$(lib.MachineHostname)
  lib.ValidateHostname "$hostname" || return 1

  local repoAge="$HOME/dotfiles/ssh/id_ed25519_${hostname}.age"
  local repoPub="$HOME/dotfiles/ssh/id_ed25519_${hostname}.pub"
  local localKey="$HOME/.ssh/id_ed25519"
  local cacheDir="$CrostiniDir/ssh/$hostname"
  local cacheKey="$cacheDir/id_ed25519"

  mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
  rm -f "$CrostiniDir/np_id_ed25519" "$CrostiniDir/np_id_ed25519.pub"

  # Classify filesystem state into decision inputs
  local -A state=(
    [repoHasAge]=0 [repoHasPub]=0 [repoFp]=""
    [localExists]=0 [localFp]=""
    [cacheExists]=0 [cacheFp]=""
    [hasTty]=0 [hasAge]=0
  )

  [[ -f "$repoAge" ]] && state[repoHasAge]=1
  [[ -f "$repoPub" ]] && state[repoHasPub]=1
  (( state[repoHasPub] )) && state[repoFp]=$(pubFingerprint "$repoPub")
  [[ -f "$localKey" && -s "$localKey" ]] && state[localExists]=1
  (( state[localExists] )) && [[ -f "$localKey.pub" && -s "$localKey.pub" ]] && state[localFp]=$(pubFingerprint "$localKey.pub")
  [[ -f "$cacheKey" && -f "$cacheKey.pub" ]] && state[cacheExists]=1
  (( state[cacheExists] )) && state[cacheFp]=$(pubFingerprint "$cacheKey.pub")
  [[ -t 0 ]] && state[hasTty]=1
  command -v -- "$age" >/dev/null 2>&1 && state[hasAge]=1

  local action
  action=$(sshKeyAction state)

  # Dispatch -- mostly mechanical. capture_to_repo has additional runtime
  # checks (tty, age availability, .pub validity) that determine whether
  # capture is attempted. Capture failure is non-fatal (key is local-only).
  case $action in
    error_*)
      echo "ERROR: ${action#error_}" >&2
      return 1
      ;;

    present)
      # Trust: local .pub fingerprint matches repo .pub. Private key is trusted
      # to match .pub if the pair was produced by ssh-keygen or installKey.
      chmod 600 "$localKey"
      if [[ -d "$CrostiniDir" ]]; then
        mkdir -p "$cacheDir" 2>/dev/null
        installKey "$localKey" "$cacheKey"
      fi 2>/dev/null || true
      SshKeyStatus=present
      return 0
      ;;

    collision)
      echo "ERROR: hostname collision -- local (${state[localFp]}) != repo (${state[repoFp]})." >&2
      SshKeyStatus=collision
      return 1
      ;;

    backup_then_cache)
      sshKeyBackupLocal "$localKey" || return 1
      echo "Restoring SSH key from mount cache ($hostname)..."
      if ! installKey "$cacheKey" "$localKey"; then
        echo "ERROR: cache restore failed after backup." >&2
        return 1
      fi
      SshKeyStatus=restored
      return 0
      ;;

    backup_then_age)
      sshKeyBackupLocal "$localKey" || return 1
      sshKeyDecryptAndInstall "$repoAge" "$repoPub" "${state[repoFp]}" "$localKey" "$cacheDir" "$cacheKey"
      return
      ;;

    backup_then_fail)
      sshKeyBackupLocal "$localKey" || return 1
      echo "ERROR: cannot restore key (no cache or age available after backup)." >&2
      return 1
      ;;

    capture_to_repo)
      # Local key usable regardless of capture outcome.
      # Capture is best-effort -- requires tty, age, and valid .pub.
      chmod 600 "$localKey"
      if (( state[hasTty] && state[hasAge] )) && [[ -f "$localKey.pub" && -s "$localKey.pub" ]]; then
        local pubFp
        pubFp=$(pubFingerprint "$localKey.pub")
        if [[ -z "$pubFp" ]]; then
          echo "WARNING: local .pub is malformed. Cannot capture to repo." >&2
          echo "  Regenerate with: ssh-keygen -y -f ~/.ssh/id_ed25519 > ~/.ssh/id_ed25519.pub"
        elif ! sshKeyEncryptToRepo "$localKey" "$repoAge" "$repoPub" "$hostname"; then
          echo "WARNING: repo backup failed. Key is local-only -- will be lost on wipe." >&2
        fi
      fi
      SshKeyStatus=present
      return 0
      ;;

    restore_from_cache)
      # Trust: cache .pub fingerprint matches repo .pub. Private key trusted
      # to match .pub -- pair was installed together by installKey.
      echo "Restoring SSH key from mount cache ($hostname)..."
      if ! installKey "$cacheKey" "$localKey"; then
        echo "ERROR: cache restore failed." >&2
        return 1
      fi
      SshKeyStatus=restored
      ;;

    restore_from_age)
      # Trust: age bundle contains both private + public from same generation.
      # Bundled .pub fingerprint is validated against repo .pub sidecar after
      # decryption -- strongest verification path.
      sshKeyDecryptAndInstall "$repoAge" "$repoPub" "${state[repoFp]}" "$localKey" "$cacheDir" "$cacheKey"
      return
      ;;

    generate)
      sshKeyGenerate "$localKey" "$repoAge" "$repoPub" "$hostname" "$cacheDir" "$cacheKey"
      return
      ;;

    missing_noninteractive)
      echo "No SSH key available and no TTY. Run update-env interactively."
      SshKeyStatus=missing_noninteractive
      return 0
      ;;

    *)
      echo "ERROR: unexpected sshKeyAction result: $action" >&2
      return 1
      ;;
  esac
}

# sshKeyBackupLocal -- back up local key before overwriting. Returns 1 on failure.
sshKeyBackupLocal() {
  local localKey=$1
  echo "WARNING: local key exists but .pub is missing/invalid. Cannot verify." >&2
  local bakFile
  bakFile=$(mktemp "$localKey.bak.XXXXXX") || { echo "ERROR: cannot create backup"; return 1; } >&2
  echo "  Backing up to $bakFile before restoring from repo."
  if ! cp "$localKey" "$bakFile" || ! chmod 600 "$bakFile"; then
    echo "ERROR: backup failed. Will not overwrite local key." >&2
    return 1
  fi
  [[ -f "$localKey.pub" ]] && cp "$localKey.pub" "$bakFile.pub" 2>/dev/null
  return 0
}

# sshKeyDecryptAndInstall -- tier 3 implementation: decrypt .age, validate, install, cache.
sshKeyDecryptAndInstall() {
  local repoAge=$1 repoPub=$2 repoFp=$3 localKey=$4 cacheDir=$5 cacheKey=$6
  echo "Decrypting SSH key..."
  local stageDir
  stageDir=$(mktemp -d "$HOME/.ssh/.stage.XXXXXX"); SshStageDir=$stageDir
  chmod 700 "$stageDir"
  if $age --decrypt "$repoAge" | $tar xf - -C "$stageDir" && [[ -s "$stageDir/id_ed25519" ]]; then
    local stagedFp
    stagedFp=$(pubFingerprint "$stageDir/id_ed25519.pub")
    if [[ -z "$stagedFp" || "$stagedFp" != "$repoFp" ]]; then
      rm -rf "$stageDir"; SshStageDir=""
      echo "ERROR: decrypted key doesn't match repo .pub. Re-encrypt the key pair." >&2
      return 1
    fi
    if ! installKey "$stageDir/id_ed25519" "$localKey"; then
      rm -rf "$stageDir"; SshStageDir=""
      echo "ERROR: failed to install decrypted key." >&2
      return 1
    fi
    rm -rf "$stageDir"; SshStageDir=""
    if [[ -d "$CrostiniDir" ]]; then
      mkdir -p "$cacheDir" 2>/dev/null
      installKey "$localKey" "$cacheKey"
    fi 2>/dev/null || echo "WARNING: mount cache write failed" >&2
    SshKeyStatus=restored
  else
    rm -rf "$stageDir"; SshStageDir=""
    echo "ERROR: age decryption failed." >&2
    return 1
  fi
}

# sshKeyEncryptToRepo -- encrypt local key pair to repo. Preserves prior repo
# state on partial failure. Not atomic (two renames), but best-effort consistent.
sshKeyEncryptToRepo() {
  local localKey=$1 repoAge=$2 repoPub=$3 hostname=$4
  echo "Local key exists but no repo backup for $hostname. Encrypting..."
  mkdir -p "$(dirname "$repoAge")"
  local stageDir agetmp pubtmp bakAge="" bakPub=""
  stageDir=$(mktemp -d "$HOME/.ssh/.stage.XXXXXX"); SshStageDir=$stageDir
  cp "$localKey" "$stageDir/id_ed25519" && chmod 600 "$stageDir/id_ed25519"
  cp "$localKey.pub" "$stageDir/id_ed25519.pub" && chmod 644 "$stageDir/id_ed25519.pub"
  echo "(Repo encryption passphrase)"
  agetmp=$(mktemp "$repoAge.XXXXXX")
  pubtmp=$(mktemp "$repoPub.XXXXXX")
  if $tar cf - -C "$stageDir" . | $age -p -o "$agetmp" && [[ -s "$agetmp" ]]; then
    cp "$localKey.pub" "$pubtmp" && chmod 644 "$pubtmp" || {
      rm -f "$agetmp" "$pubtmp"; echo "WARNING: .pub staging failed." >&2
      rm -rf "$stageDir"; SshStageDir=""; return 1
    }
    # Back up existing repo files for rollback
    [[ -f "$repoAge" ]] && { bakAge=$(mktemp "$repoAge.bak.XXXXXX") && cp "$repoAge" "$bakAge" || bakAge=""; }
    [[ -f "$repoPub" ]] && { bakPub=$(mktemp "$repoPub.bak.XXXXXX") && cp "$repoPub" "$bakPub" || bakPub=""; }
    # Commit both
    mv "$agetmp" "$repoAge" || {
      rm -f "$agetmp" "$pubtmp" "$bakAge" "$bakPub"
      echo "WARNING: .age commit failed." >&2
      rm -rf "$stageDir"; SshStageDir=""; return 1
    }
    mv "$pubtmp" "$repoPub" || {
      # Restore prior .age if we had one, otherwise remove the new one
      if [[ -n "$bakAge" ]]; then mv "$bakAge" "$repoAge" 2>/dev/null; else rm -f "$repoAge"; fi
      rm -f "$pubtmp" "$bakPub"
      echo "WARNING: .pub commit failed. Rolled back .age." >&2
      rm -rf "$stageDir"; SshStageDir=""; return 1
    }
    rm -f "$bakAge" "$bakPub"
    echo "Backed up. Commit and push ssh/id_ed25519_${hostname}.{age,pub}"
  else
    rm -f "$agetmp" "$pubtmp"
    echo "WARNING: encryption failed. Key not backed up to repo." >&2
    rm -rf "$stageDir"; SshStageDir=""
    return 1
  fi
  rm -rf "$stageDir"; SshStageDir=""
}

# sshKeyGenerate -- tier 4 implementation: generate new key, encrypt to repo, cache.
sshKeyGenerate() {
  local localKey=$1 repoAge=$2 repoPub=$3 hostname=$4 cacheDir=$5 cacheKey=$6
  command -v -- "$ssh_keygen" >/dev/null 2>&1 || { echo "$ssh_keygen not found"; return 1; }
  echo "No SSH key for $hostname. Generating..."
  echo "(SSH key passphrase -- protects the key on disk)"
  if ! sshKeygenTask "$localKey"; then
    echo "ERROR: key generation failed." >&2
    return 1
  fi
  chmod 644 "$localKey.pub"

  local backedUp=0
  if command -v -- "$age" >/dev/null 2>&1; then
    if sshKeyEncryptToRepo "$localKey" "$repoAge" "$repoPub" "$hostname"; then
      backedUp=1
    else
      echo "WARNING: key generated locally but NOT backed up to repo. Will be lost on wipe." >&2
    fi
  fi

  if [[ -d "$CrostiniDir" ]]; then
    mkdir -p "$cacheDir" 2>/dev/null
    installKey "$localKey" "$cacheKey"
  fi 2>/dev/null || echo "WARNING: mount cache write failed" >&2

  if (( backedUp )); then
    SshKeyStatus=generated
  else
    SshKeyStatus=generated_local_only
  fi
}

restoreSshKey() { withCleanupTrap cleanupSshStage restoreSshKeyImpl; }

# restoreSecrets -- three-tier restore for per-machine secrets bundle.
# Same model as SSH key: local -> mount cache -> age decrypt from repo.
# Secrets are flat files in ~/secrets/. Bundle is secrets/<hostname>.tar.age.
restoreSecrets() { withCleanupTrap cleanupSecretsTmp restoreSecretsImpl; }

restoreSecretsImpl() {
  local hostname
  hostname=$(lib.MachineHostname)
  lib.ValidateHostname "$hostname" || return 1
  local secretsDir="$HOME/secrets"
  local repoBundle="$HOME/dotfiles/secrets/${hostname}.tar.age"
  local cacheDir="$CrostiniDir/secrets/$hostname"

  mkdir -p "$secretsDir" && chmod 700 "$secretsDir"

  # Repo bundle hash for freshness
  local repoHash=""
  [[ -f "$repoBundle" ]] && repoHash=$(sha256sum "$repoBundle" | awk '{print $1}')

  # Tier 1: local secrets exist -- check freshness
  if [[ -n "$(lib.Glob "$secretsDir"/*)" ]]; then
    local localHash=""
    [[ -f "$secretsDir/.bundle-hash" ]] && localHash=$(< "$secretsDir/.bundle-hash")
    if [[ -n "$repoHash" && -n "$localHash" && "$localHash" != "$repoHash" ]]; then
      echo "WARNING: secrets may be stale (repo bundle updated). Run: scripts/encrypt-secrets" >&2
    fi
    return 0
  fi

  # Tier 2: mount cache (namespaced by hostname, freshness checked)
  if [[ -d "$cacheDir" && -f "$cacheDir/.bundle-hash" ]]; then
    local cachedHash
    cachedHash=$(< "$cacheDir/.bundle-hash")
    if [[ -z "$repoHash" || "$cachedHash" == "$repoHash" ]] && [[ -n "$(lib.Glob "$cacheDir"/*)" ]]; then
      echo "Restoring secrets from mount cache ($hostname)..."
      local stageDir
      stageDir=$(mktemp -d "$secretsDir.stage.XXXXXX")
      chmod 700 "$stageDir"
      if cp "$cacheDir"/* "$cacheDir"/.bundle-hash "$stageDir"/ 2>/dev/null; then
        chmod 600 "$stageDir"/* 2>/dev/null
        mv "$stageDir"/* "$stageDir"/.bundle-hash "$secretsDir"/ 2>/dev/null
        rmdir "$stageDir" 2>/dev/null
        return 0
      fi
      rm -rf "$stageDir"
      echo "WARNING: cache restore failed. Falling through to decrypt." >&2
    elif [[ -n "$repoHash" ]]; then
      echo "Mount secrets cache stale. Falling through to decrypt."
    fi
  fi

  # Tier 3: age decrypt tarball from repo
  if [[ -f "$repoBundle" ]]; then
    if [[ ! -t 0 ]]; then
      echo "Secrets encrypted in repo but no TTY."
      return 0
    fi
    command -v -- "$age" >/dev/null 2>&1 || { echo "$age not found"; return 1; }
    echo "Decrypting secrets for $hostname..."
    # Decrypt to temp file first, validate archive members, then extract
    local tmpBundle stageDir
    tmpBundle=$(mktemp "$secretsDir.bundle.XXXXXX"); SecretsTmpFiles=("$tmpBundle")
    if ! $age --decrypt "$repoBundle" > "$tmpBundle" || [[ ! -s "$tmpBundle" ]]; then
      rm -f "$tmpBundle"
      echo "ERROR: secrets decryption failed." >&2
      return 1
    fi
    if ! validateSecretsArchive "$tmpBundle"; then
      rm -f "$tmpBundle"
      return 1
    fi
    stageDir=$(mktemp -d "$secretsDir.stage.XXXXXX"); SecretsTmpFiles=("$tmpBundle" "$stageDir")
    chmod 700 "$stageDir"
    if $tar xf "$tmpBundle" -C "$stageDir"; then
      rm -f "$tmpBundle"
      # Enforce flat regular files only (post-extraction safety net)
      if find "$stageDir" -mindepth 1 -not -type f | grep -q .; then
        rm -rf "$stageDir"
        echo "ERROR: secrets bundle contains non-regular files." >&2
        return 1
      fi
      chmod 600 "$stageDir"/* 2>/dev/null
      # Record bundle hash for freshness
      echo "$repoHash" > "$stageDir/.bundle-hash"
      # Move into live dir (including dotfiles)
      mv "$stageDir"/* "$stageDir"/.bundle-hash "$secretsDir"/ 2>/dev/null
      rmdir "$stageDir" 2>/dev/null
      # Cache to mount (atomic: temp dir then rename)
      if [[ -d "$CrostiniDir" ]]; then
        local tmpCache
        tmpCache=$(mktemp -d "$cacheDir.XXXXXX")
        chmod 700 "$tmpCache"
        if cp "$secretsDir"/* "$secretsDir"/.bundle-hash "$tmpCache"/ 2>/dev/null; then
          chmod 600 "$tmpCache"/* 2>/dev/null
          rm -rf "$cacheDir" 2>/dev/null
          mv "$tmpCache" "$cacheDir"
        else
          rm -rf "$tmpCache"
          echo "WARNING: secrets cache write failed" >&2
        fi
      fi 2>/dev/null
    else
      rm -f "$tmpBundle"
      rm -rf "$stageDir"
      echo "ERROR: secrets extraction failed." >&2
      return 1
    fi
    return 0
  fi

  echo "No secrets for $hostname. Create ~/secrets/ files, then run scripts/encrypt-secrets."
  return 0
}

loadSshKey() {
  [[ -f "$HOME/.ssh/id_ed25519" ]] || return 0
  command -v -- "$keychain" >/dev/null 2>&1 || { echo "WARNING: $keychain not found"; return 0; } >&2
  eval "$($keychain --eval --agents ssh id_ed25519)" || {
    echo "WARNING: keychain failed to load SSH key." >&2
  }
}

authPreflight() {
  local keyFile="$HOME/.ssh/id_ed25519"
  local -a sshopts=(-o BatchMode=yes -o PreferredAuthentications=publickey
    -o IdentitiesOnly=yes -i "$keyFile" -o ConnectTimeout=10
    -o StrictHostKeyChecking=accept-new)

  [[ -f "$keyFile" ]] || { echo "  No SSH key -- all private repos will be skipped"; return; }

  local provider rc output
  for provider in github.com codeberg.org bitbucket.org; do
    if output=$($ssh -T "${sshopts[@]}" "git@$provider" 2>&1); then rc=0; else rc=$?; fi
    if (( rc == 0 || rc == 1 )); then
      :
    elif echo "$output" | grep -qi 'permission denied\|publickey'; then
      echo "  $provider: key not registered"
      [[ -f "$keyFile.pub" ]] && echo "    Register: cat $keyFile.pub"
    else
      echo "  $provider: unreachable"
    fi
  done

  if $ip link show tun0 >/dev/null 2>&1; then
    if output=$($ssh -T "${sshopts[@]}" git@stash.digi.com 2>&1); then rc=0; else rc=$?; fi
    (( rc == 0 || rc == 1 )) || echo "  stash.digi.com: SSH auth failed"
  fi
}

## helpers

fatal() {
  local msg=$1 rc=${2:-$?}
  echo "fatal: $msg"
  exit $rc
}

# crostiniHostnameSetup -- verify ChromeOS backing storage, create
# $CrostiniDir, and write hostname file. Fatal on first run without
# hostname arg or without backing storage.
# Reads: $CrostiniBacking (parent of $CrostiniDir), $CrostiniDir, $Hostname.
crostiniHostnameSetup() {
  local backing=${CrostiniBacking:-/mnt/chromeos/MyFiles/Downloads}
  [[ -d $backing ]] || { echo "fatal: ChromeOS shared storage not mounted at $backing" >&2; echo "Enable file sharing in ChromeOS Settings > Linux" >&2; return 1; }
  mkdir -p "$CrostiniDir"
  if [[ -n $Hostname ]]; then
    lib.ValidateHostname "$Hostname" || return 1
    echo "$Hostname" > "$CrostiniDir/hostname"
  elif [[ ! -e $CrostiniDir/hostname ]]; then
    echo "fatal: no Crostini hostname configured" >&2
    echo "First run requires: update-env -1 <hostname>" >&2
    return 1
  fi
}

# convergeTaskBash -- after home-manager switch, re-source session vars to
# pick up TASK_BASH_LIB from the new generation, then re-source task.bash
# from the pinned store path. Ensures the rest of this run uses the
# nix-pinned version, not the curl bootstrap.
# Unsets __HM_SESS_VARS_SOURCED first -- hm-session-vars.sh guards against
# double-sourcing, but we need the new generation's values.
# Non-NixOS only (called inside the crostini|debian|linux|macos case block).
convergeTaskBash() {
  local hmVars=$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh
  unset -v __HM_SESS_VARS_SOURCED
  [[ -r $hmVars ]] || { echo "fatal: hm-session-vars.sh not found at $hmVars" >&2; exit 1; }
  loosely source "$hmVars"
  if [[ -n ${TASK_BASH_LIB:-} ]]; then
    [[ -r $TASK_BASH_LIB ]] || { echo "fatal: TASK_BASH_LIB unreadable after switch: $TASK_BASH_LIB" >&2; exit 1; }
    source "$TASK_BASH_LIB" || { echo "fatal: failed to source converged task.bash: $TASK_BASH_LIB (rc=$?)" >&2; exit 1; }
  fi
}

# resolveSourceDir -- resolve the directory of the calling script, following
# symlink chains. Works when update-env is at ~/.local/bin/update-env.
resolveSourceDir() {
  local src=${BASH_SOURCE[1]:-${BASH_SOURCE[0]}}
  local dir
  while [[ -L $src ]]; do
    dir=$(cd -P -- "$(dirname -- "$src")" 2>/dev/null && pwd) || return 1
    src=$(readlink -- "$src") || return 1
    [[ $src != /* ]] && src=$dir/$src
  done
  cd -P -- "$(dirname -- "$src")" 2>/dev/null && pwd
}

# Shared helpers -- sourced from lib.bash to avoid duplication.
# lib.bash provides: lib.Glob, lib.MachineHostname, lib.ValidateHostname, lib.ValidSecretName
_lib_dir=$(resolveSourceDir) 2>/dev/null
if [[ -n "${_lib_dir:-}" && -f "$_lib_dir/scripts/lib.bash" ]]; then
  source "$_lib_dir/scripts/lib.bash"
else
  eval "$(curl -fsSL https://raw.githubusercontent.com/binaryphile/dotfiles/main/scripts/lib.bash)" || { echo "fatal: scripts/lib.bash not found" >&2; exit 1; }
fi
unset -v _lib_dir

# validateSecretsArchive TARFILE -- validate archive members before extraction.
# Checks both names AND types. Accepts only flat regular files with names
# matching lib.ValidSecretName. Rejects symlinks, hardlinks, directories (except
# root "."), devices, fifos, and any invalid names.
# Returns 1 with error to stderr on invalid entries or tar listing failure.
validateSecretsArchive() {
  local tarfile=$1

  # Name validation: tar -tf
  local entries
  if ! entries=$($tar tf "$tarfile" 2>/dev/null); then
    echo "ERROR: failed to list secrets bundle contents (corrupt or not a tar)." >&2
    return 1
  fi
  if [[ -z "$entries" ]]; then
    echo "ERROR: secrets bundle is empty." >&2
    return 1
  fi
  # Name validation pass
  local entry name bad="" regularCount=0
  while IFS= read -r entry; do
    [[ -z $entry ]] && continue
    # Root directory in both forms
    [[ $entry == . || $entry == ./ ]] && continue
    # Reject non-root directory entries (trailing /)
    [[ $entry == */ ]] && { bad="$bad$NL  name: $entry (non-root directory)"; continue; }
    name=$entry
    [[ $name == ./* ]] && name=${name#./}
    if ! lib.ValidSecretName "$name"; then
      bad="$bad$NL  name: $entry"
    fi
  done <<< "$entries"

  # Type validation pass: tar -tvf -- first char is the entry type (GNU tar).
  # Only regular files ('-') accepted. Directory ('d') accepted only for root.
  local verbose
  if ! verbose=$($tar tvf "$tarfile" 2>/dev/null); then
    echo "ERROR: failed to inspect secrets bundle types." >&2
    return 1
  fi
  while IFS= read -r entry; do
    [[ -z $entry ]] && continue
    local typeChar=${entry:0:1}
    case $typeChar in
      d)
        # Only root directory allowed -- check if name ends with " ./" or " ."
        # tar tvf format: "drwx... user/group size date time name"
        if [[ $entry == *" ./"  || $entry == *" ." ]]; then
          continue
        fi
        bad="$bad$NL  type: $entry (non-root directory)"
        ;;
      -) (( regularCount++ )) ;; # regular file -- ok, count it
      *)
        bad="$bad$NL  type: $entry"
        ;;
    esac
  done <<< "$verbose"

  if [[ -n "$bad" ]]; then
    echo "ERROR: secrets bundle contains invalid entries:$bad" >&2
    return 1
  fi
  if (( regularCount == 0 )); then
    echo "ERROR: secrets bundle contains no regular files." >&2
    return 1
  fi
  return 0
}

pubFingerprint() {
  [[ -f "$1" && -s "$1" ]] || return 0
  $ssh_keygen -lf "$1" 2>/dev/null | awk '{print $2}'
}

# installKey SRC DST -- install key pair from SRC to DST.
# Contract: destination reflects source pair state exactly.
# If source has .pub, destination gets it. If not, stale dst.pub is removed.
# On partial failure, prior destination state is restored (best-effort).
# Private key trust model: we trust .pub matches private key if they were
# produced together by ssh-keygen or extracted from the same age bundle.
# Manual .pub replacement is unsupported. See design docs.
installKey() {
  local src=$1 dst=$2 tmpPriv tmpPub="" bakPriv=""

  # Stage new private key
  tmpPriv=$(mktemp "$dst.XXXXXX")       || return 1
  cp "$src" "$tmpPriv"                  || { rm -f "$tmpPriv"; return 1; }
  chmod 600 "$tmpPriv"                  || { rm -f "$tmpPriv"; return 1; }

  # Stage new .pub if source has one
  if [[ -f "$src.pub" ]]; then
    tmpPub=$(mktemp "$dst.pub.XXXXXX")  || { rm -f "$tmpPriv"; return 1; }
    cp "$src.pub" "$tmpPub"             || { rm -f "$tmpPriv" "$tmpPub"; return 1; }
    chmod 644 "$tmpPub"                 || { rm -f "$tmpPriv" "$tmpPub"; return 1; }
  fi

  # Back up existing private key for rollback
  if [[ -f "$dst" ]]; then
    bakPriv=$(mktemp "$dst.rollback.XXXXXX") && cp "$dst" "$bakPriv" || bakPriv=""
  fi

  # Commit private key
  mv "$tmpPriv" "$dst" || {
    rm -f "$tmpPriv" "$tmpPub" "$bakPriv"
    return 1
  }

  # Commit .pub -- rollback private on failure
  if [[ -n "$tmpPub" ]]; then
    if ! mv "$tmpPub" "$dst.pub"; then
      # Restore prior private key or remove new one
      if [[ -n "$bakPriv" ]]; then
        mv "$bakPriv" "$dst" 2>/dev/null || rm -f "$dst"
      else
        rm -f "$dst"
      fi
      rm -f "$tmpPub" "$bakPriv"
      return 1
    fi
  elif [[ -f "$dst.pub" && ! -f "$src.pub" ]]; then
    # Source has no .pub -- remove stale dst.pub for pair consistency
    if ! rm -f "$dst.pub"; then
      # Can't remove stale .pub -- rollback private key
      if [[ -n "$bakPriv" ]]; then
        mv "$bakPriv" "$dst" 2>/dev/null || rm -f "$dst"
      else
        rm -f "$dst"
      fi
      rm -f "$bakPriv"
      return 1
    fi
  fi

  # Success -- clean up rollback backup
  rm -f "$bakPriv"
  return 0
}

isDir() { [[ -d "$1" ]]; }

isFile() { [[ -f "$1" ]]; }

loosely() {
  set +euo pipefail
  "$@"
  set -euo pipefail
}

ownerAndGroup() {
  local path=$1
  [[ $OSTYPE == darwin* && $(type -p stat) == /usr/bin/stat ]] && local flag=f || local flag=c
  echo $(stat -$flag %u $path):$(stat -$flag %g $path)
}

platform() {
  [[ $OSTYPE != darwin* ]] || { echo macos; return; }
  [[ $HOSTNAME != penguin ]] || { echo crostini; return; }
  if [[ -e /etc/NIXOS ]]; then
    [[ ! -d ~/dotfiles/contexts/$HOSTNAME ]] || { echo "$HOSTNAME"; return; }
    echo nixos; return
  fi
  ! [[ -e /etc/debian_version ]] || { echo debian; return; }
  echo linux
}


## fp

# each applies its arguments as a command to each argument from stdin.
# stream prints each argument on its own line.
stream() { printf '%s\n' "$@"; }

each() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg"
  done
}

# keepIf filters lines from stdin using command.
keepIf() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg" && echo "$arg"
  done
  return 0
}

# map returns $EXPRESSION evaluated with the value of stdin as $VARNAME.
# $EXPRESSION must respect double-quoting rules and so can't contain naked quotes.
# $VARNAME may not be "VARNAME" or "EXPRESSION".
map() {
  local VARNAME=$1 EXPRESSION=$2
  case $VARNAME in VARNAME|EXPRESSION ) fatal "map: VARNAME may not be 'VARNAME' or 'EXPRESSION'";; esac
  local "$VARNAME"
  while IFS='' read -r "$VARNAME"; do
    eval "echo \"$EXPRESSION\""
  done
}

