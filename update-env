#!/usr/bin/env bash

# update-env -- create and maintain my work environment

# Naming Policy:
#
# All function and variable names are camelCased.
#
# Local variable names begin with lowercase letters, e.g. localVariable.
# Global variable names begin with uppercase letters, e.g. GlobalVariable.
#
# Variable declarations that are name references borrow the environment namespace, e.g.
# "local -n ARRAY=$1".
#
# Locally-defined task functions are suffixed with "Task".

# the persistent crostini directory
# it does not have spaces and is exempt from quoting
CrostiniDir=/mnt/chromeos/MyFiles/Downloads/crostini

# Two-stage execution: stage 1 delivers a working shell (phases 1-3 + core
# tools); stage 2 handles remaining projects, builds, and config.
# Bare `update-env` runs both stages sequentially (backwards-compatible).
main() {
  set -euo pipefail   # enable strict mode
  Platform=$(platform)
  readonly Platform

  case $Stage in
    1   ) stage1; stage1Epilogue;;
    2   ) stage2Preflight; stage2;;
    all ) stage1; stage2;;
  esac

  task.Summarize
  sshKeyEpilogue
  postInstallMessages
}

sshKeyEpilogue() {
  case $SshKeyStatus in
    generated)
      echo
      echo "=== NEW SSH KEY GENERATED ==="
      echo "Public key: ~/.ssh/id_ed25519.pub"
      [[ -f "$HOME/.ssh/id_ed25519.pub" ]] && cat "$HOME/.ssh/id_ed25519.pub"
      echo
      echo "Register this key with: GitHub, Codeberg, Bitbucket"
      echo "Then commit and push: cd ~/dotfiles && git add ssh/ && git commit -m 'Add SSH key for $(machineHostname)' && git push"
      echo "Until registered, private repos will be skipped."
      ;;
    restored)
      echo
      echo "SSH key restored for $(machineHostname)."
      ;;
    missing_noninteractive)
      echo
      echo "WARNING: No SSH key available. Run update-env interactively to set up."
      ;;
  esac
}

# Stage 1: critical path — working shell after completion + exec bash
stage1() {
  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 1: System & Credentials (section system)              │
  #  │   ├─> [crostini/linux] apt upgrade                          │
  #  │   └─> SSH key installation:                                 │
  #  │       • np_id_ed25519 (non-passphrase) if exists            │
  #  │       • id_ed25519 (unique) as fallback                     │
  #  └─────────────────────────────────────────────────────────────┘
  section system
  each task.Ln <<'  END'
    .config         ~/config
    .local          ~/local
    .ssh            ~/ssh
    secrets/netrc   ~/.netrc
  END
  case $Platform in crostini|debian )
    aptUpgradeTask
  ;; esac

  case $Platform in crostini )
    # SSH key restore moved to stage 2 (restoreSshKey, after age is installed)
    task.Ln $CrostiniDir/repos ~/repos
    task.Ln $CrostiniDir/secrets ~/secrets
    ;;
  esac

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 2: Dotfiles & Configuration (section dotfiles)        │
  #  │   ├─> Clone dotfiles from GitHub                            │
  #  │   └─> Create symlinks                                       │
  #  └─────────────────────────────────────────────────────────────┘
  section dotfiles
  task.GitClone https://github.com/binaryphile/dotfiles ~/dotfiles main
  try git -C ~/dotfiles remote set-url origin https://github.com/binaryphile/dotfiles.git
  try git -C ~/dotfiles remote set-url --push origin git@github.com:binaryphile/dotfiles.git
  try task.GitUpdate ~/dotfiles
  # Bootstrap-only symlinks. The rest are managed by home-manager via
  # contexts/linux-base.nix once nix and home-manager are installed.
  each task.Ln <<'  END'
    contexts/"$Platform"                          ~/dotfiles/context
    ~/dotfiles/bash/init.bash                     ~/.bash_profile
    ~/dotfiles/bash/init.bash                     ~/.bashrc
    ~/dotfiles/bash/init.bash                     ~/.profile
  END
  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 3: Package Management (sections nix & home-manager)   │
  #  │   ├─> Install Nix (Lix installer)                           │
  #  │   ├─> Fix /nix ownership                                    │
  #  │   ├─> Add Home Manager channel                              │
  #  │   └─> Apply Home Manager configuration                      │
  #  └─────────────────────────────────────────────────────────────┘

  case $Platform in crostini|debian|linux|macos )
    section nix
    curlPipeLixInstallerTask
    chownRTask /nix "$(id -u)" "$(id -g)"
    loosely source /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
    task.Ln ~/dotfiles/config.nix ~/.config/nixpkgs/config.nix

    section home-manager
    nixChannelAddHomeManagerTask
    nixChannelUpdateTask
    nixShellHomeManagerInstallTask
    loosely source ~/.nix-profile/etc/profile.d/hm-session-vars.sh
    task.Ln ~/dotfiles/home.nix ~/.config/home-manager/home.nix
    export DOTFILES_STAGE1=1
    homeManagerSwitchTask
    unset DOTFILES_STAGE1
    ;;
  esac

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 5 (core): Development Tools                           │
  #  │   ├─> fp.bash           - functional programming utilities  │
  #  │   ├─> mk.bash           - build tool & git updater          │
  #  │   ├─> task.bash         - task automation (this script!)    │
  #  │   └─> tesht             - testing framework                 │
  #  │       Default branch: main. Cloned and symlinked.           │
  #  └─────────────────────────────────────────────────────────────┘

  section fp.bash
  githubCloneAndLinkTask fp.bash
  task.Ln ~/projects/fp.bash/fp.bash ~/.local/lib/fp.bash

  section mk.bash
  githubCloneAndLinkTask mk.bash
  scaffoldTask ~/projects/mk.bash
  task.Ln nix-wrapper ~/projects/mk.bash/bin/node
  task.Ln nix-wrapper ~/projects/mk.bash/bin/npx
  task.Ln ~/projects/mk.bash/mk.bash ~/.local/lib/mk.bash
  task.Ln ~/projects/mk.bash/mk-example ~/.local/bin/mk

  section task.bash
  githubCloneAndLinkTask task.bash
  scaffoldTask ~/projects/task.bash

  task.Ln ~/dotfiles/update-env  ~/.local/bin/update-env
  task.Ln ~/dotfiles/scripts/scaffold ~/.local/bin/scaffold

  section tesht
  githubCloneAndLinkTask tesht
  scaffoldTask ~/projects/tesht
  task.Ln ~/projects/tesht/tesht ~/.local/bin/tesht
}

stage1Epilogue() {
  echo
  echo "Stage 1 complete. Shell configuration changed."
  echo "Run 'exec bash' to reload your shell."
  echo "Then run 'update-env -2' to install remaining tools and repos."
}

stage2Preflight() {
  local missing=()
  command -v nix  &>/dev/null || missing+=("nix")
  command -v git  &>/dev/null || missing+=("git")
  [[ -d ~/dotfiles ]]        || missing+=("~/dotfiles")
  if (( ${#missing[@]} )); then
    echo "Stage 2 requires: ${missing[*]}"
    echo "Run 'update-env -1' first, then 'exec bash'."
    exit 2
  fi
}

# Stage 2: projects, builds, and config — all externals try-wrapped
stage2() {
  # Re-run home-manager with VPN packages (skipped in stage 1 to avoid
  # gpoc Rust compilation on the critical path to a working shell).
  case $Platform in crostini|debian|linux|macos )
    section home-manager-full
    homeManagerSwitchTask
    ;;
  esac

  # SSH key restore + agent load + auth preflight (after age is installed)
  case $Platform in crostini )
    section credential
    try restoreSshKey
    try loadSshKey
    section auth-preflight
    try authPreflight
    ;;
  esac

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 4: Platform-Specific Setup                            │
  #  │   └─> [crostini only]:                                      │
  #  │       • Link ~/crostini → $CrostiniDir                      │
  #  │       • Clone project directories from permanent mount      │
  #  └─────────────────────────────────────────────────────────────┘
  if [[ $Platform == crostini ]]; then
    section crostini
    task.Ln $CrostiniDir ~/crostini

    # clone from persisted repo directories to home dir
    if [[ -d $CrostiniDir/repos ]]; then
      local -A branches=(
        [tlilley-daily-notes.git]=main
        [urma-next-local.git]=main
      )
      (cd $CrostiniDir/repos; glob * | keepIf isDir) |
        map target '$CrostiniDir/repos/$target ~/projects/${target%.git} ${branches[$target]:-main}' |
        each task.GitClone
    fi
  fi

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 5 (projects): Additional Tools & Projects             │
  #  │   ├─> jeeves            - project guides (bitbucket)        │
  #  │   ├─> sofdevsim-2026    - software dev simulation           │
  #  │   ├─> blog              - binaryphile.github.io             │
  #  │   ├─> tandem-protocol   - Claude slash commands (codeberg)  │
  #  │   └─> era               - semantic memory MCP (codeberg)    │
  #  │       Default branch: main. Cloned and symlinked.           │
  #  └─────────────────────────────────────────────────────────────┘

  section jeeves
  try bitbucketCloneAndLinkTask jeeves
  try scaffoldTask ~/projects/jeeves
  try task.Ln nix-wrapper ~/projects/jeeves/bin/go
  try task.Ln nix-wrapper ~/projects/jeeves/bin/node
  try task.Ln nix-wrapper ~/projects/jeeves/bin/npx

  section sofdevsim-2026
  try githubCloneAndLinkTask sofdevsim-2026
  try scaffoldTask ~/projects/sofdevsim-2026
  try task.Ln nix-wrapper ~/projects/sofdevsim-2026/bin/go
  try task.Ln nix-wrapper ~/projects/sofdevsim-2026/bin/node
  try task.Ln nix-wrapper ~/projects/sofdevsim-2026/bin/npx

  section blog
  try githubCloneAndLinkTask binaryphile.github.io
  try scaffoldTask ~/projects/binaryphile.github.io
  try task.Ln nix-wrapper ~/projects/binaryphile.github.io/bin/ruby
  try task.Ln nix-wrapper ~/projects/binaryphile.github.io/bin/bundler
  try task.Ln nix-wrapper ~/projects/binaryphile.github.io/bin/node
  try task.Ln nix-wrapper ~/projects/binaryphile.github.io/bin/npx

  section tandem-protocol
  try codebergCloneAndLinkTask tandem-protocol
  try scaffoldTask ~/projects/tandem-protocol
  try task.Ln nix-wrapper ~/projects/tandem-protocol/bin/go
  glob ~/projects/tandem-protocol/commands/* |
    keepIf isFile |
    map path '$path ~/.claude/commands/$(basename $path)' |
    each task.Ln

  section era
  try codebergCloneAndLinkTask era
  try eraScaffoldTask
  try eraBuildTask
  each task.Ln <<'  END'
    ~/projects/era/bin/era           ~/.local/bin/era
    ~/projects/era/bin/era-hook      ~/.local/bin/era-hook
    ~/projects/era/scripts/evtctl                ~/.local/bin/evtctl
    ~/projects/era/scripts/task-audit             ~/.local/bin/task-audit
    ~/projects/era/scripts/validate-attestation   ~/.local/bin/validate-attestation
  END
  try task.Install 644 ~/projects/era/era-mcp.service ~/.config/systemd/user/era-mcp.service
  try eraSystemdEnableTask
  eraMcpRegisterTask
  chromeDevtoolsMcpRegisterTask

  # Era memory redirects and project CLAUDE.md files are now managed by
  # home-manager (contexts/linux/home.nix)

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 5b: Work Projects (VPN-dependent, graceful failure)   │
  #  │   ├─> urma-next        - main application (+ MCP)            │
  #  │   ├─> pepin            - build/deploy tooling               │
  #  │   ├─> cloud-services                                        │
  #  │   ├─> accelerated-linux   - DAL (cloned to ~/projects/dal)   │
  #  │   ├─> urma-obsidian    - obsidian vault                     │
  #  │   ├─> dal-obsidian     - DAL knowledge vault                │
  #  │   └─> share            - cross-team utilities               │
  #  │       All from stash.digi.com, require VPN                  │
  #  └─────────────────────────────────────────────────────────────┘

  section urma
  try stashCloneAndLinkTask urma-next urma
  ProjectDirW=~/projects/urma
  source ~/dotfiles/scripts/scaffold
  try scaffold.MkdirTask ~/projects/urma/bin
  try scaffold.NixWrapperTask
  try scaffold.GitExcludeBinTask
  try urmaEnvrcTask
  try urmaDirenvAllowTask
  try task.Ln nix-wrapper ~/projects/urma/bin/uvx
  try urmaFlakeTask
  try gitExcludeTask ~/projects/urma /obsidian
  try gitExcludeTask ~/projects/urma /flake.nix
  try gitExcludeTask ~/projects/urma /flake.lock
  try writeMcpJsonTask ~/projects/urma

  section pepin
  try stashCloneAndLinkTask pepin
  try scaffoldTask ~/projects/pepin

  section cloud-services
  try stashCloneAndLinkTask cloud-services
  try scaffoldTask ~/projects/cloud-services

  section dal
  try stashCloneAndLinkTask accelerated-linux dal acl
  try scaffoldTask ~/projects/dal
  try gitExcludeTask ~/projects/dal /obsidian

  section urma-obsidian
  try stashCloneAndLinkTask urma-obsidian urma/obsidian ~tlilley

  section dal-obsidian
  try stashCloneAndLinkTask dal-obsidian dal/obsidian ~tlilley

  section share
  try stashCloneAndLinkTask share share ~tlilley

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 6: Applications & VPN                                 │
  #  │   ├─> [crostini/linux] GlobalProtect VPN client             │
  #  │   ├─> Neovim setup (vim-plug, plugins)                      │
  #  │   ├─> Daily notes repository                                │
  #  │   └─> Ranger file manager configs                           │
  #  └─────────────────────────────────────────────────────────────┘

  section neovim
  try task.GitClone https://github.com/binaryphile/dot_vim ~/.config/nvim master
  try git -C ~/.config/nvim remote set-url origin https://github.com/binaryphile/dot_vim.git
  try git -C ~/.config/nvim remote set-url --push origin git@github.com:binaryphile/dot_vim.git
  try task.GitUpdate ~/.config/nvim
  curlTask https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim ~/.local/share/nvim/site/autoload/plug.vim
  nvimHeadlessPlugInstallTask
  task.Ln ~/.config/nvim ~/nvim

  section obsidian
  try bitbucketCloneAndLinkTask tlilley-daily-notes

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 7: SSH Key Generation (section unique_credential)     │
  #  │   └─> [crostini/linux] Generate unique SSH key if needed    │
  #  │       • Remove non-passphrase key if it was copied          │
  #  │       • Generate new passphrase-protected key               │
  #  └─────────────────────────────────────────────────────────────┘
  # Phase 7 (SSH key generation) removed — handled by restoreSshKey in stage 2

}

# postInstallMessages writes platform-specific manual setup instructions
# to a file under ~/.local/share/dotfiles/ if not already present, then
# prints a one-line reminder pointing at the file. Delete the file to
# regenerate it on the next run (e.g., after the instructions change).
postInstallMessages() {
  local dir=$HOME/.local/share/dotfiles
  mkdir -p "$dir"
  case $(platform) in crostini )
    local file=$dir/crostini-proxy-setup.txt
    if [[ ! -e $file ]]; then
      cat >"$file" <<'      EOF'
CROSTINI: configure ChromeOS Chrome to use the corporate VPN proxy (UC-8)

For VPN-only URLs (stash.digi.com, gitlab.drm.ninja, etc.) to work in
ChromeOS host Chrome — instead of just in-container browsers — point
Chrome at the in-container PAC server:

  1. ChromeOS Settings -> Network
  2. Click your active connection (Wi-Fi or Ethernet)
  3. Expand "Proxy"
  4. Connection type: "Automatic proxy configuration"
  5. URL: http://127.0.0.1:8120/proxy.pac
  6. Save

This is per-network and persists across reboots. Repeat for each network
you connect to. Verify with chrome://net-internals/#proxy after setup.

Non-VPN URLs return DIRECT in the PAC and bypass the proxy entirely;
only the configured VPN host list traverses the container.

See ~/dotfiles/docs/use-cases.md UC-8 and ~/dotfiles/docs/vpn.md for the
full story. Delete this file to have update-env regenerate it.
      EOF
    fi
    echo
    echo "Crostini ChromeOS proxy setup: see $file"
  ;; esac
}

## task definitions

# system

# aptUpgradeTask upgrades all apt packages to latest.
# Uses DPkg::Lock::Timeout to wait for any held locks (covers all lock
# files: lists, dpkg, dpkg-frontend, archives). Available on Bullseye+.
aptUpgradeTask() {
  desc   'apt upgrade'
  prog   on
  runas  root
  unchg  '0 upgraded, 0 newly installed'

  cmd 'DEBIAN_FRONTEND=noninteractive apt-get update -o DPkg::Lock::Timeout=60 -qq && DEBIAN_FRONTEND=noninteractive apt-get upgrade -y -o DPkg::Lock::Timeout=60'
}

bitbucketCloneAndLinkTask() {
  local repo=$1 branch=${2:-main}
  task.GitClone git@bitbucket.org:accelecon/$repo ~/projects/$repo $branch
  try task.GitUpdate ~/projects/$repo
}

codebergCloneAndLinkTask() {
  local repo=$1 branch=${2:-main}
  task.GitClone "https://codeberg.org/binaryphile/$repo" ~/projects/"$repo" "$branch"
  try git -C ~/projects/"$repo" remote set-url origin "https://codeberg.org/binaryphile/$repo.git"
  try git -C ~/projects/"$repo" remote set-url --push origin "git@codeberg.org:binaryphile/$repo.git"
  try task.GitUpdate ~/projects/"$repo"
}

scaffoldTask() {
  local dir=$1
  ProjectDirW=$dir
  source ~/dotfiles/scripts/scaffold
  scaffold.MkdirTask "$dir/bin"
  scaffold.NixWrapperTask
  scaffold.GitExcludeBinTask
  scaffold.EnvrcTask
  scaffold.DirenvAllowTask
}

urmaFlakeTask() {
  local path=~/projects/urma/flake.nix
  desc 'install urma flake.nix'

  urmaFlakeUpToDate() { [[ -f $path ]] && diff -q "$path" <(urmaFlakeContent) >/dev/null 2>&1; }
  ok urmaFlakeUpToDate

  urmaFlakeInstall() { urmaFlakeContent > "$path"; }
  cmd urmaFlakeInstall
}

urmaFlakeContent() {
  cat << 'EOF'
{
  description = "URMA development environment";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs";
    flake-utils.url = "github:numtide/flake-utils";
  };

  outputs = { self, nixpkgs, flake-utils }:
    flake-utils.lib.eachDefaultSystem (system:
      let
        pkgs = import nixpkgs {
          inherit system;
        };
      in {
        devShells.default = pkgs.mkShell {
          buildInputs = with pkgs; [
            bash
            coreutils
            git
            uv
          ];
        };
      }
    );
}
EOF
}

urmaEnvrcTask() {
  local path=~/projects/urma/.envrc
  desc 'install urma .envrc'

  urmaEnvrcUpToDate() { [[ -f $path ]] && diff -q "$path" <(urmaEnvrcContent) >/dev/null 2>&1; }
  ok urmaEnvrcUpToDate

  urmaEnvrcInstall() { urmaEnvrcContent > "$path"; }
  cmd urmaEnvrcInstall
}

urmaDirenvAllowTask() {
  local path=~/projects/urma/.envrc
  desc "direnv allow ~/projects/urma"
  check "diff -q '$path' <(urmaEnvrcContent) >/dev/null 2>&1"
  ok "grep -rq '$path' ~/.local/share/direnv/allow/ 2>/dev/null"

  cmd "direnv allow ~/projects/urma"
}

urmaEnvrcContent() {
  cat << 'EOF'
export PROJECT_ROOT=$(cd "$(dirname "$BASH_SOURCE")"; pwd)
export PATH=$PROJECT_ROOT/bin:$PATH

# Atlassian — Bitbucket Server (stash.digi.com)
export BITBUCKET_URL=https://stash.digi.com
export BITBUCKET_USERNAME=tlilley
export BITBUCKET_PERSONAL_TOKEN=$(< ~/secrets/stash.key)

# Atlassian — Confluence Cloud (onedigi.atlassian.net)
export CONFLUENCE_URL=https://onedigi.atlassian.net/wiki
export CONFLUENCE_USERNAME=tlilley@digi.com
export CONFLUENCE_PERSONAL_TOKEN=$(< ~/secrets/confluence.key)
EOF
}

eraScaffoldTask() {
  scaffoldTask ~/projects/era
  each task.Ln <<'  END'
    nix-wrapper ~/projects/era/bin/go
    nix-wrapper ~/projects/era/bin/node
    nix-wrapper ~/projects/era/bin/npx
  END
}

eraBuildTask() {
  desc  'build era binaries'
  prog  on
  exist ~/projects/era/bin/era

  cmd 'nix develop ~/projects/era --command bash -c "cd ~/projects/era && go generate ./internal/hugot/ && ./mk build"'
}

eraSystemdEnableTask() {
  desc  'enable era-mcp systemd service'
  ok    'systemctl --user is-enabled era-mcp &>/dev/null'
  cmd   'systemctl --user enable --now era-mcp'
}

eraMcpRegisterTask() {
  desc  'register era MCP in claude.json'
  ok    '[[ -f ~/.claude.json ]] && jq -e ".mcpServers.era" ~/.claude.json &>/dev/null'

  eraMcpRegister() {
    local src=${1:-'{}'}
    [[ -f ~/.claude.json ]] && src=$(cat ~/.claude.json)
    printf '%s' "$src" |
      jq '.mcpServers.era = {type: "http", url: "http://127.0.0.1:9310/mcp"}' > ~/.claude.json.tmp &&
      mv ~/.claude.json.tmp ~/.claude.json
  }
  cmd eraMcpRegister
}

chromeDevtoolsMcpRegisterTask() {
  desc  'register chrome-devtools MCP in claude.json'
  ok    '[[ -f ~/.claude.json ]] && jq -e ".mcpServers.\"chrome-devtools\"" ~/.claude.json &>/dev/null'

  chromeDevtoolsMcpRegister() {
    local src=${1:-'{}'}
    [[ -f ~/.claude.json ]] && src=$(cat ~/.claude.json)
    printf '%s' "$src" |
      jq '.mcpServers."chrome-devtools" = {command: "npx", args: ["-y", "chrome-devtools-mcp@latest", "--browser-url", "http://127.0.0.1:9222"]}' > ~/.claude.json.tmp &&
      mv ~/.claude.json.tmp ~/.claude.json
  }
  cmd chromeDevtoolsMcpRegister
}

# claudeProjectMemoryTask - REMOVED
# Memory redirects are now managed by home-manager (contexts/linux/home.nix)

writeMcpJsonTask() {
  local dir=$1
  desc   "write .mcp.json to $dir"
  exist  "$dir/.mcp.json"
  check  "[[ -d '$dir' ]]"

  writeMcpJson() {
    cat >"$dir/.mcp.json" <<'EOF'
{
  "mcpServers": {
    "atlassian": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-atlassian-with-bitbucket"]
    }
  }
}
EOF
  }
  cmd writeMcpJson
}

stashCloneAndLinkTask() {
  local repo=$1 dir=${2:-$1} project=${3:-idigi} branch=${4:-main}

  desc   "clone repo stash.digi.com/$project/$repo to ~/projects/$dir"
  exist  "$HOME/projects/$dir"
  check  'ping -c 1 -W 2 stash.digi.com'

  stashClone() {
    GIT_SSH_COMMAND='ssh -o StrictHostKeyChecking=accept-new -o ConnectTimeout=5' git clone --branch "$branch" "git@stash.digi.com:$project/$repo.git" ~/projects/"$dir"
  }
  cmd stashClone

  try task.GitUpdate ~/projects/$dir
}

gitExcludeTask() {
  local repoDir=$1 pattern=$2
  local excludeFile=$repoDir/.git/info/exclude

  desc   "add $pattern to git exclude for $repoDir"
  check  "[[ -d $repoDir/.git ]]"
  ok     "grep -qxF $pattern $excludeFile 2>/dev/null"

  cmd "echo $pattern >> $excludeFile"
}

githubCloneAndLinkTask() {
  local repo=$1 branch=${2:-main}
  task.GitClone "https://github.com/binaryphile/$repo" ~/projects/"$repo" "$branch"
  try git -C ~/projects/"$repo" remote set-url origin "https://github.com/binaryphile/$repo.git"
  try git -C ~/projects/"$repo" remote set-url --push origin "git@github.com:binaryphile/$repo.git"
  try task.GitUpdate ~/projects/"$repo"
}

installGlobalProtectClient() {
  local dir
  dir=$(mktemp -d)
  trap "rm -rf $dir" EXIT
