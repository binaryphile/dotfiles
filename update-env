#!/usr/bin/env bash

# Safe-expansion discipline (file-top per shellcheck-convention-plugin SC9010).
# Strict mode (`set -eufo pipefail`) is deferred to main() — bash style guide
# §1 "defer strict mode until after option parsing" — but IFS+noglob can be
# set at file top without affecting option parsing (which uses ${1:-} idioms).
IFS=$'\n'
set -o noglob

# update-env -- create and maintain my work environment

# Naming Policy:
#
# All function and variable names are camelCased.
#
# Local variable names begin with lowercase letters, e.g. localVariable.
# Global variable names begin with uppercase letters, e.g. GlobalVariable.
#
# Injectable dependency variables use the command name directly (snake_case,
# underscores replacing hyphens): e.g. ssh_keygen. Lowercase despite being
# global -- designed to be shadowed by local declarations in tests via bash
# dynamic scoping. See bash style guide # Injectable dependencies.
#
# Variables that need to stay quoted at use site are marked by name so the
# reader knows. Two conditions force quoting under IFS=$'\n'; set -o noglob:
#   (a) value can contain IFS characters (newlines) — unquoted use word-
#       splits the value across multiple positional args.
#   (b) value can be empty — unquoted empty expansion DISAPPEARS as a
#       positional arg, shifting downstream args (set -u catches unset,
#       not empty).
# Two marker conventions, mutually exclusive:
#   - Trailing underscore: oldIfs_, cmd_. Generic marker for either condition.
#   - *List suffix: groupList, hostList. Multi-value marker (implies IFS;
#     covers condition (a)).
# Unmarked variables MUST be guaranteed non-empty AND IFS-free at every use
# site so they are safe to expand unquoted. Prefer non-empty initialization
# (local i=0) over the _ suffix where the empty case can be eliminated by
# construction. Empty-string initialization (local s='') does NOT defeat the
# empty case — s still needs the suffix. Initialization defeats the empty
# case only when the initial value is non-empty AND every assignment path
# preserves non-emptiness; the suffix is for cases where emptiness is
# load-bearing.
#
# Variable declarations that are name references borrow the environment namespace, e.g.
# "local -n ARRAY=$1".
#
# Locally-defined task functions are suffixed with "Task".

# the persistent crostini directory
# it does not have spaces and is exempt from quoting
CrostiniDir=/mnt/chromeos/MyFiles/Downloads/crostini

usageText() {
  cat <<'EOF'
Usage: update-env [-1 [hostname] | -2 | -c] [-s] [-x] [--strict]

  -1, --stage1 [hostname]  Stage 1: system, packages, credentials
  -2, --stage2             Stage 2: projects, dev tools, config
  -c, --credential         Credential setup only (SSH key, signing key, secrets)
  -s, --short              Short run (skip unchanged tasks)
  -x, --trace              Enable bash trace output
      --strict             Hard-fail preflight on missing downstream commands
  -h, --help               Show this help

  Bare 'update-env' runs both stages sequentially.
  Hostname is required on first Crostini run with -1.
  -c requires prior completion of stage 1 phases 1-3.
EOF
}

# Two-stage execution: stage 1 delivers a working shell (phases 1-3 + core
# tools); stage 2 handles remaining projects, builds, and config.
# Bare `update-env` runs both stages sequentially (backwards-compatible).
main() {
  set -eufo pipefail   # enable strict mode (f = noglob)
  IFS=$'\n'
  export GIT_CONFIG_COUNT=1
  export GIT_CONFIG_KEY_0=rebase.autoStash
  export GIT_CONFIG_VALUE_0=true

  # Self-update: pull dotfiles/main, re-exec if update-env itself changed.
  # UPDATE_ENV_REEXEC (0|1) prevents infinite re-exec loops.
  # Skip if dotfiles has uncommitted work (don't blow away in-flight edits)
  # or if we already re-exec'd.
  local reexec=${UPDATE_ENV_REEXEC:-0}
  if (( !reexec )) && git -C ~/dotfiles diff --quiet 2>/dev/null && git -C ~/dotfiles diff --cached --quiet 2>/dev/null; then
    local oldHash newHash
    oldHash=$(sha256sum ~/dotfiles/update-env | awk '{print $1}')
    if git -C ~/dotfiles pull --ff-only --quiet 2>/dev/null; then
      newHash=$(sha256sum ~/dotfiles/update-env | awk '{print $1}')
      if [[ $oldHash != $newHash ]]; then
        echo "[update-env] self-updated from main; re-executing" >&2
        export UPDATE_ENV_REEXEC=1
        exec "$0" "${OriginalArgs_[@]}"
      fi
    fi
  fi

  Platform=$(${platform:-detectPlatform})
  readonly Platform

  if [[ ! -d ~/dotfiles/contexts/$Platform ]]; then
    local groupList
    groupList=$(platformTaskGroups $Platform)
    if hasGroup "$groupList" hm; then
      echo "fatal: detected platform '$Platform' but contexts/$Platform does not exist" >&2
      echo "Check detectPlatform or create the context directory." >&2
      exit 1
    fi
  fi

  case $Stage in
    1|2|credential|all ) preflightCrostiniLxcfs ;;
  esac

  case $Stage in
    1|2|all )
      if hasGroup "$(platformTaskGroups $Platform)" hm; then
        preflightCheckCommands ${IsStrictPreflight:-0}
      fi
      ;;
  esac

  case $Stage in
    1          ) stage1; stage1Epilogue;;
    2          ) stage2Preflight; stage2;;
    credential ) credentialPreflight; credentialStage;;
    all        ) stage1; stage2;;
  esac

  task.Summarize
  postInstallMessages
}

# platformTaskGroups -- pure decision function mapping platform to the set of
# task groups both stages should run. No side effects.
# Groups: apt, hostname, gpoc, pangp, nix, hm, credential.
# nix = install nix itself. hm = apply home-manager flake config.
# hm is separate from nix because not all nix platforms have flake configs
# in this repo (linux needs nixos-config's flake, macos needs darwin pkgs).
# pangp = preconditions for the nix-managed proprietary PAN client (tarball
# present + apt deb removed if a prior install left one behind).
platformTaskGroups() {
  local platform=$1
  local groups=()
  case $platform in crostini|debian )   groups+=(apt);; esac
  case $platform in crostini )          groups+=(hostname gpoc);; esac
  case $platform in crostini|desktop )  groups+=(pangp);; esac
  case $platform in crostini|debian|desktop|macos ) groups+=(nix);; esac
  case $platform in crostini|debian|macos ) groups+=(hm);; esac
  case $platform in crostini )          groups+=(credential);; esac
  echo ${groups[*]}
}

# hasGroup tests whether a newline-separated group list contains a group name.
# Exact line match -- avoids substring false positives (e.g., *hm* matching "ohmy").
# Groups are newline-separated because ${array[*]} joins with IFS[0] ($'\n').
hasGroup() {
  local NL=$'\n'
  [[ "${NL}${1}${NL}" == *"${NL}${2}${NL}"* ]]
}

# preflightCrostiniLxcfs detects orphaned lxcfs FUSE mounts on Crostini and
# aborts with a recovery pointer before any nix work happens. Returns 0 on
# non-crostini platforms or when /proc/meminfo is readable. Called only for
# substantive stages (1, 2, credential, all) -- -h bypasses.
preflightCrostiniLxcfs() {
  [[ $Platform == crostini ]] || return 0
  test -r /proc/meminfo && return 0
  echo "fatal: lxcfs disconnect detected (/proc/meminfo unreadable)" >&2
  echo "  Repair (doctor on PATH): crostini-procfs-doctor --repair" >&2
  echo "  Repair (direct path):    bash ~/projects/jeeves/guides/scripts/crostini-procfs-doctor --repair" >&2
  echo "  Guide:                   ~/projects/jeeves/guides/crostini-recovery-guide.md" >&2
  exit 1
}

# preflightCheckCommands verifies that commands referenced by downstream
# home-manager activations are available on PATH at update-env runtime.
# Default behavior is warn-only; with strict=1 (--strict), exits non-zero.
#
# Anchor: pangpSystemUnit activation failed because `systemctl` was absent
# from home-manager's activation PATH. The fix (dotfiles commit 0a888eb)
# replaced bare `systemctl` calls with `${pkgs.systemd}/bin/systemctl` in
# the nix expression. This preflight surfaces the same failure-class
# BEFORE home-manager runs, so the operator can either widen PATH or
# update the activation hooks to reference nix-managed binary paths.
#
# Hardcoded command list audited against current contexts/*.nix usage
# (systemctl in pangp/onepassword/crostini activations; sudo in pangp
# system-service install + crostini opGroupSetup). Add commands here
# when new activations introduce new system-command dependencies.
preflightCheckCommands() {
  local strict=${1:-0}
  local cmd missing=()
  for cmd in systemctl sudo; do
    command -v $cmd &>/dev/null || missing+=("$cmd")
  done
  (( ${#missing[@]} == 0 )) && return 0

  local m
  for m in "${missing[@]}"; do
    echo "warning: required command not on PATH: $m" >&2
    echo "  downstream home-manager activations invoke '$m' during activation." >&2
    echo "  consider using nix-managed \${pkgs.<pkg>}/bin/<cmd> pattern in" >&2
    echo "  home-manager activations (anchor: pangpSystemUnit fix at dotfiles" >&2
    echo "  commit 0a888eb)." >&2
  done

  if (( strict )); then
    echo "fatal: --strict preflight set and required commands missing: ${missing[*]}" >&2
    exit 1
  fi
}

# Stage 1: critical path -- working shell after completion + exec bash
stage1() {
  #  +-------------------------------------------------------------+
  #  | PHASE 1: System (section system)                            |
  #  |   +-> [crostini/debian] apt-get upgrade                     |
  #  +-------------------------------------------------------------+
  section system
  each task.Ln <<'  END'
    .config         ~/config
    .local          ~/local
    .ssh            ~/ssh
  END
  desc  'create ~/scratch directory'
  ok    "[[ -d ~/scratch ]]"
  cmd   "mkdir -p ~/scratch"
  local groupList
  groupList=$(platformTaskGroups $Platform)

  if hasGroup "$groupList" apt; then
    aptUpgradeTask
  fi

  if hasGroup "$groupList" hostname; then
    crostiniHostnameSetup
    task.Ln $CrostiniDir/secrets ~/secrets
    # ~/.netrc -> secrets/netrc depends on $CrostiniDir/secrets being seeded
    # via restoreSecrets (crostini path only); non-crostini hosts skip both
    # the parent secrets link and this child to avoid dangling links
    # (tasks.jeeves #18188).
    task.Ln secrets/netrc ~/.netrc
  fi

  # One-time cleanup: ~/.netrc symlink was historically created in the system
  # block (pre-#18188), leaving a dangling link on non-crostini hosts where
  # ~/secrets/netrc was never seeded. Remove on hosts that no longer match
  # the hostname group. SUNSET: drop this block after 2026-09-15 (3 months
  # post-cycle; active hosts will have run stage-1 by then).
  if ! hasGroup "$groupList" hostname; then
    desc  'remove stale ~/.netrc symlink (left behind by pre-#18188 stage-1)'
    ok    '[[ ! -L ~/.netrc ]]'
    cmd   'rm -f ~/.netrc'
  fi

  #  +-------------------------------------------------------------+
  #  | PHASE 2: Dotfiles & Configuration (section dotfiles)        |
  #  |   +-> Clone dotfiles from GitHub                            |
  #  |   +-> Create symlinks                                       |
  #  +-------------------------------------------------------------+
  section dotfiles
  task.GitClone https://github.com/binaryphile/dotfiles ~/dotfiles main
  try git -C ~/dotfiles remote set-url origin git@github.com:binaryphile/dotfiles.git
  try gitUpdate ~/dotfiles
  each task.Ln <<'  END'
    contexts/"$Platform"                          ~/dotfiles/context
    ~/dotfiles/bash/init.bash                     ~/.bash_profile
    ~/dotfiles/bash/init.bash                     ~/.bashrc
    ~/dotfiles/bash/init.bash                     ~/.profile
    ~/dotfiles/.shellcheckrc                      ~/.shellcheckrc
  END
  desc  'set git hooksPath to .githooks'
  ok    "[[ $(git -C ~/dotfiles config core.hooksPath) == .githooks ]]"
  cmd   "git -C ~/dotfiles config core.hooksPath .githooks"
  #  +-------------------------------------------------------------+
  #  | PHASE 3a: Package Management (gpoc, nix)                    |
  #  |   +-> [crostini] Install gpoc .deb from GitHub releases     |
  #  |   +-> Install Nix (Determinate installer, hash-verified)    |
  #  |   +-> Fix /nix ownership, write nix.conf, source profile    |
  #  +-------------------------------------------------------------+
  #  | PHASE 3b: Home Manager [crostini/debian]                    |
  #  |   +-> Apply Home Manager configuration (flake)              |
  #  |   +-> Converge task.bash to nix-pinned version              |
  #  +-------------------------------------------------------------+

  if hasGroup "$groupList" gpoc; then
    section gpoc
    aptInstallGpocTask
  fi

  if hasGroup "$groupList" pangp; then
    section pangp
    verifyPangpTarballTask
    aptRemoveGlobalprotectTask
    extractGlobalprotectDebToOptTask
    installPangpSystemDesktopTask
    enablePangpDefaultBrowserTask
  fi

  if hasGroup "$groupList" nix; then
    section nix
    installNixTask
    chownRTask /nix "$(id -u)" "$(id -g)"
    writeNixConfTask
    local nixProfile=/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
    [[ -r $nixProfile ]] || { echo "nix profile script not found at $nixProfile" >&2; return 1; }
    loosely source $nixProfile
  fi

  if hasGroup "$groupList" hm; then
    section home-manager
    homeManagerFlakeSwitchTask $Platform
    convergeTaskBash
  fi

  if hasGroup "$groupList" credential; then
    section credential
    try sshAgentPreflight
    try deploySigningPub
    try restoreSecrets
    try agentTomlTask
    section auth-preflight
    try authPreflight
    try runSigningKeyPreflight
  fi

  try task.Ln ~/dotfiles/update-env ~/.local/bin/update-env

  # One-time cleanup: sync-shellcheckrc script was retired in commit 727b09c
  # (2026-06-01); update-env's prior stage-1 task.Ln created the symlink on
  # hosts that ran update-env before the retirement, and existence-only
  # idempotence never repaired the dangling link. Predicate-gated removal
  # converges all hosts on the next post-cycle run (tasks.jeeves #18178).
  #
  # SUNSET: remove this block after 2026-09-15 (3 months post-cycle). By
  # then every active host will have run stage-1 at least once, executed
  # the cleanup, and the block becomes pure overhead. If a stale host
  # surfaces after the sunset, restore the block or remove the dangling
  # link manually.
  desc  'remove stale ~/.local/bin/sync-shellcheckrc (script retired 2026-06-01)'
  ok    '[[ ! -e ~/.local/bin/sync-shellcheckrc && ! -L ~/.local/bin/sync-shellcheckrc ]]'
  cmd   'rm -f ~/.local/bin/sync-shellcheckrc'

  claudeBaseCopyTask
  claudeSettingsCopyTask
  try task.Ln ~/dotfiles/claude/claude-bg-bash-guard ~/.local/bin/claude-bg-bash-guard
  try task.Ln ~/dotfiles/claude/claude-bash-lint-guard ~/.local/bin/claude-bash-lint-guard
  try task.Ln ~/dotfiles/claude/claude-guide-load-guard ~/.local/bin/claude-guide-load-guard
  try task.Ln ~/dotfiles/claude/claude-agent-identity ~/.local/bin/claude-agent-identity
}

stage1Epilogue() {
  echo
  echo "Stage 1 complete. Working shell with identity."
  echo "Run 'exec bash' to reload your shell."
  echo "Then run 'update-env -2' to clone projects and dev tool repos."
}

stage2Preflight() {
  local missing=()
  command -v nix  &>/dev/null || missing+=("nix")
  command -v git  &>/dev/null || missing+=("git")
  [[ -d ~/dotfiles ]]        || missing+=("~/dotfiles")
  if (( ${#missing[@]} )); then
    echo "Stage 2 requires: ${missing[*]}"
    echo "Run 'update-env -1' first, then 'exec bash'."
    exit 2
  fi
}

credentialPreflight() {
  case $Platform in
    crostini ) ;;
    * )
      echo "Credential setup is only supported on Crostini."
      echo "On this platform ($Platform), credentials are managed separately."
      exit 2
      ;;
  esac
  local missing=()
  [[ -d ~/dotfiles ]]                 || missing+=("~/dotfiles")
  if [[ ! -f $CrostiniDir/hostname ]]; then
    missing+=("hostname (run 'update-env -1 <hostname>' first)")
  else
    local h
    h=$(lib.MachineHostname) || missing+=("hostname (file exists but unreadable)")
    lib.ValidateHostname "${h:-}" 2>/dev/null || missing+=("hostname '${h:-}' is invalid")
  fi
  if (( ${#missing[@]} )); then
    echo "Credential stage requires: ${missing[*]}"
    echo "Run 'update-env -1' first, then 'exec bash'."
    exit 2
  fi
}

# Credential-only stage: runs SSH key, signing key, secrets, agent load,
# and auth preflight without re-running system setup or packages. Useful
# when stage 1 completed phases 1-3 but credentials need interactive
# completion (e.g., interrupted bootstrap, key generation deferred from
# non-interactive run).
credentialStage() {
  section credential
  try sshAgentPreflight
  try deploySigningPub
  try restoreSecrets
  try agentTomlTask
  section auth-preflight
  try authPreflight
  try runSigningKeyPreflight
}

# Stage 2: projects, builds, and config -- all externals try-wrapped
stage2() {
  # Re-run home-manager to converge (idempotent -- no-op if stage 1
  # already applied the same config).
  local groupList
  groupList=$(platformTaskGroups $Platform)
  if hasGroup "$groupList" hm; then
    section home-manager
    homeManagerFlakeSwitchTask $Platform
    convergeTaskBash
  fi

  #  +-------------------------------------------------------------+
  #  | PHASE 4: Platform-Specific Setup                            |
  #  |   +-> [crostini only]:                                      |
  #  |       * Link ~/crostini -> $CrostiniDir                      |
  #  |       * Clone project directories from permanent mount      |
  #  +-------------------------------------------------------------+
  if [[ $Platform == crostini ]]; then
    section crostini
    task.Ln $CrostiniDir ~/crostini

  fi

  #  +-------------------------------------------------------------+
  #  | PHASE 5 (core): Dev Tool Clones (nix-packaged, cloned for  |
  #  |   development). Tools available via nix after stage 1.      |
  #  |   +-> task.bash         - task automation                   |
  #  |   +-> fp.bash           - functional programming utilities  |
  #  |   +-> mk.bash           - build tool & git updater          |
  #  |   +-> tesht             - testing framework                 |
  #  +-------------------------------------------------------------+

  section task.bash
  try githubCloneAndLinkTask task.bash
  try task.Ln ~/projects/task.bash/task.bash ~/.local/bin/task.bash
  try obsidianSnippetsTask ~/projects/task.bash/.obsidian/snippets

  section fp.bash
  try githubCloneAndLinkTask fp.bash
  desc  'switch fp.bash to main (was develop)'
  ok    '[[ $(git -C ~/projects/fp.bash branch --show-current 2>/dev/null) != develop ]]'
  cmd   'git -C ~/projects/fp.bash checkout main'
  try task.Ln ~/projects/fp.bash/fp.bash ~/.local/bin/fp.bash
  try obsidianSnippetsTask ~/projects/fp.bash/.obsidian/snippets

  section mk.bash
  try githubCloneAndLinkTask mk.bash
  desc  'switch mk.bash to main (was develop)'
  ok    '[[ $(git -C ~/projects/mk.bash branch --show-current 2>/dev/null) != develop ]]'
  cmd   'git -C ~/projects/mk.bash checkout main'
  try obsidianSnippetsTask ~/projects/mk.bash/.obsidian/snippets
  try task.Ln ~/projects/mk.bash/mk.bash ~/.local/bin/mk.bash
  # Global `mk` binary retired 2026-06-01: git-update functionality replaced
  # by try clauses in update-env. Library still installed for per-project ./mk
  # scripts that source it.
  desc  'remove stale ~/.local/bin/mk symlink (global mk retired 2026-06-01)'
  ok    '[[ ! -e ~/.local/bin/mk && ! -L ~/.local/bin/mk ]]'
  cmd   'rm -f ~/.local/bin/mk'

  section tesht
  try githubCloneAndLinkTask tesht
  desc  'switch tesht to main (was develop)'
  ok    '[[ $(git -C ~/projects/tesht branch --show-current 2>/dev/null) != develop ]]'
  cmd   'git -C ~/projects/tesht checkout main'
  try task.Ln ~/projects/tesht/tesht ~/.local/bin/tesht
  try obsidianSnippetsTask ~/projects/tesht/.obsidian/snippets

  #  +-------------------------------------------------------------+
  #  | PHASE 5 (projects): Additional Tools & Projects             |
  #  |   +-> shellcheck        - ShellCheck fork (dynamic plugins) |
  #  |   +-> shellcheck-convention-plugin - SC9001-SC9004 plugin   |
  #  |   +-> jeeves            - project guides (bitbucket)        |
  #  |   +-> fluentfp          - Go FP library (sofdevsim go.mod   |
  #  |                           replace target: ../fluentfp)      |
  #  |   +-> sofdevsim-2026    - software dev simulation           |
  #  |   +-> blog              - binaryphile.github.io             |
  #  |   +-> tandem-protocol   - Claude slash commands             |
  #  |   +-> era               - semantic memory MCP               |
  #  |       Default branch: main. Cloned and symlinked.           |
  #  |   +-> toc               - TOC DBR pipeline lib              |
  #  |   +-> tmux-claude       - tmux plugin for claude panes      |
  #  |   +-> agent-orchestration - coordination spec + reference   |
  #  |   +-> flake-locks       - pin all locks to same nixpkgs rev |
  #  +-------------------------------------------------------------+

  section shellcheck
  try githubCloneAndLinkTask shellcheck main

  section shellcheck-convention-plugin
  try githubCloneAndLinkTask shellcheck-convention-plugin

  section jeeves
  try bitbucketCloneAndLinkTask jeeves
  try obsidianSnippetsTask ~/projects/jeeves/.obsidian/snippets
  desc  'set git hooksPath to .githooks (UC-14 binary-rejection pre-commit)'
  ok    "[[ $(git -C ~/projects/jeeves config core.hooksPath) == .githooks ]]"
  cmd   "git -C ~/projects/jeeves config core.hooksPath .githooks"

  section fluentfp
  try githubCloneAndLinkTask fluentfp

  section sofdevsim-2026
  try githubCloneAndLinkTask sofdevsim-2026
  try obsidianSnippetsTask ~/projects/sofdevsim-2026/.obsidian/snippets
  each try task.Ln nix-wrapper <<'  END'
    ~/projects/sofdevsim-2026/bin/go
    ~/projects/sofdevsim-2026/bin/node
    ~/projects/sofdevsim-2026/bin/npx
  END

  section finances
  try githubCloneAndLinkTask finances
  try obsidianSnippetsTask ~/projects/finances/.obsidian/snippets
  desc  'set git hooksPath to .githooks (privacy-firewall pre-commit)'
  ok    "[[ $(git -C ~/projects/finances config core.hooksPath) == .githooks ]]"
  cmd   "git -C ~/projects/finances config core.hooksPath .githooks"

  section blog
  try githubCloneAndLinkTask binaryphile.github.io
  try obsidianSnippetsTask ~/projects/binaryphile.github.io/.obsidian/snippets

  section tandem-protocol
  try githubCloneAndLinkTask tandem-protocol
  try obsidianSnippetsTask ~/projects/tandem-protocol/.obsidian/snippets
  desc   'remove stale /g command (renamed to /grade)'
  ok     '[[ ! -e ~/.claude/commands/g.md ]]'
  cmd    'rm -f ~/.claude/commands/g.md'

  lib.Glob ~/projects/tandem-protocol/commands/* |
    keepIf isFile |
    map path '$path ~/.claude/commands/$(basename $path)' |
    each task.Ln

  section era
  try githubCloneAndLinkTask era
  try obsidianSnippetsTask ~/projects/era/.obsidian/snippets
  try eraBuildTask
  each task.Ln <<'  END'
    ~/projects/era/bin/era           ~/.local/bin/era
    ~/projects/era/bin/era-serve     ~/.local/bin/era-serve
    ~/projects/era/bin/era-hook      ~/.local/bin/era-hook
    ~/projects/era/bin/era-soak              ~/.local/bin/era-soak
    ~/projects/era/bin/era-soak-fit          ~/.local/bin/era-soak-fit
    ~/projects/era/bin/era-package           ~/.local/bin/era-package
    ~/projects/era/bin/evtctl                ~/.local/bin/evtctl
    ~/projects/era/bin/task-audit             ~/.local/bin/task-audit
    ~/projects/era/bin/validate-attestation   ~/.local/bin/validate-attestation
    ~/projects/era/bin/validate-plan          ~/.local/bin/validate-plan
    ~/projects/era/bin/cross-repo-dirty-sweep ~/.local/bin/cross-repo-dirty-sweep
    ~/projects/era/bin/stash-audit            ~/.local/bin/stash-audit
  END

  lib.Glob ~/projects/era/commands/* |
    keepIf isFile |
    map path '$path ~/.claude/commands/$(basename $path)' |
    each task.Ln

  lib.Glob ~/projects/share/commands/* |
    keepIf isFile |
    map path '$path ~/.claude/commands/$(basename $path)' |
    each task.Ln

  each try <<'  END'
    eraMcpCleanupTask
    eraServiceCleanupTask
  END
  each try task.Install 644 <<'  END'
    ~/projects/era/era.service ~/.config/systemd/user/era.service
    ~/projects/era/evtctl-forward@.service ~/.config/systemd/user/evtctl-forward@.service
    ~/projects/era/evtctl-canary-watch@.service ~/.config/systemd/user/evtctl-canary-watch@.service
    ~/projects/era/evtctl-canary-watch@.timer ~/.config/systemd/user/evtctl-canary-watch@.timer
    ~/dotfiles/evtctl-forward/dropins/evtctl-forward@urma.service.d/canary-interval.conf ~/.config/systemd/user/evtctl-forward@urma.service.d/canary-interval.conf
