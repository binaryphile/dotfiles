# remoteAvailable -- session-cached reachability probe for a hostname.
# First call per host pings once (-W 2); the result is memoized so subsequent
# calls return immediately. Used by gitUpdate and stashCloneAndLinkTask to
# skip work cleanly when a remote (corp VPN, Codeberg, etc.) is unreachable
# instead of issuing N redundant SSH lookups that all fail the same way.
declare -A RemoteUp_
remoteAvailable() {
  local host=$1
  if [[ -z ${RemoteUp_[$host]:-} ]]; then
    if ping -c 1 -W 2 "$host" >/dev/null 2>&1; then
      RemoteUp_[$host]=1
    else
      RemoteUp_[$host]=0
    fi
  fi
  [[ ${RemoteUp_[$host]} == 1 ]]
}

# git autostash pop can fail silently when local and upstream both modified the same file;
# on conflict the stash stays, labeled "autostash". Drop it -- pulled version wins.
# Targets the specific stash ref (not stash@{0}) to avoid clobbering user stashes above it.
#
# Auto-skip when the repo's origin host is unreachable -- the per-host probe in
# remoteAvailable caches the result so the second-and-later same-host repos no-op
# silently instead of each producing its own "Could not resolve hostname" failure.
gitUpdate() {
  local dir=$1 host
  host=$(git -C "$dir" remote get-url origin 2>/dev/null | sed -E 's|.*[/@]([^/:]+)[/:].*|\1|')
  if [[ -n $host ]] && ! remoteAvailable "$host"; then
    return 0
  fi
  task.GitUpdate $1
  local stashRef
  stashRef=$(git -C $1 stash list 2>/dev/null | grep -E ': autostash$' | grep -o 'stash@{[0-9]*}' | head -1) || true
  [[ -z $stashRef ]] || loosely git -C $1 stash drop $stashRef >/dev/null 2>&1
}

# evtctlAgentEnvrcAllProjectsTask iterates ~/projects/*/ and ensures each
# project's .envrc carries a per-project EVTCTL_AGENT export
# (claude-<project-basename>@<host>). Idempotent: skips projects whose
# .envrc already exports EVTCTL_AGENT; appends the standard block otherwise.
# Skips dirs with no .envrc (uninitialized scaffold).
#
# Per-project identity lets parallel Claude agents (one per project tmux
# window) publish events with distinct metadata.agent so cross-project
# audits + the operator-authored decision-share metric (icarus roadmap
# §Phase B indicator #7) can distinguish them. See era docs/evtctl.md
# §"Mux identity contract".
#
# Note on Claude Code's SessionStart hook
# (~/dotfiles/claude/claude-agent-identity): post-2026-06-22 the hook
# prefers cwd-local .claude/agent-role over global ~/.claude/agent-role
# AND appends a 6-char session-id suffix when role is set, so .envrc +
# hook together produce: interactive shells get `claude-<project>@<host>`
# (no suffix); Claude Code sessions get `claude-<project>-<sid6>@<host>`
# (suffix per session, parallel-agent-safe). The per-project
# .claude/agent-role file is scaffolded by claudeAgentRoleAllProjectsTask
# below.
evtctlAgentEnvrcAllProjectsTask() {
  local dir_
  find ~/projects -mindepth 1 -maxdepth 1 -type d 2>/dev/null | while IFS= read -r dir_; do
    evtctlAgentEnvrcTask "$dir_"
  done
}

# claudeAgentRoleAllProjectsTask iterates ~/projects/*/ and ensures each
# project carries a .claude/agent-role file whose contents is the project's
# basename. Read by the SessionStart hook (claude-agent-identity) at session
# start; sets the role half of the identity so Claude Code sessions in
# ~/projects/era publish as `claude-era-<sid6>@<host>`, sessions in
# ~/projects/icarus publish as `claude-icarus-<sid6>@<host>`, etc.
# Idempotent: writes the file only when absent or stale (basename changed).
claudeAgentRoleAllProjectsTask() {
  local dir_
  find ~/projects -mindepth 1 -maxdepth 1 -type d 2>/dev/null | while IFS= read -r dir_; do
    claudeAgentRoleTask "$dir_"
  done
}

claudeAgentRoleTask() {
  local dir=$1
  local path=$dir/.claude/agent-role
  local basename_=${dir##*/}

  desc "ensure $path contains '$basename_'"
  ok "[[ -f $path ]] && [[ \$(<$path) == '$basename_' ]]"

  claudeAgentRoleWrite() {
    mkdir -p "$dir/.claude"
    printf '%s\n' "$basename_" > "$path"
  }
  cmd claudeAgentRoleWrite
}

evtctlAgentEnvrcTask() {
  local dir=$1
  local path=$dir/.envrc

  desc "ensure EVTCTL_AGENT export in $path"
  ok "[[ ! -f $path ]] || grep -qE '^export EVTCTL_AGENT=' $path 2>/dev/null"
  check "[[ -f $path ]]"   # only operate on projects with a scaffold-shaped .envrc

  evtctlAgentEnvrcAppend() {
    cat >> $path <<'ENVRC'

# Per-project mux-identity attribution (era docs/evtctl.md §"Mux identity
# contract"). Identity = claude-<project-basename>@<host>; host is
# Crostini-aware (~/crostini/hostname when present, else $(hostname)).
HostShort_=$([[ -r $HOME/crostini/hostname ]] && cat $HOME/crostini/hostname || hostname)
