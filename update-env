eraBuildTask() {
  desc 'build era binaries (rebuild if any era source file is newer than the binary)'
  prog on

  # Predicate: binary exists AND is at-or-newer-than the newest .go file
  # in the source paths that contribute to era-serve. If the binary is
  # absent or older than any contributing source, rebuild.
  #
  # Trade-off: filesystem-mtime check is coarser than Go's build cache
  # (which checks content hash) but cheap + reliable across nix-shell
  # entries. Go will internally no-op if its own cache says nothing
  # changed, so re-invoking the build under stale mtime is safe + fast.
  eraBinIsCurrent() {
    local bin=~/projects/era/bin/era-serve
    [[ -f $bin ]] || return 1
    local binTime newest=0 path mt
    binTime=$(stat -c %Y "$bin")
    # Source paths whose changes can affect era-serve's behavior.
    for path in \
        ~/projects/era/cmd/era-serve \
        ~/projects/era/internal \
        ~/projects/era/era.go \
        ~/projects/era/storepipeline; do
      [[ -e $path ]] || continue
      if [[ -d $path ]]; then
        mt=$(find $path -name '*.go' -printf '%T@\n' 2>/dev/null | sort -n | tail -1)
      else
        mt=$(stat -c %Y "$path")
      fi
      mt=${mt%.*}
      [[ -z $mt ]] && continue
      (( mt > newest )) && newest=$mt
    done
    (( binTime >= newest ))
  }
  ok eraBinIsCurrent

  # Build via bin/mk into era's bin/. The ~/.local/bin/era-serve
  # symlink target stays constant (~/projects/era/bin/era-serve); the
  # file AT that path is replaced; subsequent lookups via PATH pick up
  # the new binary automatically without symlink churn. bin/mk handles
  # the CGO_ENABLED=0 pure-Go static-binary discipline + builds the
  # adjacent binaries (era-package, era-soak-fit, era-embed-bench) the
  # symlink stanza below also depends on.
  cmd 'nix develop ~/projects/era --command bash -c "cd ~/projects/era && go generate ./internal/hugot/ && bin/mk build"'
}

