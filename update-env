# obsidianSnippetsTask deploys shared CSS snippets from dotfiles/obsidian/snippets/
# to the given .obsidian/snippets/ directory. The parent .obsidian dir need not
# exist yet -- mkdir -p creates it. Idempotent: skips files already matching.
obsidianSnippetsTask() {
  local snippetsDir=$1
  local srcDir=$HOME/dotfiles/obsidian/snippets

  desc "deploy obsidian snippets to $snippetsDir"

  obsidianSnippetsUpToDate() {
    local IFS=$'\n' f
    for f in $(lib.Glob $srcDir/*.css); do
      [[ -f $snippetsDir/$(basename $f) ]] && diff -q $f $snippetsDir/$(basename $f) >/dev/null 2>&1 || return 1
