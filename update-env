# agentTomlTask writes ~/.config/1Password/ssh/agent.toml to restrict which
# keys the 1Password SSH agent offers to the current machine. Without this,
# the agent offers ALL vault keys to every server (use-authority expansion).
agentTomlTask() {
  local hostname=${agentToml_hostname:-$(lib.MachineHostname)}
  local path=${agentToml_path:-$HOME/.config/1Password/ssh/agent.toml}
  desc "write 1Password agent.toml for $hostname"

  agentTomlUpToDate() {
    [[ -f $path ]] && diff -q $path <(agentTomlContent $hostname) >/dev/null 2>&1
  }
  ok agentTomlUpToDate

  agentTomlInstall() {
    mkdir -p $(dirname $path)
    agentTomlContent $hostname >$path
  }
  cmd agentTomlInstall
}

agentTomlContent() {
  local hostname=$1
  # Auth key listed first so ssh negotiation matches it before the signing key.
  # On flat-section registries (Codeberg/Forgejo issue #4268), this preserves
  # NIST SP 800-57 key-purpose separation operationally: auth ops use the auth
  # key, signing ops use the signing key (via op-ssh-sign which selects by
  # fingerprint, not by agent-offer order).
  cat <<EOF
[[ssh-keys]]
account = "$(opAccount $hostname)"
vault = "$(opVault $hostname)"
item = "$(opAuthKeyItem $hostname)"

[[ssh-keys]]
account = "$(opAccount $hostname)"
vault = "$(opVault $hostname)"
item = "$(opSigningKeyItem $hostname)"
EOF
}

# claudeBaseCopyTask copies the base CLAUDE.md (Conventions, Secrets) to
# ~/.claude/. Runs in stage 1 after HM switch. Stage 2's claudeEraConfigTask
# appends era content. Not managed by HM because stage 2 mutates it.
claudeBaseCopyTask() {
  local src=${claudeBase_src:-$HOME/dotfiles/claude/CLAUDE.md}
  local dst=${claudeBase_dst:-$HOME/.claude/CLAUDE.md}
  local hashFile=${claudeBase_hash:-$HOME/.claude/CLAUDE.md.base-src-hash}
  desc 'install base CLAUDE.md'

  # Content-aware: redeploy when source changes. Per-task hash sentinel matches
  # the precedent of claudeMemoryRedirectsTask using diff-q. Era and tandem
  # appends are non-destructive on redeploy because their own ok-tests grep for
  # marker strings that won't exist after a fresh base copy.
  #
  # Uses the $sha256sum DI var (defined near script bottom) which resolves to
  # GNU sha256sum on Linux/Nix and falls back to BSD `shasum -a 256` on bare
  # macOS. The DI var is split-on-spaces by bash for the multi-word fallback.
  claudeBaseUpToDate() {
    [[ -f $dst ]] && ! [[ -L $dst ]] || return 1
    [[ -f $hashFile ]] || return 1
    [[ "$($sha256sum $src | cut -d' ' -f1)" == "$(< $hashFile)" ]]
  }
  ok claudeBaseUpToDate

  claudeBaseCopy() {
    mkdir -p $(dirname $dst)
    local tmp
    tmp=$(mktemp) && cp $src "$tmp" && mv -f "$tmp" $dst
    $sha256sum $src | cut -d' ' -f1 >$hashFile
  }
  cmd claudeBaseCopy
}

# claudeSettingsCopyTask copies claude-code settings.json to ~/.claude/.
# Mirrors claudeBaseCopyTask shape: content-aware via per-task hash sentinel.
# Anchor 2026-06-15: shell-hygiene mechanical guard (claude-bg-bash-guard)
# requires a PreToolUse hook entry; settings.json carries that wiring.
# Memory-only enforcement of the rule failed; auto-deploying settings.json
# is what makes the mechanical block actually fire on fresh hosts.
