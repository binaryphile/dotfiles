# Projects with non-standard flake inputs that can't share the canonical lock.
# Pin all flake.lock files to the same nixpkgs revision.
# Uses nix flake lock --override-input to update each lock file's nixpkgs
# input to the canonical rev (from ~/projects/era/flake.lock).
# Nix deduplicates store paths automatically when revs match.
# flakeManagedDirs emits dirs that have both flake.nix and flake.lock, where
# flake.nix is tracked by git (the same check nix uses). Untracked flake.nix
# files (e.g. urma: local-only, git-excluded) are naturally skipped.
# find is scoped to avoid .git dirs, node_modules, and vendor trees.
# Shared by flakeLocksRepairTask and flakeLockPinTask.
flakeManagedDirs() {
  local f
  while IFS= read -r f; do
    [[ -f $f/flake.lock ]] || continue
    git -C "$f" ls-files --error-unmatch flake.nix &>/dev/null || continue
    echo "$f"
  done < <(find ~/projects ~/dotfiles \
    -not -path '*/.git/*' \
    -not -path '*/node_modules/*' \
    -not -path '*/vendor/*' \
    -name flake.nix -exec dirname {} \; 2>/dev/null)
}

flakeLocksRepairTask() {
  desc 'repair flake.lock in flake-managed dirs (unmerged index or unparseable JSON)'
  # Observed twice on caltrop (task.bash, mk.bash): flake.lock in "needs merge"
  # state (UU in `git status -s`) after a prior failed flakeLockPin attempt
  # left the index unresolved. `git restore` updates only the working tree;
  # `git checkout HEAD --` clears both the working tree AND the index
  # entries, recovering the file from HEAD's tree -- which is the canonical
  # state since local flake.lock edits are mechanical and reproducible by
  # the next flakeLockPin run. Predicate covers both failure modes (unmerged
  # index OR jq parse failure) so this is a no-op on healthy repos.

  flakeLocksHealthy() {
    local f
    while IFS= read -r f; do
      git -C "$f" status --porcelain -- flake.lock 2>/dev/null | grep -q '^UU' && return 1
      jq empty "$f/flake.lock" 2>/dev/null || return 1
    done < <(flakeManagedDirs)
  }
  ok flakeLocksHealthy

  flakeLocksRepair() {
    local f
    while IFS= read -r f; do
      if git -C "$f" status --porcelain -- flake.lock 2>/dev/null | grep -q '^UU' \
         || ! jq empty "$f/flake.lock" 2>/dev/null; then
        git -C "$f" checkout HEAD -- flake.lock 2>/dev/null || true
      fi
    done < <(flakeManagedDirs)
  }
  cmd flakeLocksRepair
}

flakeLockPathInputsRefreshTask() {
  desc 'refresh narHash of any path: input whose on-disk content drifted'
  # path: inputs (e.g. nixos-config's dotfiles and pangp-src) recompute their
  # narHash on every content change. When the lock's hash and the on-disk hash
  # diverge, nix evaluation aborts with "NAR hash mismatch" -- which blocks
  # nixos-rebuild and any downstream `nix build`. Hit twice in one session:
  # dotfiles after committing to it, pangp-src after the placeholder rolled.
  # This task scans every flake-managed dir, recomputes each path-input's
  # narHash, and runs `nix flake lock --update-input <name>` only when the
  # locked and actual hashes disagree. No-op on healthy machines.

  pathInputsCurrent() {
    local d name lockedPath lockedHash actualHash
    while IFS= read -r d; do
      while IFS=$'\t' read -r name lockedPath lockedHash; do
        [[ -e $lockedPath ]] || continue
        actualHash=$(nix hash path "$lockedPath" 2>/dev/null) || continue
        [[ $lockedHash == "$actualHash" ]] || return 1
      done < <(jq -r '.nodes | to_entries[] | select(.value.locked.type == "path") | "\(.key)\t\(.value.locked.path)\t\(.value.locked.narHash)"' "$d/flake.lock" 2>/dev/null)
    done < <(flakeManagedDirs)
  }
  ok pathInputsCurrent

  pathInputsRefresh() {
    local d name lockedPath lockedHash actualHash
    while IFS= read -r d; do
      while IFS=$'\t' read -r name lockedPath lockedHash; do
        [[ -e $lockedPath ]] || continue
        actualHash=$(nix hash path "$lockedPath" 2>/dev/null) || continue
        if [[ $lockedHash != "$actualHash" ]]; then
          (cd "$d" && nix flake lock --update-input "$name" 2>/dev/null) || true
        fi
      done < <(jq -r '.nodes | to_entries[] | select(.value.locked.type == "path") | "\(.key)\t\(.value.locked.path)\t\(.value.locked.narHash)"' "$d/flake.lock" 2>/dev/null)
    done < <(flakeManagedDirs)
  }
  cmd pathInputsRefresh
}

flakeLockPinTask() {
  desc 'pin all flake.lock nixpkgs to canonical rev'

  # flakeManagedDirs lives at top level (above flakeLocksRepairTask) so both
  # tasks share one iteration definition.

  flakeLocksPinned() {
    local canonical=~/projects/era/flake.lock
    [[ -f $canonical ]] || return 1
    local canonicalRev
    canonicalRev=$(jq -r '.nodes.nixpkgs.locked.rev' $canonical)
    [[ -n $canonicalRev && $canonicalRev != null ]] || return 1
    local f rev
    while IFS= read -r f; do
      rev=$(jq -r '.nodes.nixpkgs.locked.rev // empty' "$f/flake.lock" 2>/dev/null)
      [[ $rev == "$canonicalRev" ]] || return 1
    done < <(flakeManagedDirs)
  }
  ok flakeLocksPinned

  # flakeLocksPin copies the canonical nixpkgs locked entry from era/flake.lock
  # directly into each managed project's flake.lock via jq. This avoids
  # nix flake lock --override-input, which implies --no-write-lock-file and
  # therefore never actually writes anything.
  # After pinning, commits and pushes each changed flake.lock so other machines
  # see the canonical rev on their next gitUpdate and avoid autostash conflicts.
  # Push is loosely'd -- SSH failures (Codeberg, Bitbucket) are non-fatal;
  # the next machine with remote access propagates.
  flakeLocksPin() {
    local canonical=~/projects/era/flake.lock
    [[ -f $canonical ]] || { echo "no canonical flake.lock at $canonical" >&2; return 1; }
    local canonicalNode canonicalRev
    canonicalNode=$(jq '.nodes.nixpkgs.locked' $canonical)
    canonicalRev=$(jq -r '.nodes.nixpkgs.locked.rev' $canonical)
    [[ -n $canonicalNode && $canonicalNode != null ]] || { echo "cannot extract nixpkgs locked node from canonical" >&2; return 1; }
    # Per-file jq failures (malformed flake.lock somewhere downstream) warn and skip
    # rather than aborting the whole pin pass. One bad lock used to mask every other
    # repo's drift.
    local f tmp
    while IFS= read -r f; do
      tmp=$(mktemp) || { echo "error: cannot create temp file" >&2; return 1; }
      if ! jq --argjson node "$canonicalNode" '.nodes.nixpkgs.locked = $node' "$f/flake.lock" >"$tmp" 2>/dev/null; then
        rm -f "$tmp"
        echo "warn: jq failed on $f/flake.lock -- skipping" >&2
        continue
      fi
      mv "$tmp" "$f/flake.lock"
    done < <(flakeManagedDirs)
    while IFS= read -r f; do
      [[ -z $(git -C "$f" status --porcelain -- flake.lock 2>/dev/null) ]] && continue
      git -C "$f" add flake.lock
      loosely git -C "$f" commit -m "pin nixpkgs to canonical rev ${canonicalRev:0:8}"
      loosely git -C "$f" push
    done < <(flakeManagedDirs)
  }
  cmd flakeLocksPin
}

# NOTE: the pre-commit flake.lock-drift guard lives in
# ~/dotfiles/.githooks/pre-commit (checkFlakeLockPin). Because
