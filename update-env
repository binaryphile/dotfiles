stashCloneAndLinkTask() {
  local repo=$1 dir=${2:-$1} project=${3:-idigi} branch=${4:-main}

  desc   "clone repo stash.digi.com/$project/$repo to ~/projects/$dir"
  exist  $HOME/projects/$dir/.git
  check  'remoteAvailable stash.digi.com'

  stashClone() {
    local dest=~/projects/"$dir"
    if [[ -d $dest && ! -d $dest/.git ]]; then
      # Directory exists (scaffold/obsidian) but no git repo.
      # Stash contents via atomic rename, clone fresh, overlay preserved files back.
      # On any failure, restore original state via atomic rename.
      local stash
      stash=$(mktemp -d "${dest}.XXXXXX")
      rmdir "$stash"
      mv $dest "$stash"
      GIT_SSH_COMMAND='ssh -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10' git clone --branch $branch "git@stash.digi.com:$project/$repo.git" $dest || {
        rm -rf $dest
        mv "$stash" $dest
        return 1
      }
      cp -a "$stash/." "$dest/"
      rm -rf "$stash"
    else
      GIT_SSH_COMMAND='ssh -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10' git clone --branch $branch "git@stash.digi.com:$project/$repo.git" $dest
    fi
  }
  cmd stashClone

  try gitUpdate ~/projects/$dir
}

