#!/usr/bin/env bash

# update-env -- create and maintain my work environment

# Naming Policy:
#
# All function and variable names are camelCased.
#
# Local variable names begin with lowercase letters, e.g. localVariable.
# Global variable names begin with uppercase letters, e.g. GlobalVariable.
#
# Injectable dependency variables use the command name directly (snake_case,
# underscores replacing hyphens): e.g. ssh_keygen. Lowercase despite being
# global -- designed to be shadowed by local declarations in tests via bash
# dynamic scoping. See bash style guide # Injectable dependencies.
#
# Variables containing IFS characters (newlines under IFS=$'\n') are marked so
# the reader knows to quote them. Two conventions, mutually exclusive:
#   - Trailing underscore: oldIfs_, cmd_. Name alone doesn't signal IFS content.
#   - *List suffix: groupList, hostList. Suffix signals multi-value (implies IFS).
#
# Variable declarations that are name references borrow the environment namespace, e.g.
# "local -n ARRAY=$1".
#
# Locally-defined task functions are suffixed with "Task".

# the persistent crostini directory
# it does not have spaces and is exempt from quoting
CrostiniDir=/mnt/chromeos/MyFiles/Downloads/crostini

usageText() {
  cat <<'EOF'
Usage: update-env [-1 [hostname] | -2 | -c] [-s] [-x]

  -1, --stage1 [hostname]  Stage 1: system, packages, credentials
  -2, --stage2             Stage 2: projects, dev tools, config
  -c, --credential         Credential setup only (SSH key, signing key, secrets)
  -s, --short              Short run (skip unchanged tasks)
  -x, --trace              Enable bash trace output
  -h, --help               Show this help

  Bare 'update-env' runs both stages sequentially.
  Hostname is required on first Crostini run with -1.
  -c requires prior completion of stage 1 phases 1-3.
EOF
}

# Two-stage execution: stage 1 delivers a working shell (phases 1-3 + core
# tools); stage 2 handles remaining projects, builds, and config.
# Bare `update-env` runs both stages sequentially (backwards-compatible).
main() {
  set -eufo pipefail   # enable strict mode (f = noglob)
  IFS=$'\n'
  export GIT_CONFIG_COUNT=1
  export GIT_CONFIG_KEY_0=rebase.autoStash
  export GIT_CONFIG_VALUE_0=true
  Platform=$($platform)
  readonly Platform

  case $Stage in
    1          ) stage1; stage1Epilogue;;
    2          ) stage2Preflight; stage2;;
    credential ) credentialPreflight; credentialStage;;
    all        ) stage1; stage2;;
  esac

  task.Summarize
  postInstallMessages
}

# platformTaskGroups -- pure decision function mapping platform to the set of
# task groups both stages should run. No side effects.
# Groups: apt, hostname, gpoc, nix, hm, credential.
# nix = install nix itself. hm = apply home-manager flake config.
# hm is separate from nix because not all nix platforms have flake configs
# in this repo (linux needs nixos-config's flake, macos needs darwin pkgs).
platformTaskGroups() {
  local platform=$1
  local groups=()
  case $platform in crostini|debian )   groups+=(apt);; esac
  case $platform in crostini )          groups+=(hostname gpoc);; esac
  case $platform in crostini|debian|desktop|macos ) groups+=(nix);; esac
  case $platform in crostini|debian|desktop|macos ) groups+=(hm);; esac
  case $platform in crostini )          groups+=(credential);; esac
  echo "${groups[*]}"
}

# hasGroup tests whether a newline-separated group list contains a group name.
# Exact line match -- avoids substring false positives (e.g., *hm* matching "ohmy").
# Groups are newline-separated because ${array[*]} joins with IFS[0] ($'\n').
hasGroup() {
  local NL=$'\n'
  [[ "${NL}${1}${NL}" == *"${NL}${2}${NL}"* ]]
}

# Stage 1: critical path -- working shell after completion + exec bash
stage1() {
  #  +-------------------------------------------------------------+
  #  | PHASE 1: System (section system)                            |
  #  |   +-> [crostini/debian] apt-get upgrade                     |
  #  +-------------------------------------------------------------+
  section system
  each task.Ln <<'  END'
    .config         ~/config
    .local          ~/local
    .ssh            ~/ssh
    secrets/netrc   ~/.netrc
  END
  local groupList
  groupList=$(platformTaskGroups "$Platform")

  if hasGroup "$groupList" apt; then
    aptUpgradeTask
  fi

  if hasGroup "$groupList" hostname; then
    crostiniHostnameSetup
    task.Ln $CrostiniDir/secrets ~/secrets
  fi

  #  +-------------------------------------------------------------+
  #  | PHASE 2: Dotfiles & Configuration (section dotfiles)        |
  #  |   +-> Clone dotfiles from GitHub                            |
  #  |   +-> Create symlinks                                       |
  #  +-------------------------------------------------------------+
  section dotfiles
  task.GitClone https://github.com/binaryphile/dotfiles ~/dotfiles main
  try git -C ~/dotfiles remote set-url origin git@github.com:binaryphile/dotfiles.git
  try task.GitUpdate ~/dotfiles
  each task.Ln <<'  END'
    contexts/"$Platform"                          ~/dotfiles/context
    ~/dotfiles/bash/init.bash                     ~/.bash_profile
    ~/dotfiles/bash/init.bash                     ~/.bashrc
    ~/dotfiles/bash/init.bash                     ~/.profile
  END
  desc  'set git hooksPath to .githooks'
  ok    "[[ $(git -C ~/dotfiles config core.hooksPath) == .githooks ]]"
  cmd   "git -C ~/dotfiles config core.hooksPath .githooks"
  #  +-------------------------------------------------------------+
  #  | PHASE 3a: Package Management (gpoc, nix)                    |
  #  |   +-> [crostini] Install gpoc .deb from GitHub releases     |
  #  |   +-> Install Nix (Determinate installer, hash-verified)    |
  #  |   +-> Fix /nix ownership, write nix.conf, source profile    |
  #  +-------------------------------------------------------------+
  #  | PHASE 3b: Home Manager [crostini/debian]                    |
  #  |   +-> Apply Home Manager configuration (flake)              |
  #  |   +-> Converge task.bash to nix-pinned version              |
  #  +-------------------------------------------------------------+

  if hasGroup "$groupList" gpoc; then
    section gpoc
    aptInstallGpocTask
  fi

  if hasGroup "$groupList" nix; then
    section nix
    installNixTask
    chownRTask /nix "$(id -u)" "$(id -g)"
    writeNixConfTask
    local nixProfile=/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
    [[ -r $nixProfile ]] || { echo "nix profile script not found at $nixProfile" >&2; return 1; }
    loosely source $nixProfile
  fi

  if hasGroup "$groupList" hm; then
    section home-manager
    homeManagerFlakeSwitchTask $Platform
    convergeTaskBash
  fi

  if hasGroup "$groupList" credential; then
    section credential
    try sshAgentPreflight
    try deploySigningPub
    try restoreSecrets
    try agentTomlTask
    section auth-preflight
    try authPreflight
    try runSigningKeyPreflight
  fi

  task.Ln ~/dotfiles/update-env  ~/.local/bin/update-env
  task.Ln ~/dotfiles/scripts/scaffold ~/.local/bin/scaffold
  claudeBaseCopyTask
}

stage1Epilogue() {
  echo
  echo "Stage 1 complete. Working shell with identity."
  echo "Run 'exec bash' to reload your shell."
  echo "Then run 'update-env -2' to clone projects and dev tool repos."
}

stage2Preflight() {
  local missing=()
  command -v nix  &>/dev/null || missing+=("nix")
  command -v git  &>/dev/null || missing+=("git")
  [[ -d ~/dotfiles ]]        || missing+=("~/dotfiles")
  if (( ${#missing[@]} )); then
    echo "Stage 2 requires: ${missing[*]}"
    echo "Run 'update-env -1' first, then 'exec bash'."
    exit 2
  fi
}

credentialPreflight() {
  case $Platform in
    crostini ) ;;
    * )
      echo "Credential setup is only supported on Crostini."
      echo "On this platform ($Platform), credentials are managed separately."
      exit 2
      ;;
  esac
  local missing=()
  [[ -d ~/dotfiles ]]                 || missing+=("~/dotfiles")
  if [[ ! -f $CrostiniDir/hostname ]]; then
    missing+=("hostname (run 'update-env -1 <hostname>' first)")
  else
    local h
    h=$(lib.MachineHostname) || missing+=("hostname (file exists but unreadable)")
    lib.ValidateHostname "${h:-}" 2>/dev/null || missing+=("hostname '${h:-}' is invalid")
  fi
  if (( ${#missing[@]} )); then
    echo "Credential stage requires: ${missing[*]}"
    echo "Run 'update-env -1' first, then 'exec bash'."
    exit 2
  fi
}

# Credential-only stage: runs SSH key, signing key, secrets, agent load,
# and auth preflight without re-running system setup or packages. Useful
# when stage 1 completed phases 1-3 but credentials need interactive
# completion (e.g., interrupted bootstrap, key generation deferred from
# non-interactive run).
credentialStage() {
  section credential
  try sshAgentPreflight
  try deploySigningPub
  try restoreSecrets
  try agentTomlTask
  section auth-preflight
  try authPreflight
  try runSigningKeyPreflight
}

# Stage 2: projects, builds, and config -- all externals try-wrapped
stage2() {
  # Re-run home-manager to converge (idempotent -- no-op if stage 1
  # already applied the same config).
  local groupList
  groupList=$(platformTaskGroups "$Platform")
  if hasGroup "$groupList" hm; then
    section home-manager
    homeManagerFlakeSwitchTask $Platform
    convergeTaskBash
  fi

  #  +-------------------------------------------------------------+
  #  | PHASE 4: Platform-Specific Setup                            |
  #  |   +-> [crostini only]:                                      |
  #  |       * Link ~/crostini -> $CrostiniDir                      |
  #  |       * Clone project directories from permanent mount      |
  #  +-------------------------------------------------------------+
  if [[ $Platform == crostini ]]; then
    section crostini
    task.Ln $CrostiniDir ~/crostini

  fi

  #  +-------------------------------------------------------------+
  #  | PHASE 5 (core): Dev Tool Clones (nix-packaged, cloned for  |
  #  |   development). Tools available via nix after stage 1.      |
  #  |   +-> task.bash         - task automation                   |
  #  |   +-> fp.bash           - functional programming utilities  |
  #  |   +-> mk.bash           - build tool & git updater          |
  #  |   +-> tesht             - testing framework                 |
  #  +-------------------------------------------------------------+

  section task.bash
  try githubCloneAndLinkTask task.bash
  try scaffoldTask ~/projects/task.bash
  try task.Ln ~/projects/task.bash/task.bash ~/.local/bin/task.bash

  section fp.bash
  try githubCloneAndLinkTask fp.bash
  try task.Ln ~/projects/fp.bash/fp.bash ~/.local/bin/fp.bash

  section mk.bash
  try githubCloneAndLinkTask mk.bash
  try scaffoldTask ~/projects/mk.bash
  try task.Ln nix-wrapper ~/projects/mk.bash/bin/node
  try task.Ln nix-wrapper ~/projects/mk.bash/bin/npx
  try task.Ln ~/projects/mk.bash/mk.bash ~/.local/bin/mk.bash
  # mk-example symlink deferred until upstream uses repo-relative sourcing.
  # Nix-packaged mk (patched to store path) is the active command until then.

  section tesht
  try githubCloneAndLinkTask tesht
  try scaffoldTask ~/projects/tesht
  try task.Ln ~/projects/tesht/tesht ~/.local/bin/tesht

  #  +-------------------------------------------------------------+
  #  | PHASE 5 (projects): Additional Tools & Projects             |
  #  |   +-> jeeves            - project guides (bitbucket)        |
  #  |   +-> sofdevsim-2026    - software dev simulation           |
  #  |   +-> blog              - binaryphile.github.io             |
  #  |   +-> tandem-protocol   - Claude slash commands (codeberg)  |
  #  |   +-> era               - semantic memory MCP (codeberg)    |
  #  |       Default branch: main. Cloned and symlinked.           |
  #  +-------------------------------------------------------------+

  section jeeves
  try bitbucketCloneAndLinkTask jeeves
  try scaffoldTask ~/projects/jeeves
  try task.Ln nix-wrapper ~/projects/jeeves/bin/go
  try task.Ln nix-wrapper ~/projects/jeeves/bin/node
  try task.Ln nix-wrapper ~/projects/jeeves/bin/npx

  section sofdevsim-2026
  try githubCloneAndLinkTask sofdevsim-2026
  try scaffoldTask ~/projects/sofdevsim-2026
  try task.Ln nix-wrapper ~/projects/sofdevsim-2026/bin/go
  try task.Ln nix-wrapper ~/projects/sofdevsim-2026/bin/node
  try task.Ln nix-wrapper ~/projects/sofdevsim-2026/bin/npx

  section blog
  try githubCloneAndLinkTask binaryphile.github.io
  try scaffoldTask ~/projects/binaryphile.github.io
  try task.Ln nix-wrapper ~/projects/binaryphile.github.io/bin/ruby
  try task.Ln nix-wrapper ~/projects/binaryphile.github.io/bin/bundler
  try task.Ln nix-wrapper ~/projects/binaryphile.github.io/bin/node
  try task.Ln nix-wrapper ~/projects/binaryphile.github.io/bin/npx

  section tandem-protocol
  try codebergCloneAndLinkTask tandem-protocol
  try scaffoldTask ~/projects/tandem-protocol
  try task.Ln nix-wrapper ~/projects/tandem-protocol/bin/go
  lib.Glob ~/projects/tandem-protocol/commands/* |
    keepIf isFile |
    map path '$path ~/.claude/commands/$(basename $path)' |
    each task.Ln

  section era
  try codebergCloneAndLinkTask era
  try eraScaffoldTask
  try eraBuildTask
  each task.Ln <<'  END'
    ~/projects/era/bin/era           ~/.local/bin/era
    ~/projects/era/bin/era-hook      ~/.local/bin/era-hook
    ~/projects/era/scripts/evtctl                ~/.local/bin/evtctl
    ~/projects/era/scripts/task-audit             ~/.local/bin/task-audit
    ~/projects/era/scripts/validate-attestation   ~/.local/bin/validate-attestation
  END
  try task.Install 644 ~/projects/era/era-mcp.service ~/.config/systemd/user/era-mcp.service
  try eraSystemdEnableTask
  eraMcpRegisterTask
  chromeDevtoolsMcpRegisterTask
  claudeEraConfigTask
  claudeMemoryRedirectsTask

  #  +-------------------------------------------------------------+
  #  | PHASE 5b: Work Projects (VPN-dependent, graceful failure)   |
  #  |   +-> urma-next        - main application (+ MCP)            |
  #  |   +-> pepin            - build/deploy tooling               |
  #  |   +-> cloud-services                                        |
  #  |   +-> accelerated-linux   - DAL (cloned to ~/projects/dal)   |
  #  |   +-> urma-obsidian    - obsidian vault                     |
  #  |   +-> dal-obsidian     - DAL knowledge vault                |
  #  |   +-> share            - cross-team utilities               |
  #  |       All from stash.digi.com, require VPN                  |
  #  +-------------------------------------------------------------+

  section urma
  try stashCloneAndLinkTask urma-next urma
  ProjectDirW=~/projects/urma
  source ~/dotfiles/scripts/scaffold
  try scaffold.MkdirTask ~/projects/urma/bin
  try scaffold.NixWrapperTask
  try scaffold.GitExcludeBinTask
  try urmaEnvrcTask
  try urmaDirenvAllowTask
  try task.Ln nix-wrapper ~/projects/urma/bin/uvx
  try urmaFlakeTask
  try gitExcludeTask ~/projects/urma /obsidian
  try gitExcludeTask ~/projects/urma /flake.nix
  try gitExcludeTask ~/projects/urma /flake.lock
  try writeMcpJsonTask ~/projects/urma

  section pepin
  try stashCloneAndLinkTask pepin
  try scaffoldTask ~/projects/pepin

  section cloud-services
  try stashCloneAndLinkTask cloud-services
  try scaffoldTask ~/projects/cloud-services

  section dal
  try stashCloneAndLinkTask accelerated-linux dal acl
  try scaffoldTask ~/projects/dal
  try gitExcludeTask ~/projects/dal /obsidian

  section urma-obsidian
  try stashCloneAndLinkTask urma-obsidian urma/obsidian ~tlilley

  section dal-obsidian
  try stashCloneAndLinkTask dal-obsidian dal/obsidian ~tlilley

  section share
  try stashCloneAndLinkTask share share ~tlilley

  #  +-------------------------------------------------------------+
  #  | PHASE 6: Applications & VPN                                 |
  #  |   +-> [crostini/linux] GlobalProtect VPN client             |
  #  |   +-> Neovim setup (vim-plug, plugins)                      |
  #  |   +-> Daily notes repository                                |
  #  |   +-> Ranger file manager configs                           |
  #  +-------------------------------------------------------------+

  section neovim
  try task.GitClone https://github.com/binaryphile/dot_vim ~/.config/nvim main
  try git -C ~/.config/nvim remote set-url origin git@github.com:binaryphile/dot_vim.git
  try task.GitUpdate ~/.config/nvim
  curlTask https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim ~/.local/share/nvim/site/autoload/plug.vim
  nvimHeadlessPlugInstallTask
  task.Ln ~/.config/nvim ~/nvim

  section obsidian
  try bitbucketCloneAndLinkTask tlilley-daily-notes

  #  +-------------------------------------------------------------+
  #  | PHASE 7: SSH Key Generation (section unique_credential)     |
  #  |   +-> [crostini/linux] Generate unique SSH key if needed    |
  #  |       * Remove non-passphrase key if it was copied          |
  #  +-------------------------------------------------------------+

}

postInstallMessages() {
  case $Platform in crostini )
    echo
    echo "=== CHROMEOS PROXY SETUP (per-network, one-time) ==="
    echo "ChromeOS Settings > Network > your connection > Proxy > Automatic proxy configuration"
    echo "URL: http://127.0.0.1:8120/proxy.pac"
  ;; esac
}

## task definitions

# system

# aptUpgradeTask upgrades all apt packages to latest.
# Uses DPkg::Lock::Timeout to wait for any held locks (covers all lock
# files: lists, dpkg, dpkg-frontend, archives). Available on Bullseye+.
aptUpgradeTask() {
  desc   'apt-get upgrade'
  prog   on
  runas  root
  unchg  '0 upgraded, 0 newly installed'

  cmd 'DEBIAN_FRONTEND=noninteractive apt-get update -o DPkg::Lock::Timeout=60 -qq && DEBIAN_FRONTEND=noninteractive apt-get upgrade -y -o DPkg::Lock::Timeout=60'
}

# aptInstallGpocTask installs GlobalProtect-openconnect (gpoc) from
# yuezk's GitHub releases. Downloads the .deb and installs with dpkg.
# Crostini-only -- NixOS gets gpoc from nixos-config's flake input.
aptInstallGpocTask() {
  desc   'install globalprotect-openconnect (gpoc)'
  prog   on
  exist  /usr/bin/gpclient

  aptInstallGpoc() {
    local version=2.5.1
    local deb="globalprotect-openconnect_${version}-1_amd64.deb"
    local url="https://github.com/yuezk/GlobalProtect-openconnect/releases/download/v${version}/${deb}"
    local sha256=676fb6480df402884e5097b29a3bcb8856be1943cab04edb7a251518288064a2
    local tmp
    tmp=$(mktemp -d) || { echo "failed to create temp directory" >&2; return 1; }
    $curl -fsSL "$url" -o "$tmp/$deb" || { rm -rf "$tmp"; echo "failed to download gpoc" >&2; return 1; }
    verifySha256 "$sha256" "$tmp/$deb" || {
      rm -rf "$tmp"
      echo "gpoc hash mismatch -- possible tampering" >&2
      return 1
    }
    sudo dpkg -i "$tmp/$deb" || sudo apt-get install -f -y
    rm -rf "$tmp"
  }
  cmd aptInstallGpoc
}

bitbucketCloneAndLinkTask() {
  local repo=$1 branch=${2:-main}
  task.GitClone git@bitbucket.org:accelecon/$repo ~/projects/$repo $branch
  try task.GitUpdate ~/projects/$repo
}

codebergCloneAndLinkTask() {
  local repo=$1 branch=${2:-main}
  task.GitClone https://codeberg.org/binaryphile/$repo ~/projects/$repo $branch
  try git -C ~/projects/"$repo" remote set-url origin "git@codeberg.org:binaryphile/$repo.git"
  try task.GitUpdate ~/projects/$repo
}

scaffoldTask() {
  local dir=$1
  ProjectDirW=$dir
  source ~/dotfiles/scripts/scaffold
  scaffold.MkdirTask $dir/bin
  scaffold.NixWrapperTask
  scaffold.GitExcludeBinTask
  scaffold.EnvrcTask
  scaffold.DirenvAllowTask
}

urmaFlakeTask() {
  local path=~/projects/urma/flake.nix
  desc 'install urma flake.nix'

  urmaFlakeUpToDate() { [[ -f $path ]] && diff -q "$path" <(urmaFlakeContent) >/dev/null 2>&1; }
  ok urmaFlakeUpToDate

  urmaFlakeInstall() { urmaFlakeContent >$path; }
  cmd urmaFlakeInstall
}

urmaFlakeContent() {
  cat << 'EOF'
{
  description = "URMA development environment";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs";
    flake-utils.url = "github:numtide/flake-utils";
  };

  outputs = { self, nixpkgs, flake-utils }:
    flake-utils.lib.eachDefaultSystem (system:
      let
        pkgs = import nixpkgs {
          inherit system;
        };
      in {
        devShells.default = pkgs.mkShell {
          buildInputs = with pkgs; [
            bash
            coreutils
            git
            uv
          ];
        };
      }
    );
}
EOF
}

urmaEnvrcTask() {
  local path=~/projects/urma/.envrc
  desc 'install urma .envrc'

  urmaEnvrcUpToDate() { [[ -f $path ]] && diff -q "$path" <(urmaEnvrcContent) >/dev/null 2>&1; }
  ok urmaEnvrcUpToDate

  urmaEnvrcInstall() { urmaEnvrcContent >$path; }
  cmd urmaEnvrcInstall
}

urmaDirenvAllowTask() {
  local path=~/projects/urma/.envrc
  desc "direnv allow ~/projects/urma"
  check "diff -q '$path' <(urmaEnvrcContent) >/dev/null 2>&1"
  ok "grep -rq '$path' ~/.local/share/direnv/allow/ 2>/dev/null"

  cmd "direnv allow ~/projects/urma"
}

urmaEnvrcContent() {
  cat << 'EOF'
export PROJECT_ROOT=$(cd "$(dirname "$BASH_SOURCE")"; pwd)
export PATH=$PROJECT_ROOT/bin:$PATH

# Atlassian -- Bitbucket Server (stash.digi.com)
# Token loaded from file. MCP atlassian plugin requires env var values.
# with-secret is preferred for one-off commands but direnv needs the value
# for tools that read it from the environment (mcp-atlassian-with-bitbucket).
export BITBUCKET_URL=https://stash.digi.com
export BITBUCKET_USERNAME=tlilley
export BITBUCKET_PERSONAL_TOKEN=$(< ~/secrets/stash.key)

# Atlassian -- Confluence Cloud (onedigi.atlassian.net)
export CONFLUENCE_URL=https://onedigi.atlassian.net/wiki
export CONFLUENCE_USERNAME=tlilley@digi.com
export CONFLUENCE_PERSONAL_TOKEN=$(< ~/secrets/confluence.key)
EOF
}

eraScaffoldTask() {
  scaffoldTask ~/projects/era
  each task.Ln <<'  END'
    nix-wrapper ~/projects/era/bin/go
    nix-wrapper ~/projects/era/bin/node
    nix-wrapper ~/projects/era/bin/npx
  END
}

eraBuildTask() {
  desc  'build era binaries'
  prog  on
  exist ~/projects/era/bin/era

  cmd 'nix develop ~/projects/era --command bash -c "cd ~/projects/era && go generate ./internal/hugot/ && ./mk build"'
}

eraSystemdEnableTask() {
  desc  'enable era-mcp systemd service'
  ok    'systemctl --user is-enabled era-mcp &>/dev/null'
  cmd   'systemctl --user enable --now era-mcp'
}

eraMcpRegisterTask() {
  desc  'register era MCP in claude.json'
  ok    '[[ -f ~/.claude.json ]] && jq -e ".mcpServers.era" ~/.claude.json &>/dev/null'

  eraMcpRegister() {
    local src_=${1:-'{}'}
    [[ -f ~/.claude.json ]] && src_=$(cat ~/.claude.json)
    printf '%s' "$src_" |
      jq '.mcpServers.era = {type: "http", url: "http://127.0.0.1:9310/mcp"}' > ~/.claude.json.tmp &&
      mv ~/.claude.json.tmp ~/.claude.json
  }
  cmd eraMcpRegister
}

chromeDevtoolsMcpRegisterTask() {
  desc  'register chrome-devtools MCP in claude.json'
  ok    '[[ -f ~/.claude.json ]] && jq -e ".mcpServers.\"chrome-devtools\"" ~/.claude.json &>/dev/null'

  chromeDevtoolsMcpRegister() {
    local src_=${1:-'{}'}
    [[ -f ~/.claude.json ]] && src_=$(cat ~/.claude.json)
    printf '%s' "$src_" |
      jq '.mcpServers."chrome-devtools" = {command: "npx", args: ["-y", "chrome-devtools-mcp@latest", "--browser-url", "http://127.0.0.1:9222"]}' > ~/.claude.json.tmp &&
      mv ~/.claude.json.tmp ~/.claude.json
  }
  cmd chromeDevtoolsMcpRegister
}

# agentTomlTask writes ~/.config/1Password/ssh/agent.toml to restrict which
# keys the 1Password SSH agent offers to the current machine. Without this,
# the agent offers ALL vault keys to every server (use-authority expansion).
agentTomlTask() {
  local hostname=${agentToml_hostname:-$(lib.MachineHostname)}
  local path=${agentToml_path:-$HOME/.config/1Password/ssh/agent.toml}
  desc "write 1Password agent.toml for $hostname"

  agentTomlUpToDate() {
