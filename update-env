## credential bootstrap

SshKeyStatus=present
SshStageDir=""  # tracked for signal cleanup

cleanupSshStage() {
  if [[ -n "$SshStageDir" && -d "$SshStageDir" ]]; then
    rm -rf "$SshStageDir"
  fi
  SshStageDir=""
}

# withCleanupTrap CLEANUP FUNC [ARGS...] — call FUNC with INT/TERM trap that
# runs CLEANUP then re-raises the signal (preserving abort semantics).
# Saves and restores previous trap handlers. Does NOT suppress set -e inside
# FUNC — the function runs under normal errexit behavior.
withCleanupTrap() {
  local cleanup=$1 func=$2; shift 2
  local prevInt prevTerm
  prevInt=$(trap -p INT)
  prevTerm=$(trap -p TERM)
  trap "$cleanup; trap - INT; kill -INT \$\$" INT
  trap "$cleanup; trap - TERM; kill -TERM \$\$" TERM
  "$func" "$@"
  local rc=$?
  eval "${prevInt:-trap - INT}"
  eval "${prevTerm:-trap - TERM}"
  return $rc
}

# sshKeyAction — pure decision function for SSH key restore.
#
# Takes a nameref to an associative array with keys:
#   repoHasAge repoHasPub repoFp localExists localFp
#   cacheExists cacheFp hasTty hasAge
# All values are 0/1 (booleans) or strings (fingerprints, "" if absent).
#
# Returns 0 always. Prints exactly one action from this closed set:
#   present | collision | capture_to_repo
#   backup_then_cache | backup_then_age | backup_then_fail
#   restore_from_cache | restore_from_age | generate
#   missing_noninteractive
#   error_age_without_pub | error_pub_without_age | error_malformed_pub
#   error_age_not_found
#
# Decision table (abbreviated, see tests for full coverage):
#   local exists + repo match       → present
#   local exists + repo mismatch    → collision
#   local exists + repo unverifiable → backup_then_{cache|age|fail}
#   local exists + no repo          → capture_to_repo
#   cache valid + repo match/absent → restore_from_cache
#   repo age available + tty + age  → restore_from_age
#   nothing + tty                   → generate
#   nothing + no tty                → missing_noninteractive
sshKeyAction() {
  local -n STATE=$1

  # Pair invariant
  if (( STATE[repoHasAge] && !STATE[repoHasPub] )); then echo error_age_without_pub; return 0; fi
  if (( STATE[repoHasPub] && !STATE[repoHasAge] )); then echo error_pub_without_age; return 0; fi
  if (( STATE[repoHasPub] )) && [[ -z "${STATE[repoFp]}" ]]; then echo error_malformed_pub; return 0; fi

  # Tier 1: local key exists
  if (( STATE[localExists] )); then
    if [[ -n "${STATE[repoFp]}" ]]; then
      if [[ -n "${STATE[localFp]}" && "${STATE[localFp]}" == "${STATE[repoFp]}" ]]; then echo present; return 0; fi
      if [[ -n "${STATE[localFp]}" && "${STATE[localFp]}" != "${STATE[repoFp]}" ]]; then echo collision; return 0; fi
      # localFp empty = unverifiable — backup, then try cache/age/fail
      if (( STATE[cacheExists] )) && [[ -n "${STATE[cacheFp]}" ]]; then
        if [[ -z "${STATE[repoFp]}" || "${STATE[cacheFp]}" == "${STATE[repoFp]}" ]]; then
          echo backup_then_cache; return 0
        fi
      fi
      if (( STATE[repoHasAge] )); then
        if (( !STATE[hasTty] )); then echo missing_noninteractive; return 0; fi
        if (( !STATE[hasAge] )); then echo error_age_not_found; return 0; fi
        echo backup_then_age; return 0
      fi
      echo backup_then_fail; return 0
    else
      echo capture_to_repo; return 0
    fi
  fi

  # Tier 2: mount cache
  if (( STATE[cacheExists] )) && [[ -n "${STATE[cacheFp]}" ]]; then
    if [[ -n "${STATE[repoFp]}" && "${STATE[cacheFp]}" != "${STATE[repoFp]}" ]]; then
      : # stale, fall through
    else
      echo restore_from_cache; return 0
    fi
  fi

  # Tier 3: age decrypt
  if (( STATE[repoHasAge] )); then
    if (( !STATE[hasTty] )); then echo missing_noninteractive; return 0; fi
    if (( !STATE[hasAge] )); then echo error_age_not_found; return 0; fi
    echo restore_from_age; return 0
  fi

  # Tier 4: generate
  if (( !STATE[hasTty] )); then echo missing_noninteractive; return 0; fi
  echo generate; return 0
}

restoreSshKeyImpl() {
  local hostname
  hostname=$(machineHostname)
  validateHostname "$hostname" || return 1

  local repoAge="$HOME/dotfiles/ssh/id_ed25519_${hostname}.age"
  local repoPub="$HOME/dotfiles/ssh/id_ed25519_${hostname}.pub"
  local localKey="$HOME/.ssh/id_ed25519"
  local cacheDir="$CrostiniDir/ssh/$hostname"
  local cacheKey="$cacheDir/id_ed25519"

  mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
  rm -f "$CrostiniDir/np_id_ed25519" "$CrostiniDir/np_id_ed25519.pub"

  # Classify filesystem state into decision inputs
  local -A state=(
    [repoHasAge]=0 [repoHasPub]=0 [repoFp]=""
    [localExists]=0 [localFp]=""
    [cacheExists]=0 [cacheFp]=""
    [hasTty]=0 [hasAge]=0
  )

  [[ -f "$repoAge" ]] && state[repoHasAge]=1
  [[ -f "$repoPub" ]] && state[repoHasPub]=1
  (( state[repoHasPub] )) && state[repoFp]=$(pubFingerprint "$repoPub")
  [[ -f "$localKey" && -s "$localKey" ]] && state[localExists]=1
  (( state[localExists] )) && [[ -f "$localKey.pub" && -s "$localKey.pub" ]] && state[localFp]=$(pubFingerprint "$localKey.pub")
  [[ -f "$cacheKey" && -f "$cacheKey.pub" ]] && state[cacheExists]=1
  (( state[cacheExists] )) && state[cacheFp]=$(pubFingerprint "$cacheKey.pub")
  [[ -t 0 ]] && state[hasTty]=1
  command -v age >/dev/null && state[hasAge]=1

  local action
  action=$(sshKeyAction state)

  # Dispatch — mostly mechanical. capture_to_repo has additional runtime
  # checks (tty, age availability, .pub validity) that determine whether
  # capture is attempted. Capture failure is non-fatal (key is local-only).
  case $action in
    error_*)
      echo "ERROR: ${action#error_}"
      return 1
      ;;

    present)
      # Trust: local .pub fingerprint matches repo .pub. Private key is trusted
      # to match .pub if the pair was produced by ssh-keygen or installKey.
      chmod 600 "$localKey"
      if [[ -d "$CrostiniDir" ]]; then
        mkdir -p "$cacheDir" 2>/dev/null
        installKey "$localKey" "$cacheKey"
      fi 2>/dev/null || true
      SshKeyStatus=present
      return 0
      ;;

    collision)
      echo "ERROR: hostname collision — local (${state[localFp]}) != repo (${state[repoFp]})."
      SshKeyStatus=collision
      return 1
      ;;

    backup_then_cache)
      sshKeyBackupLocal "$localKey" || return 1
      echo "Restoring SSH key from mount cache ($hostname)..."
      if ! installKey "$cacheKey" "$localKey"; then
        echo "ERROR: cache restore failed after backup."
        return 1
      fi
      SshKeyStatus=restored
      return 0
      ;;

    backup_then_age)
      sshKeyBackupLocal "$localKey" || return 1
      sshKeyDecryptAndInstall "$repoAge" "$repoPub" "${state[repoFp]}" "$localKey" "$cacheDir" "$cacheKey"
      return
      ;;

    backup_then_fail)
      sshKeyBackupLocal "$localKey" || return 1
      echo "ERROR: cannot restore key (no cache or age available after backup)."
      return 1
      ;;

    capture_to_repo)
      # Local key usable regardless of capture outcome.
      # Capture is best-effort — requires tty, age, and valid .pub.
      chmod 600 "$localKey"
      if (( state[hasTty] && state[hasAge] )) && [[ -f "$localKey.pub" && -s "$localKey.pub" ]]; then
        local pubFp
        pubFp=$(pubFingerprint "$localKey.pub")
        if [[ -z "$pubFp" ]]; then
          echo "WARNING: local .pub is malformed. Cannot capture to repo."
          echo "  Regenerate with: ssh-keygen -y -f ~/.ssh/id_ed25519 > ~/.ssh/id_ed25519.pub"
        elif ! sshKeyEncryptToRepo "$localKey" "$repoAge" "$repoPub" "$hostname"; then
          echo "WARNING: repo backup failed. Key is local-only — will be lost on wipe."
        fi
      fi
      SshKeyStatus=present
      return 0
      ;;

    restore_from_cache)
      # Trust: cache .pub fingerprint matches repo .pub. Private key trusted
      # to match .pub — pair was installed together by installKey.
      echo "Restoring SSH key from mount cache ($hostname)..."
      if ! installKey "$cacheKey" "$localKey"; then
        echo "ERROR: cache restore failed."
        return 1
      fi
      SshKeyStatus=restored
      ;;

    restore_from_age)
      # Trust: age bundle contains both private + public from same generation.
      # Bundled .pub fingerprint is validated against repo .pub sidecar after
      # decryption — strongest verification path.
      sshKeyDecryptAndInstall "$repoAge" "$repoPub" "${state[repoFp]}" "$localKey" "$cacheDir" "$cacheKey"
      return
      ;;

    generate)
      sshKeyGenerate "$localKey" "$repoAge" "$repoPub" "$hostname" "$cacheDir" "$cacheKey"
      return
      ;;

    missing_noninteractive)
      echo "No SSH key available and no TTY. Run update-env interactively."
      SshKeyStatus=missing_noninteractive
      return 0
      ;;

    *)
      echo "ERROR: unexpected sshKeyAction result: $action"
      return 1
      ;;
  esac
}

# sshKeyBackupLocal — back up local key before overwriting. Returns 1 on failure.
sshKeyBackupLocal() {
  local localKey=$1
  echo "WARNING: local key exists but .pub is missing/invalid. Cannot verify."
  local bakFile
  bakFile=$(mktemp "$localKey.bak.XXXXXX") || { echo "ERROR: cannot create backup"; return 1; }
  echo "  Backing up to $bakFile before restoring from repo."
  if ! cp "$localKey" "$bakFile" || ! chmod 600 "$bakFile"; then
    echo "ERROR: backup failed. Will not overwrite local key."
    return 1
  fi
  [[ -f "$localKey.pub" ]] && cp "$localKey.pub" "$bakFile.pub" 2>/dev/null
  return 0
}

# sshKeyDecryptAndInstall — tier 3 implementation: decrypt .age, validate, install, cache.
sshKeyDecryptAndInstall() {
  local repoAge=$1 repoPub=$2 repoFp=$3 localKey=$4 cacheDir=$5 cacheKey=$6
  echo "Decrypting SSH key..."
  local stageDir
  stageDir=$(mktemp -d "$HOME/.ssh/.stage.XXXXXX"); SshStageDir=$stageDir
  chmod 700 "$stageDir"
  if age --decrypt "$repoAge" | tar xf - -C "$stageDir" && [[ -s "$stageDir/id_ed25519" ]]; then
    local stagedFp
    stagedFp=$(pubFingerprint "$stageDir/id_ed25519.pub")
    if [[ -z "$stagedFp" || "$stagedFp" != "$repoFp" ]]; then
      rm -rf "$stageDir"; SshStageDir=""
      echo "ERROR: decrypted key doesn't match repo .pub. Re-encrypt the key pair."
      return 1
    fi
    if ! installKey "$stageDir/id_ed25519" "$localKey"; then
      rm -rf "$stageDir"; SshStageDir=""
      echo "ERROR: failed to install decrypted key."
      return 1
    fi
    rm -rf "$stageDir"; SshStageDir=""
    if [[ -d "$CrostiniDir" ]]; then
      mkdir -p "$cacheDir" 2>/dev/null
      installKey "$localKey" "$cacheKey"
    fi 2>/dev/null || echo "WARNING: mount cache write failed"
    SshKeyStatus=restored
  else
    rm -rf "$stageDir"; SshStageDir=""
    echo "ERROR: age decryption failed."
    return 1
  fi
}

# sshKeyEncryptToRepo — encrypt local key pair to repo. Preserves prior repo
# state on partial failure. Not atomic (two renames), but best-effort consistent.
sshKeyEncryptToRepo() {
  local localKey=$1 repoAge=$2 repoPub=$3 hostname=$4
  echo "Local key exists but no repo backup for $hostname. Encrypting..."
  mkdir -p "$(dirname "$repoAge")"
  local stageDir agetmp pubtmp bakAge="" bakPub=""
  stageDir=$(mktemp -d "$HOME/.ssh/.stage.XXXXXX"); SshStageDir=$stageDir
  cp "$localKey" "$stageDir/id_ed25519" && chmod 600 "$stageDir/id_ed25519"
  cp "$localKey.pub" "$stageDir/id_ed25519.pub" && chmod 644 "$stageDir/id_ed25519.pub"
  echo "(Repo encryption passphrase)"
  agetmp=$(mktemp "$repoAge.XXXXXX")
  pubtmp=$(mktemp "$repoPub.XXXXXX")
  if tar cf - -C "$stageDir" . | age -p -o "$agetmp" && [[ -s "$agetmp" ]]; then
    cp "$localKey.pub" "$pubtmp" && chmod 644 "$pubtmp" || {
      rm -f "$agetmp" "$pubtmp"; echo "WARNING: .pub staging failed."
      rm -rf "$stageDir"; SshStageDir=""; return 1
    }
    # Back up existing repo files for rollback
    [[ -f "$repoAge" ]] && { bakAge=$(mktemp "$repoAge.bak.XXXXXX") && cp "$repoAge" "$bakAge" || bakAge=""; }
    [[ -f "$repoPub" ]] && { bakPub=$(mktemp "$repoPub.bak.XXXXXX") && cp "$repoPub" "$bakPub" || bakPub=""; }
    # Commit both
    mv "$agetmp" "$repoAge" || {
      rm -f "$agetmp" "$pubtmp" "$bakAge" "$bakPub"
      echo "WARNING: .age commit failed."
      rm -rf "$stageDir"; SshStageDir=""; return 1
    }
    mv "$pubtmp" "$repoPub" || {
      # Restore prior .age if we had one, otherwise remove the new one
      if [[ -n "$bakAge" ]]; then mv "$bakAge" "$repoAge" 2>/dev/null; else rm -f "$repoAge"; fi
      rm -f "$pubtmp" "$bakPub"
      echo "WARNING: .pub commit failed. Rolled back .age."
      rm -rf "$stageDir"; SshStageDir=""; return 1
    }
    rm -f "$bakAge" "$bakPub"
    echo "Backed up. Commit and push ssh/id_ed25519_${hostname}.{age,pub}"
  else
    rm -f "$agetmp" "$pubtmp"
    echo "WARNING: encryption failed. Key not backed up to repo."
    rm -rf "$stageDir"; SshStageDir=""
    return 1
  fi
  rm -rf "$stageDir"; SshStageDir=""
}

# sshKeyGenerate — tier 4 implementation: generate new key, encrypt to repo, cache.
sshKeyGenerate() {
  local localKey=$1 repoAge=$2 repoPub=$3 hostname=$4 cacheDir=$5 cacheKey=$6
  command -v ssh-keygen >/dev/null || { echo "ssh-keygen not found"; return 1; }
  echo "No SSH key for $hostname. Generating..."
  echo "(SSH key passphrase — protects the key on disk)"
  if ! sshKeygenTask "$localKey"; then
    echo "ERROR: key generation failed."
    return 1
  fi
  chmod 644 "$localKey.pub"

  if command -v age >/dev/null; then
    if ! sshKeyEncryptToRepo "$localKey" "$repoAge" "$repoPub" "$hostname"; then
      echo "WARNING: key generated locally but NOT backed up to repo. Will be lost on wipe."
    fi
  fi

  if [[ -d "$CrostiniDir" ]]; then
    mkdir -p "$cacheDir" 2>/dev/null
    installKey "$localKey" "$cacheKey"
  fi 2>/dev/null || echo "WARNING: mount cache write failed"

  SshKeyStatus=generated
}

restoreSshKey() { withCleanupTrap cleanupSshStage restoreSshKeyImpl; }

loadSshKey() {
  [[ -f "$HOME/.ssh/id_ed25519" ]] || return 0
  command -v keychain >/dev/null || { echo "WARNING: keychain not found"; return 0; }
  eval "$(keychain --eval --agents ssh id_ed25519)" || {
    echo "WARNING: keychain failed to load SSH key."
  }
}

authPreflight() {
  local keyFile="$HOME/.ssh/id_ed25519"
  local -a sshopts=(-o BatchMode=yes -o PreferredAuthentications=publickey
    -o IdentitiesOnly=yes -i "$keyFile" -o ConnectTimeout=10
    -o StrictHostKeyChecking=accept-new)

  [[ -f "$keyFile" ]] || { echo "  No SSH key — all private repos will be skipped"; return; }

  local provider rc output
  for provider in github.com codeberg.org bitbucket.org; do
    if output=$(ssh -T "${sshopts[@]}" "git@$provider" 2>&1); then rc=0; else rc=$?; fi
    if (( rc == 0 || rc == 1 )); then
      :
    elif echo "$output" | grep -qi 'permission denied\|publickey'; then
      echo "  $provider: key not registered"
      [[ -f "$keyFile.pub" ]] && echo "    Register: cat $keyFile.pub"
    else
      echo "  $provider: unreachable"
    fi
  done

  if ip link show tun0 >/dev/null 2>&1; then
    if output=$(ssh -T "${sshopts[@]}" git@stash.digi.com 2>&1); then rc=0; else rc=$?; fi
    (( rc == 0 || rc == 1 )) || echo "  stash.digi.com: SSH auth failed"
  fi
}

