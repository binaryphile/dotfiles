    [[ -f $dst ]] && ! [[ -L $dst ]] || return 1
    [[ -f $hashFile ]] || return 1
    [[ "$($sha256sum $src | cut -d' ' -f1)" == "$(< $hashFile)" ]]
  }
  ok claudeSettingsUpToDate

  claudeSettingsCopy() {
    mkdir -p $(dirname $dst)
    local tmp_
    tmp_=$(mktemp) && cp $src $tmp_ && mv -f $tmp_ $dst
    $sha256sum $src | cut -d' ' -f1 >$hashFile
  }
  cmd claudeSettingsCopy
}

