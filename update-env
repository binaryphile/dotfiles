# crostiniHostnameSetup -- verify ChromeOS backing storage, create
# $CrostiniDir, and write hostname file. Fatal on first run without
# hostname arg or without backing storage.
# Reads: $CrostiniBacking (parent of $CrostiniDir), $CrostiniDir, $Hostname.
crostiniHostnameSetup() {
  local backing=${CrostiniBacking:-/mnt/chromeos/MyFiles/Downloads}
  [[ -d $backing ]] || { echo fatal: ChromeOS shared storage not mounted at $backing >&2; echo "Enable file sharing in ChromeOS Settings > Linux" >&2; return 1; }
  mkdir -p $CrostiniDir
  if [[ -n $Hostname ]]; then
    lib.ValidateHostname $Hostname || return 1
    echo $Hostname >$CrostiniDir/hostname
  elif [[ ! -e $CrostiniDir/hostname ]]; then
    echo "fatal: no Crostini hostname configured" >&2
    echo "First run requires: update-env -1 <hostname>" >&2
    return 1
