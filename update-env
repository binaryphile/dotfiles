  nixConfUpToDate() { [[ -f $path ]] && diff -q "$path" <(nixConfContent) >/dev/null 2>&1; }
  ok nixConfUpToDate

  writeNixConf() { nixConfContent >$path; }
  cmd writeNixConf
}

# verifyNixFlakes checks that nix is runnable and flakes are enabled.
