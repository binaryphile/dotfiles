# convergeTaskBash -- after home-manager switch, re-source session vars to
# pick up TASK_BASH_LIB from the new generation, then re-source task.bash
# from the pinned store path. Ensures the rest of this run uses the
# nix-pinned version, not the curl bootstrap.
# Unsets __HM_SESS_VARS_SOURCED first -- hm-session-vars.sh guards against
# double-sourcing, but we need the new generation's values.
# Non-NixOS only (called inside the crostini|debian|linux|macos case block).
convergeTaskBash() {
  local hmVars=$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh
  unset -v __HM_SESS_VARS_SOURCED
  [[ -r $hmVars ]] || { echo fatal: hm-session-vars.sh not found at $hmVars >&2; exit 1; }
  loosely source $hmVars
  if [[ -n ${TASK_BASH_LIB:-} ]]; then
    [[ -r $TASK_BASH_LIB ]] || { echo fatal: TASK_BASH_LIB unreadable after switch: $TASK_BASH_LIB >&2; exit 1; }
    source $TASK_BASH_LIB || { echo "fatal: failed to source converged task.bash: $TASK_BASH_LIB (rc=$?)" >&2; exit 1; }
  fi
}

# resolveSourceDir -- resolve the directory of the calling script, following
# symlink chains. Works when update-env is at ~/.local/bin/update-env.
resolveSourceDir() {
  local src=${BASH_SOURCE[1]:-${BASH_SOURCE[0]}}
  local dir
  while [[ -L $src ]]; do
    dir=$(cd -P -- "$(dirname -- "$src")" 2>/dev/null && pwd) || return 1
    src=$(readlink -- "$src") || return 1
    [[ $src != /* ]] && src=$dir/$src
  done
  cd -P -- "$(dirname -- "$src")" 2>/dev/null && pwd
}

# Shared helpers -- sourced from lib.bash to avoid duplication.
# lib.bash provides: lib.Glob, lib.MachineHostname, lib.ValidateHostname, lib.ValidSecretName
