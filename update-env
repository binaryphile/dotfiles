removeMatchingFileTask() {
  local targetFilename=$1 matchFilename=$2
  desc  "remove file $targetFilename if it matches $matchFilename"

  ifFilesDontMatch() {
    [[ -e $matchFilename ]] && ! [[ -e $targetFilename ]] ||
      [[ $(<$targetFilename) != $(<$matchFilename) ]]
  }
  ok ifFilesDontMatch

  rmTargetIfMatches() {
    if [[ -e $matchFilename && -e $targetFilename ]] &&
      [[ $(<$targetFilename) == $(<$matchFilename) ]];
    then
      rm $targetFilename
    fi
  }
  cmd rmTargetIfMatches
}

sshKeygenTask() {
  local keyFilename=$1
  desc  'generate an ssh key'
  exist $keyFilename
  prog  on

  generateKey() {
    local passphrase passphrase2
    read -sp 'generating ssh key.  passphrase: ' passphrase
    [[ -n $passphrase ]] || { echo "${NL}passphrase required"; return 1; }
    read -sp "${NL}again: " passphrase2
    [[ $passphrase == $passphrase2 ]] || { echo "${NL}passphrase did not match"; return 1; }
    echo
    ssh-keygen -t ed25519 -f "$keyFilename" -N "$passphrase" -C "$USER@$(machineHostname)"
    cat "$keyFilename.pub"
  }
  cmd generateKey
}

## credential bootstrap

SshKeyStatus=present
SshStageDir=""  # tracked for signal cleanup

cleanupSshStage() {
  if [[ -n "$SshStageDir" && -d "$SshStageDir" ]]; then
    rm -rf "$SshStageDir"
  fi
  SshStageDir=""
}

# withCleanupTrap CLEANUP FUNC [ARGS...] — call FUNC with INT/TERM trap that
# runs CLEANUP then re-raises the signal (preserving abort semantics).
# Saves and restores previous trap handlers. Does NOT suppress set -e inside
# FUNC — the function runs under normal errexit behavior.
withCleanupTrap() {
  local cleanup=$1 func=$2; shift 2
  local prevInt prevTerm
  prevInt=$(trap -p INT)
  prevTerm=$(trap -p TERM)
  trap "$cleanup; trap - INT; kill -INT \$\$" INT
  trap "$cleanup; trap - TERM; kill -TERM \$\$" TERM
  "$func" "$@"
  local rc=$?
  eval "${prevInt:-trap - INT}"
  eval "${prevTerm:-trap - TERM}"
  return $rc
}

restoreSshKeyImpl() {
  local hostname
  hostname=$(machineHostname)
  validateHostname "$hostname" || return 1

  local repoAge="$HOME/dotfiles/ssh/id_ed25519_${hostname}.age"
  local repoPub="$HOME/dotfiles/ssh/id_ed25519_${hostname}.pub"
  local localKey="$HOME/.ssh/id_ed25519"
  local cacheDir="$CrostiniDir/ssh/$hostname"
  local cacheKey="$cacheDir/id_ed25519"

  mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
  rm -f "$CrostiniDir/np_id_ed25519" "$CrostiniDir/np_id_ed25519.pub"

  # Pair invariant: both or neither in repo
  if [[ -f "$repoAge" && ! -f "$repoPub" ]]; then
    echo "ERROR: repo has .age but no .pub for $hostname."; return 1
  fi
  if [[ -f "$repoPub" && ! -f "$repoAge" ]]; then
    echo "ERROR: repo has .pub but no .age for $hostname."; return 1
  fi

  local repoFp=""
  if [[ -f "$repoPub" ]]; then
    repoFp=$(pubFingerprint "$repoPub")
    [[ -n "$repoFp" ]] || { echo "ERROR: repo .pub is malformed: $repoPub"; return 1; }
  fi

  # Tier 1: local key exists
  if [[ -f "$localKey" && -s "$localKey" ]]; then
    local localFp=""
    [[ -f "$localKey.pub" && -s "$localKey.pub" ]] && localFp=$(pubFingerprint "$localKey.pub")

    if [[ -n "$repoFp" ]]; then
      if [[ -n "$localFp" && "$localFp" == "$repoFp" ]]; then
        chmod 600 "$localKey"
        if [[ -d "$CrostiniDir" ]]; then
          mkdir -p "$cacheDir" 2>/dev/null
          installKey "$localKey" "$cacheKey"
        fi 2>/dev/null || true
        SshKeyStatus=present
        return
      elif [[ -n "$localFp" && "$localFp" != "$repoFp" ]]; then
        echo "ERROR: hostname collision — local ($localFp) != repo ($repoFp)."
        SshKeyStatus=collision
        return 1
      else
        echo "WARNING: local key exists but .pub is missing/invalid. Cannot verify."
        local bakFile
        bakFile=$(mktemp "$localKey.bak.XXXXXX") || { echo "ERROR: cannot create backup"; SshKeyStatus=present; return 1; }
        echo "  Backing up to $bakFile before restoring from repo."
        if ! cp "$localKey" "$bakFile" || ! chmod 600 "$bakFile"; then
          echo "ERROR: backup failed. Will not overwrite local key."
          SshKeyStatus=present
          return 1
        fi
        [[ -f "$localKey.pub" ]] && cp "$localKey.pub" "$bakFile.pub" 2>/dev/null
        # Fall through to tier 2/3
      fi
    else
      # No repo pair — local key not backed up yet
      chmod 600 "$localKey"
      if [[ -t 0 ]] && command -v age >/dev/null && [[ -f "$localKey.pub" && -s "$localKey.pub" ]]; then
        local pubFp
        pubFp=$(pubFingerprint "$localKey.pub")
        if [[ -z "$pubFp" ]]; then
          echo "WARNING: local .pub is malformed. Cannot capture to repo."
          echo "  Regenerate with: ssh-keygen -y -f ~/.ssh/id_ed25519 > ~/.ssh/id_ed25519.pub"
        else
          echo "Local key exists but no repo backup for $hostname. Encrypting..."
          mkdir -p "$(dirname "$repoAge")"
          local agetmp stageDir
          stageDir=$(mktemp -d "$HOME/.ssh/.stage.XXXXXX"); SshStageDir=$stageDir
          cp "$localKey" "$stageDir/id_ed25519" && chmod 600 "$stageDir/id_ed25519"
          cp "$localKey.pub" "$stageDir/id_ed25519.pub" && chmod 644 "$stageDir/id_ed25519.pub"
          echo "(Repo encryption passphrase)"
          agetmp=$(mktemp "$repoAge.XXXXXX")
          if tar cf - -C "$stageDir" . | age -p -o "$agetmp" && [[ -s "$agetmp" ]]; then
            mv "$agetmp" "$repoAge"
            cp "$localKey.pub" "$repoPub"
            echo "Backed up. Commit and push ssh/id_ed25519_${hostname}.{age,pub}"
          else
            rm -f "$agetmp"
            echo "WARNING: encryption failed. Key not backed up to repo."
          fi
          rm -rf "$stageDir"; SshStageDir=""
        fi
      fi
      SshKeyStatus=present
      return
    fi
  fi

  # Tier 2: mount cache (namespaced by hostname)
  if [[ -f "$cacheKey" && -f "$cacheKey.pub" ]]; then
    local cacheFp
    cacheFp=$(pubFingerprint "$cacheKey.pub")
    if [[ -n "$cacheFp" ]]; then
      if [[ -n "$repoFp" && "$cacheFp" != "$repoFp" ]]; then
        echo "Mount cache stale. Falling through to age decrypt."
      else
        echo "Restoring SSH key from mount cache ($hostname)..."
        if ! installKey "$cacheKey" "$localKey"; then
          echo "WARNING: cache restore failed. Falling through to age decrypt."
        else
          SshKeyStatus=restored
          return
        fi
      fi
    fi
  fi

  # Tier 3: age decrypt (powerwash recovery)
  if [[ -f "$repoAge" ]]; then
    if [[ ! -t 0 ]]; then
      echo "SSH key encrypted in repo but no TTY."
      SshKeyStatus=missing_noninteractive
      return 0
    fi
    command -v age >/dev/null || { echo "age not found"; return 1; }
    echo "Decrypting SSH key for $hostname..."
    local stageDir
    stageDir=$(mktemp -d "$HOME/.ssh/.stage.XXXXXX"); SshStageDir=$stageDir
    chmod 700 "$stageDir"
    if age --decrypt "$repoAge" | tar xf - -C "$stageDir" && [[ -s "$stageDir/id_ed25519" ]]; then
      local stagedFp
      stagedFp=$(pubFingerprint "$stageDir/id_ed25519.pub")
      if [[ -z "$stagedFp" || "$stagedFp" != "$repoFp" ]]; then
        rm -rf "$stageDir"; SshStageDir=""
        echo "ERROR: decrypted key doesn't match repo .pub. Re-encrypt the key pair."
        return 1
      fi
      if ! installKey "$stageDir/id_ed25519" "$localKey"; then
        rm -rf "$stageDir"; SshStageDir=""
        echo "ERROR: failed to install decrypted key."
        return 1
      fi
      rm -rf "$stageDir"; SshStageDir=""
      if [[ -d "$CrostiniDir" ]]; then
        mkdir -p "$cacheDir" 2>/dev/null
        installKey "$localKey" "$cacheKey"
      fi 2>/dev/null || echo "WARNING: mount cache write failed"
      SshKeyStatus=restored
    else
      rm -rf "$stageDir"; SshStageDir=""
      echo "ERROR: age decryption failed."
      return 1
    fi
    return
  fi

  # Tier 4: generate (first-time machine)
  if [[ ! -t 0 ]]; then
    echo "No SSH key for $hostname and no TTY."
    SshKeyStatus=missing_noninteractive
    return 0
  fi
  command -v ssh-keygen >/dev/null || { echo "ssh-keygen not found"; return 1; }
  echo "No SSH key for $hostname. Generating..."
  echo "(SSH key passphrase — protects the key on disk)"
  if ! sshKeygenTask "$localKey"; then
    SshKeyStatus=missing_noninteractive
    return 1
  fi
  chmod 644 "$localKey.pub"

  mkdir -p "$(dirname "$repoAge")"
  if command -v age >/dev/null; then
    echo "(Repo encryption passphrase — protects the key in git)"
    local stageDir agetmp
    stageDir=$(mktemp -d "$HOME/.ssh/.stage.XXXXXX"); SshStageDir=$stageDir
    cp "$localKey" "$stageDir/id_ed25519" && chmod 600 "$stageDir/id_ed25519"
    cp "$localKey.pub" "$stageDir/id_ed25519.pub" && chmod 644 "$stageDir/id_ed25519.pub"
    agetmp=$(mktemp "$repoAge.XXXXXX")
    if tar cf - -C "$stageDir" . | age -p -o "$agetmp" && [[ -s "$agetmp" ]]; then
      mv "$agetmp" "$repoAge"
      cp "$localKey.pub" "$repoPub"
      echo "Key encrypted. Commit and push ssh/id_ed25519_${hostname}.{age,pub}"
    else
      rm -f "$agetmp"
      echo "WARNING: encryption failed. Key NOT in repo. Will be LOST on wipe."
    fi
    rm -rf "$stageDir"; SshStageDir=""
  fi

  if [[ -d "$CrostiniDir" ]]; then
    mkdir -p "$cacheDir" 2>/dev/null
    installKey "$localKey" "$cacheKey"
  fi 2>/dev/null || echo "WARNING: mount cache write failed"

  SshKeyStatus=generated
}

restoreSshKey() { withCleanupTrap cleanupSshStage restoreSshKeyImpl; }

loadSshKey() {
  [[ -f "$HOME/.ssh/id_ed25519" ]] || return 0
  command -v keychain >/dev/null || { echo "WARNING: keychain not found"; return 0; }
  eval "$(keychain --eval --agents ssh id_ed25519)" || {
    echo "WARNING: keychain failed to load SSH key."
  }
}

authPreflight() {
  local keyFile="$HOME/.ssh/id_ed25519"
  local -a sshopts=(-o BatchMode=yes -o PreferredAuthentications=publickey
    -o IdentitiesOnly=yes -i "$keyFile" -o ConnectTimeout=10
    -o StrictHostKeyChecking=accept-new)

  [[ -f "$keyFile" ]] || { echo "  No SSH key — all private repos will be skipped"; return; }

  local provider rc output
  for provider in github.com codeberg.org bitbucket.org; do
    if output=$(ssh -T "${sshopts[@]}" "git@$provider" 2>&1); then rc=0; else rc=$?; fi
    if (( rc == 0 || rc == 1 )); then
      :
    elif echo "$output" | grep -qi 'permission denied\|publickey'; then
      echo "  $provider: key not registered"
      [[ -f "$keyFile.pub" ]] && echo "    Register: cat $keyFile.pub"
    else
      echo "  $provider: unreachable"
    fi
  done

  if ip link show tun0 >/dev/null 2>&1; then
    if output=$(ssh -T "${sshopts[@]}" git@stash.digi.com 2>&1); then rc=0; else rc=$?; fi
    (( rc == 0 || rc == 1 )) || echo "  stash.digi.com: SSH auth failed"
  fi
}

## helpers

fatal() {
  local msg=$1 rc=${2:-$?}
  echo "fatal: $msg"
  exit $rc
}

glob() {
  local nullglobWasOn=0 noglobWasOn=1
  [[ $(shopt nullglob) == *on ]] && nullglobWasOn=1 || shopt -s nullglob  # enable nullglob
  [[ $- != *f* ]] && noglobWasOn=0 || set +o noglob                       # disable noglob

  eval "local results=( $* )"

  # reset to old settings
  (( noglobWasOn )) && set -o noglob
  (( nullglobWasOn )) || shopt -u nullglob

  local IFS=$NL
  (( ${#results[*]} == 0 )) || echo "${results[*]}"
}

machineHostname() {
  if [[ "${HOSTNAME:-}" == penguin && -e "$CrostiniDir/hostname" ]]; then
    cat -- "$CrostiniDir/hostname"
    return
  fi
  echo "${HOSTNAME:-}"
}

validateHostname() {
  local h=$1
  [[ $h != penguin ]] || { echo "ERROR: hostname is 'penguin'. Set \$CrostiniDir/hostname."; return 1; }
  [[ $h =~ ^[a-z0-9][a-z0-9-]*$ ]] || { echo "ERROR: invalid hostname '$h'. Must be [a-z0-9][a-z0-9-]*."; return 1; }
}

pubFingerprint() {
  [[ -f "$1" && -s "$1" ]] || return 0
  ssh-keygen -lf "$1" 2>/dev/null | awk '{print $2}'
}

installKey() {
  local src=$1 dst=$2 tmpPriv tmpPub=""

  # Stage private key
  tmpPriv=$(mktemp "$dst.XXXXXX")       || return 1
  cp "$src" "$tmpPriv"                  || { rm -f "$tmpPriv"; return 1; }
  chmod 600 "$tmpPriv"                  || { rm -f "$tmpPriv"; return 1; }

  # Stage .pub if present
  if [[ -f "$src.pub" ]]; then
    tmpPub=$(mktemp "$dst.pub.XXXXXX")  || { rm -f "$tmpPriv"; return 1; }
    cp "$src.pub" "$tmpPub"             || { rm -f "$tmpPriv" "$tmpPub"; return 1; }
    chmod 644 "$tmpPub"                 || { rm -f "$tmpPriv" "$tmpPub"; return 1; }
  fi

  # Commit: per-file rename is atomic, but the pair is not — if .pub mv fails
  # after private mv succeeds, roll back the private key to restore consistency.
  mv "$tmpPriv" "$dst"                  || { rm -f "$tmpPriv" "$tmpPub"; return 1; }
  if [[ -n "$tmpPub" ]]; then
    mv "$tmpPub" "$dst.pub"             || { rm -f "$tmpPub" "$dst"; return 1; }
  fi
}

isDir() { [[ -d "$1" ]]; }

isFile() { [[ -f "$1" ]]; }

loosely() {
  set +euo pipefail
  "$@"
  set -euo pipefail
}

ownerAndGroup() {
  local path=$1
  [[ $OSTYPE == darwin* && $(type -p stat) == /usr/bin/stat ]] && local flag=f || local flag=c
  echo $(stat -$flag %u $path):$(stat -$flag %g $path)
}

platform() {
  [[ $OSTYPE != darwin* ]] || { echo macos; return; }
  [[ $HOSTNAME != penguin ]] || { echo crostini; return; }
  if [[ -e /etc/NIXOS ]]; then
    [[ ! -d ~/dotfiles/contexts/$HOSTNAME ]] || { echo "$HOSTNAME"; return; }
    echo nixos; return
  fi
  ! [[ -e /etc/debian_version ]] || { echo debian; return; }
  echo linux
}


## fp

# each applies its arguments as a command to each argument from stdin.
# stream prints each argument on its own line.
stream() { printf '%s\n' "$@"; }

each() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg"
  done
}

# keepIf filters lines from stdin using command.
keepIf() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg" && echo "$arg"
  done
  return 0
}

# map returns $EXPRESSION evaluated with the value of stdin as $VARNAME.
# $EXPRESSION must respect double-quoting rules and so can't contain naked quotes.
# $VARNAME may not be "VARNAME" or "EXPRESSION".
map() {
  local VARNAME=$1 EXPRESSION=$2
  case $VARNAME in VARNAME|EXPRESSION ) fatal "map: VARNAME may not be 'VARNAME' or 'EXPRESSION'";; esac
  local "$VARNAME"
  while IFS='' read -r "$VARNAME"; do
    eval "echo \"$EXPRESSION\""
  done
}

