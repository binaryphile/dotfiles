  source $TASK_BASH_LIB || { echo "fatal: failed to source $TASK_BASH_LIB (rc=$?)" >&2; exit 1; }
else
  TaskTmp=$(mktemp) || { echo "fatal: cannot create temp file" >&2; exit 1; }
  $curl -fsSL "https://raw.githubusercontent.com/binaryphile/task.bash/$TaskBashBootstrapRev/task.bash" >$TaskTmp ||
    { rm -f $TaskTmp; echo "fatal: task.bash bootstrap fetch failed" >&2; exit 1; }
  verifySha256 $TaskBashBootstrapSha256 $TaskTmp ||
    { rm -f $TaskTmp; echo "fatal: task.bash hash mismatch -- possible tampering" >&2; exit 1; }
  source $TaskTmp && Rc=$? || Rc=$?
  rm -f $TaskTmp
  unset -v TaskTmp
  (( Rc == 0 )) || { echo "fatal: failed to source bootstrap task.bash (rc=$Rc)" >&2; exit 1; }
  unset -v Rc
fi
unset -v TaskBashBootstrapRev TaskBashBootstrapSha256

return 2>/dev/null  # stop here if sourced, for interactive debugging

IsShortRun=0
IsStrictPreflight=0
Stage=all
OriginalArgs_=("$@")    # captured before parsing for self-update re-exec

# parse options
while [[ ${1:-} == -?* ]]; do
  case $1 in
    -h|--help   ) usageText; exit 0;;
    -x|--trace  ) set -x;;

    -s|--short )
      task.SetShortRun on
      IsShortRun=1
      ;;

    --strict ) IsStrictPreflight=1;;

    -1|--stage1     ) Stage=1;;
    -2|--stage2     ) Stage=2;;
    -c|--credential ) Stage=credential;;

    -- ) shift; break;;
  esac
  shift
done

Hostname=
if [[ $Stage == 1 && -n ${1:-} ]]; then
  Hostname=$1
  shift
fi
(( $# == 0 )) || { echo "fatal: unexpected argument: $1" >&2; exit 1; }

main
