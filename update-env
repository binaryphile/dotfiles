# restoreSecrets -- two-tier restore for per-machine secrets.
# Secrets are flat files in ~/secrets/. Backed up to 1Password, not the repo.
# Restore: local -> mount cache -> manual from 1Password.
restoreSecrets() {
  local hostname
  hostname=$(lib.MachineHostname)
  lib.ValidateHostname $hostname || return 1
  local secretsDir="$HOME/secrets"
  local cacheDir="$CrostiniDir/secrets/$hostname"

  mkdirp $secretsDir && chmod 700 $secretsDir

  # Tier 1: local secrets exist
  if [[ -n $(lib.Glob $secretsDir/*) ]]; then
    return 0
  fi

  # Tier 2: mount cache (namespaced by hostname)
  if [[ -d $cacheDir ]] && [[ -n $(lib.Glob $cacheDir/*) ]]; then
    echo "Restoring secrets from mount cache ($hostname)..."
    local stageDir
    stageDir=$(mktemp -d "$secretsDir.stage.XXXXXX")
    chmod 700 "$stageDir"
    if cp $cacheDir/* "$stageDir"/ 2>/dev/null; then
      chmod 600 "$stageDir"/* 2>/dev/null
      mv "$stageDir"/* $secretsDir/ 2>/dev/null
      rmdir "$stageDir" 2>/dev/null
      return 0
    fi
    rm -rf "$stageDir"
    echo "WARNING: cache restore failed." >&2
  fi

  echo No secrets for $hostname. Create ~/secrets/ files and store in 1Password.
  return 0
}

sshAgentPreflight() {
  desc '1Password SSH agent available'
  ok "[[ -S $HOME/.1password/agent.sock ]]"

  sshAgentCheck() {
    if ! SSH_AUTH_SOCK=~/.1password/agent.sock $ssh_add -l >/dev/null 2>&1; then
      echo "ERROR: 1Password SSH agent unavailable or vault locked." >&2
      echo "Start 1Password and unlock your vault, then re-run." >&2
      return 1
    fi
  }
  cmd sshAgentCheck
}

# deploySigningPub -- copy the signing key .pub sidecar from the repo to
# ~/.ssh/id_ed25519_signing.pub. This is all op-ssh-sign needs to identify
# which 1Password vault key to use for commit signing. No private key on disk.
#
# Source prefers the hostname-keyed sidecar (id_ed25519_signing_<hostname>.pub)
# if it exists, falling back to the unscoped sidecar for legacy hosts that
# haven't migrated to per-machine signing keys yet. Hostname-keyed lookup
# matches opSigningKeyItem's per-host case-branch pattern.
deploySigningPub() {
  local repoPub=${signingPub_src:-}
  if [[ -z $repoPub ]]; then
    local hostname
    hostname=$(lib.MachineHostname 2>/dev/null) || hostname=
    if [[ -n $hostname && -f $HOME/dotfiles/ssh/id_ed25519_signing_${hostname}.pub ]]; then
      repoPub=$HOME/dotfiles/ssh/id_ed25519_signing_${hostname}.pub
    else
      repoPub=$HOME/dotfiles/ssh/id_ed25519_signing.pub
    fi
  fi
  local dst=${signingPub_dst:-$HOME/.ssh/id_ed25519_signing.pub}

  [[ -f $repoPub ]] || { echo "No signing key .pub sidecar in repo"; return 0; }

  desc "deploy signing key .pub"

  signingPubUpToDate() {
    [[ -f $dst ]] && diff -q $dst $repoPub >/dev/null 2>&1
  }
  ok signingPubUpToDate

  signingPubCopy() {
    mkdir -p $(dirname $dst)
    cp $repoPub $dst
    chmod 644 $dst
  }
  cmd signingPubCopy
}

# runSigningKeyPreflight -- checks that the signing .pub is deployed and
# the key is available in the 1Password agent. Warns if not.
runSigningKeyPreflight() {
  local pubFile=$HOME/.ssh/id_ed25519_signing.pub

  if [[ ! -f $pubFile ]]; then
    echo "WARNING: signing key .pub not deployed to $pubFile"
    echo "  Commit signing will fail. Check repo sidecar and re-run update-env."
    return
  fi

  local pubFp
  pubFp=$($ssh_keygen -lf $pubFile 2>/dev/null | awk '{print $2}')
  if [[ -z $pubFp ]]; then
    echo "WARNING: signing key .pub at $pubFile is unreadable"
    return
  fi

  if ! SSH_AUTH_SOCK=~/.1password/agent.sock $ssh_add -l 2>/dev/null | grep -qF $pubFp; then
    echo "WARNING: signing key not in 1Password agent"
    echo "  Unlock 1Password to enable commit signing."
  fi
}

authPreflight() {
  local keyFile=$HOME/.ssh/id_ed25519
  local -a sshopts=(-o BatchMode=yes -o PreferredAuthentications=publickey
    -o IdentitiesOnly=yes -i "$keyFile" -o ConnectTimeout=10
    -o StrictHostKeyChecking=accept-new)

  [[ -f $keyFile ]] || { echo "  No SSH key -- all private repos will be skipped"; return; }

  # Guard: check that THIS key is in the agent before testing registries.
  # BatchMode SSH fails identically whether the key was rejected by the
  # registry or never offered -- without this guard, a missing or wrong
  # key produces misleading "key not registered" for all providers.
  local keyFp
  keyFp=$($ssh_keygen -lf "$keyFile.pub" 2>/dev/null | awk '{print $2}')
  if [[ -z $keyFp ]] || ! $ssh_add -l 2>/dev/null | grep -qF $keyFp; then
    echo "  key not in agent -- run 'ssh-add ~/.ssh/id_ed25519' after exec bash"
    return
  fi

  checkProvider() {
    local provider=$1 rc output_
    if output_=$($ssh -T "${sshopts[@]}" "git@$provider" 2>&1); then rc=0; else rc=$?; fi
    if (( rc == 0 || rc == 1 )); then
      :
    elif echo "$output_" | grep -qi 'permission denied\|publickey'; then
      echo "  $provider: key not registered"
      [[ -f $keyFile.pub ]] && echo "    Register: cat $keyFile.pub"
    else
      echo "  $provider: unreachable"
    fi
  }
  each checkProvider <<'  END'
    github.com
    codeberg.org
    bitbucket.org
  END

  if $ip link show tun0 >/dev/null 2>&1; then
    local rc output_
    if output_=$($ssh -T "${sshopts[@]}" git@stash.digi.com 2>&1); then rc=0; else rc=$?; fi
    (( rc == 0 || rc == 1 )) || echo "  stash.digi.com: SSH auth failed"
  fi
}

