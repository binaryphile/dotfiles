}

validateHostname() {
  local h=$1
  [[ $h != penguin ]] || { echo "ERROR: hostname is 'penguin'. Set \$CrostiniDir/hostname."; return 1; }
  [[ $h =~ ^[a-z0-9][a-z0-9-]*$ ]] || { echo "ERROR: invalid hostname '$h'. Must be [a-z0-9][a-z0-9-]*."; return 1; }
}

pubFingerprint() {
  [[ -f "$1" && -s "$1" ]] || return 0
  ssh-keygen -lf "$1" 2>/dev/null | awk '{print $2}'
}

# installKey SRC DST — install key pair from SRC to DST.
# Contract: destination reflects source pair state exactly.
# If source has .pub, destination gets it. If not, stale dst.pub is removed.
# On partial failure, prior destination state is restored (best-effort).
# Private key trust model: we trust .pub matches private key if they were
# produced together by ssh-keygen or extracted from the same age bundle.
# Manual .pub replacement is unsupported. See design docs.
installKey() {
  local src=$1 dst=$2 tmpPriv tmpPub="" bakPriv=""

  # Stage new private key
  tmpPriv=$(mktemp "$dst.XXXXXX")       || return 1
  cp "$src" "$tmpPriv"                  || { rm -f "$tmpPriv"; return 1; }
  chmod 600 "$tmpPriv"                  || { rm -f "$tmpPriv"; return 1; }

  # Stage new .pub if source has one
  if [[ -f "$src.pub" ]]; then
    tmpPub=$(mktemp "$dst.pub.XXXXXX")  || { rm -f "$tmpPriv"; return 1; }
    cp "$src.pub" "$tmpPub"             || { rm -f "$tmpPriv" "$tmpPub"; return 1; }
    chmod 644 "$tmpPub"                 || { rm -f "$tmpPriv" "$tmpPub"; return 1; }
  fi

  # Back up existing private key for rollback
  if [[ -f "$dst" ]]; then
    bakPriv=$(mktemp "$dst.rollback.XXXXXX") && cp "$dst" "$bakPriv" || bakPriv=""
  fi

  # Commit private key
  mv "$tmpPriv" "$dst" || {
    rm -f "$tmpPriv" "$tmpPub" "$bakPriv"
    return 1
  }

  # Commit .pub — rollback private on failure
  if [[ -n "$tmpPub" ]]; then
    if ! mv "$tmpPub" "$dst.pub"; then
      # Restore prior private key or remove new one
      if [[ -n "$bakPriv" ]]; then
        mv "$bakPriv" "$dst" 2>/dev/null || rm -f "$dst"
      else
        rm -f "$dst"
      fi
      rm -f "$tmpPub" "$bakPriv"
      return 1
    fi
  elif [[ -f "$dst.pub" && ! -f "$src.pub" ]]; then
    # Source has no .pub — remove stale dst.pub for pair consistency
    if ! rm -f "$dst.pub"; then
      # Can't remove stale .pub — rollback private key
      if [[ -n "$bakPriv" ]]; then
        mv "$bakPriv" "$dst" 2>/dev/null || rm -f "$dst"
      else
        rm -f "$dst"
      fi
      rm -f "$bakPriv"
      return 1
    fi
  fi

  # Success — clean up rollback backup
  rm -f "$bakPriv"
  return 0
}

isDir() { [[ -d "$1" ]]; }

isFile() { [[ -f "$1" ]]; }

loosely() {
  set +euo pipefail
  "$@"
  set -euo pipefail
}

ownerAndGroup() {
  local path=$1
  [[ $OSTYPE == darwin* && $(type -p stat) == /usr/bin/stat ]] && local flag=f || local flag=c
  echo $(stat -$flag %u $path):$(stat -$flag %g $path)
}

platform() {
  [[ $OSTYPE != darwin* ]] || { echo macos; return; }
  [[ $HOSTNAME != penguin ]] || { echo crostini; return; }
  if [[ -e /etc/NIXOS ]]; then
    [[ ! -d ~/dotfiles/contexts/$HOSTNAME ]] || { echo "$HOSTNAME"; return; }
    echo nixos; return
  fi
  ! [[ -e /etc/debian_version ]] || { echo debian; return; }
  echo linux
}


## fp

# each applies its arguments as a command to each argument from stdin.
# stream prints each argument on its own line.
stream() { printf '%s\n' "$@"; }

each() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg"
  done
}

# keepIf filters lines from stdin using command.
keepIf() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg" && echo "$arg"
  done
  return 0
}

# map returns $EXPRESSION evaluated with the value of stdin as $VARNAME.
# $EXPRESSION must respect double-quoting rules and so can't contain naked quotes.
# $VARNAME may not be "VARNAME" or "EXPRESSION".
map() {
  local VARNAME=$1 EXPRESSION=$2
  case $VARNAME in VARNAME|EXPRESSION ) fatal "map: VARNAME may not be 'VARNAME' or 'EXPRESSION'";; esac
  local "$VARNAME"
  while IFS='' read -r "$VARNAME"; do
    eval "echo \"$EXPRESSION\""
  done
}

## globals

NL=$'\n'

## boilerplate

Here=$(cd "$(dirname "$BASH_SOURCE")"; cd -P "$(dirname "$(readlink "$BASH_SOURCE" || echo .)")"; pwd)
if [[ -e "$Here"/task.bash ]]; then
  source "$Here"/task.bash
else
  Lib=$(curl -fsSL https://raw.githubusercontent.com/binaryphile/task.bash/main/task.bash) || exit
  eval "$Lib"
fi
unset -v Here Lib

return 2>/dev/null  # stop here if sourced, for interactive debugging

IsShortRun=0
Stage=all

# parse options
while [[ ${1:-} == -?* ]]; do
  case $1 in
    -h|--help   ) [[ -v Usage_ ]] && echo "$Usage_"; exit;;
    -x|--trace  ) set -x;;

    -s|--short )
      task.SetShortRun on
      IsShortRun=1
      ;;

    -1|--stage1 ) Stage=1;;
    -2|--stage2 ) Stage=2;;

    -- ) shift; break;;
  esac
  shift
done

main
