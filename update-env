# claudeMemoryRedirectsTask installs per-project MEMORY.md files that point
# Claude Code's auto-memory to Era. One file per project.
claudeMemoryRedirectsTask() {
  local redirectSrc=${claudeRedirects_src:-$HOME/dotfiles/claude/era-memory-redirect.md}
  local memBase=${claudeRedirects_memBase:-$HOME/.claude/projects}
  desc 'install era memory redirects for all projects'
  check "[[ -f $redirectSrc ]]"

  # Project dirs covered by the redirect. Single source of truth shared
  # by the up-to-date check and the install command -- adding a project
  # means adding one line here.
  memoryProjectDirs() {
    echo $HOME/dotfiles
    map path '$HOME/projects/$path' <<'    END'
      era
      fp.bash
      mk.bash
      task.bash
      tesht
      jeeves
      shellcheck
      sofdevsim-2026
      binaryphile.github.io
      tandem-protocol
      urma
      share
      dal
    END
  }

  claudeRedirectsUpToDate() {
    local dir encoded f
    for dir in $(memoryProjectDirs); do
      encoded=${dir//\//-}
      f=$memBase/$encoded/memory/MEMORY.md
      [[ -f $f ]] && diff -q "$f" $redirectSrc >/dev/null 2>&1 || return 1
    done
  }
  ok claudeRedirectsUpToDate

  claudeRedirectsInstall() {
    installRedirect() {
      local dir=$1 encoded=${1//\//-}
      local memDir=$memBase/$encoded/memory
      mkdir -p $memDir
      cp $redirectSrc "$memDir/MEMORY.md"
    }
    memoryProjectDirs | each installRedirect
  }
  cmd claudeRedirectsInstall
}

