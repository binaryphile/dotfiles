# system

# aptUpgradeTask upgrades all apt packages to latest.
# Uses DPkg::Lock::Timeout to wait for any held locks (covers all lock
# files: lists, dpkg, dpkg-frontend, archives). Available on Bullseye+.
aptUpgradeTask() {
  desc   'apt-get upgrade'
  prog   on
  runas  root
  unchg  '0 upgraded, 0 newly installed'

  cmd 'DEBIAN_FRONTEND=noninteractive apt-get update -o DPkg::Lock::Timeout=60 -qq && DEBIAN_FRONTEND=noninteractive apt-get upgrade -y -o DPkg::Lock::Timeout=60'
}

# aptInstallGpocTask installs GlobalProtect-openconnect (gpoc) from
# yuezk's GitHub releases. Downloads the .deb and installs with dpkg.
# Crostini-only -- NixOS gets gpoc from nixos-config's flake input.
aptInstallGpocTask() {
  # Bumping version triggers reinstall on next update-env run via the
  # version-equality predicate below (was previously presence-based on
  # /usr/bin/gpclient, which silently skipped already-installed-but-stale
  # hosts on version bumps).
  local version=2.5.4
  local sha256=edbba2d45533782d695aad76aeb244d758f6d591d14b08f6b190aeda1b2a5663

  desc   'install globalprotect-openconnect (gpoc)'
  prog   on

  # Use the dpkg DB as source of truth (not `gpclient --version`): avoids
  # parsing CLI output, fails closed if the package is absent, and immune
  # to PATH ambiguity. Trade-off: trusts package DB and binary state co-move.
  gpocVersionMatches() {
    dpkg-query -W -f='${Version}\n' globalprotect-openconnect 2>/dev/null | grep -qxF "$version-1"
  }
  ok gpocVersionMatches

  aptInstallGpoc() {
    local deb="globalprotect-openconnect_${version}-1_amd64.deb"
    local url="https://github.com/yuezk/GlobalProtect-openconnect/releases/download/v${version}/${deb}"
    local tmp
    tmp=$(mktemp -d) || { echo "failed to create temp directory" >&2; return 1; }
    $curl -fsSL $url -o "$tmp/$deb" || { rm -rf "$tmp"; echo "failed to download gpoc" >&2; return 1; }
    verifySha256 $sha256 "$tmp/$deb" || {
      rm -rf "$tmp"
      echo "gpoc hash mismatch -- possible tampering" >&2
      return 1
    }
    sudo dpkg -i "$tmp/$deb" || sudo apt-get install -f -y
    rm -rf "$tmp"
  }
  cmd aptInstallGpoc
}

# verifyPangpTarballTask asserts the PanGPLinux-<ver>.tgz tarball is at the
# path baked into flake.nix's `pangp` let-binding. The tarball can't be
# auto-downloaded (PAN's customer support portal requires auth), so this
# is a precondition check: fail loud with placement instructions if the
# user hasn't seeded it. Home-manager's pangp build relies on this file.
verifyPangpTarballTask() {
  local tarball="$CrostiniDir/PanGPLinux-6.3.3-c31.tgz"

  desc 'verify pangp tarball is present for nix-managed install'
  prog on
  pangpTarballPresent() { [[ -r "$tarball" ]]; }
  ok pangpTarballPresent

  failMissing() {
    cat <<EOF >&2
pangp.nix expects the PAN GlobalProtect tarball at:
    $tarball
Download it from your PAN customer support portal (the
PanGPLinux-6.3.3-c31.tgz file or newer; update flake.nix's pangp src=
path if the version differs), drop it at the path above, and re-run
update-env.
EOF
    return 1
  }
  cmd failMissing
}

# aptRemoveGlobalprotectTask removes the deprecated apt-installed
# GlobalProtect package (`globalprotect`, NOT to be confused with the OSS
# `globalprotect-openconnect`/gpoc). The nix-managed install via pangp.nix
# replaces it; running both in parallel risks the apt-shipped gpd.service
# fighting the home-manager-deployed one. Predicate-gated so it's a no-op
# on hosts that never had the apt deb.
aptRemoveGlobalprotectTask() {
  desc 'remove deprecated apt-installed globalprotect (nix derivation replaces it)'
  prog on
  globalprotectAbsent() {
    ! dpkg-query -W -f='${Status}\n' globalprotect 2>/dev/null | grep -q '^install ok installed$'
  }
  ok globalprotectAbsent

  aptRemoveGlobalprotect() {
    sudo apt-get remove -y globalprotect
  }
  cmd aptRemoveGlobalprotect
}

# extractGlobalprotectDebToOptTask stages pangp's autoPatchelf'd binaries
# from nix-store into the runtime base (pangp.passthru.runtimeBase, which
# is /opt/paloaltonetworks/globalprotect by convention). Both PanGPS and
# PanGPA land co-located there; both are patched (interpreter -> nix-store
# glibc, which exists at that path on NixOS AND Crostini after Nix install).
#
# PanGPS performs an IPC peer co-location check at PanGPA connect time:
# dirname(realpath(/proc/<peer>/exe)) must equal dirname(realpath(/proc/
# self/exe)). Staging both binaries at the same runtime base satisfies
# this; cp -a preserves the libwa symlink chain.
#
# The earlier strategy (extract .deb to /opt, leave binaries unpatched)
# works on Debian-flavored hosts (Crostini) where /lib64/ld-linux-x86-64
# .so.2 is a real glibc loader. On bare NixOS that path is a stub-ld
# that deliberately fails. See docs/vpn.md "NixOS adaptation".
#
# Markers (deployed by contexts/pangp.nix):
#   ~/.local/share/pangp/source -> $out/opt/paloaltonetworks/globalprotect
#   ~/.local/share/pangp/dest   -> runtimeBase (e.g., /opt/...)
#
# Idempotency: deployed PanGPS interpreter must start with the recorded
# nix-store prefix. If not (stub-ld, missing, or stale rev), re-stage.
#
# Marker absence is FATAL -- home-manager must have activated to deploy
# them before this task runs. See docs/vpn.md for the bootstrap sequence.
#
# Requires sudo NOPASSWD on Crostini for the install into /opt.
extractGlobalprotectDebToOptTask() {
  local srcMarker=$HOME/.local/share/pangp/source
  local destMarker=$HOME/.local/share/pangp/dest

  desc 'stage pangp patched binaries from nix-store into runtimeBase'

  # Marker presence is a HARD prerequisite -- home-manager must have
  # activated to deploy them. Fatal if absent; operator runs
  # `home-manager switch` first.
  if [[ ! -r $srcMarker || ! -r $destMarker ]]; then
    echo "pangp marker files not deployed at $srcMarker / $destMarker; run home-manager switch first" >&2
    return 1
  fi

  local pangpSource pangpDest
  pangpSource=$(< $srcMarker)
  pangpDest=$(< $destMarker)

  # Defensive: markers may exist but be empty (interrupted home-manager
  # activation) or point at a path that no longer exists (nix-store GC
  # fired between marker deploy and task run).
  if [[ -z $pangpSource || -z $pangpDest ]]; then
    echo "pangp marker files are empty; re-run home-manager switch" >&2
    return 1
  fi
  if [[ ! -d $pangpSource ]]; then
    echo "pangp source path '$pangpSource' does not exist (nix-store GC?); re-run home-manager switch" >&2
    return 1
  fi

  # Idempotence: deployed binaries must be byte-identical to the
  # nix-store source. cmp -s is robust regardless of whether bytes are
  # autoPatchelf'd or pristine -- the prior interpreter-prefix proxy
  # broke when pangp.nix switched to pristine binaries (the patched
  # binary in /opt still had a /nix/store interpreter and the check
  # falsely passed, skipping re-extraction).
  optMatchesSource() {
    [[ -x "$pangpDest/PanGPS" && -x "$pangpDest/PanGPA" ]] && \
      cmp -s "$pangpDest/PanGPS" "$pangpSource/PanGPS" && \
      cmp -s "$pangpDest/PanGPA" "$pangpSource/PanGPA"
  }
  ok optMatchesSource

  extractFromNixStore() {
    # Backup current dest content for one-week observation window. Only
    # backs up if the dir has real content AND no backup exists yet.
    # Single-snapshot rationale: source of truth is the immutable nix-
    # store; the dest snapshot is a rollback safety net for the deploy
    # operation, not a per-deploy history.
    if [[ -e "$pangpDest/PanGPS" && ! -e "$pangpDest.pre-pangp-store-extract" ]]; then
      sudo cp -a "$pangpDest" "$pangpDest.pre-pangp-store-extract"
    fi
    sudo mkdir -p "$pangpDest"
    # cp -a preserves symlinks. libwa* libraries ship as a symlink
    # chain (libwaapi.so -> libwaapi.so.4 -> libwaapi.so.4.3.3608.0);
    # -a preserves the chain. -aL would dereference symlinks producing
    # byte-identical regular files per chain -- works for dlopen but
    # changes filesystem semantics for no benefit.
    sudo cp -a "$pangpSource/." "$pangpDest/"
  }
  cmd extractFromNixStore
}

# installPangpSystemDesktopTask resolves the globalprotectcallback://
# scheme-handler conflict between the apt-shipped gpgui.desktop and
# pangp's gp.desktop. ChromeOS host Chrome dispatches the scheme from
# /usr/share/applications/mimeinfo.cache, NOT from user-level
# ~/.local/share/applications/. So the apt gpgui.desktop wins on the
# host side and routes every SAML callback to gpoc's `gpclient launch-
# gui`, which has no peer in pangp mode -- the cookie never reaches
# PanGPS. See docs/design.md "Crostini garcon discovery gotcha".
#
# Fix: disable the apt gpgui.desktop (mv to .disabled so apt reinstall
# would restore it) and copy nix-profile's gp.desktop to the system
# applications dir so ChromeOS sees it. The user-level symlinks for
# both stay in place; the system-level overrides are what ChromeOS
# consults for callback dispatch.
installPangpSystemDesktopTask() {
  local sysApps=/usr/share/applications
  local gpguiSys=$sysApps/gpgui.desktop
  local gpDesktopUser=$HOME/.nix-profile/share/applications/gp.desktop
  local gpDesktopSys=$sysApps/gp.desktop

  desc 'install gp.desktop at /usr/share/applications and disable apt gpgui.desktop (pangp callback routing)'
  prog on
  pangpDesktopActive() {
    [[ ! -f "$gpguiSys" && -f "$gpDesktopSys" ]]
  }
  ok pangpDesktopActive

  installPangpDesktop() {
    if [[ -f "$gpguiSys" ]]; then
      sudo mv $gpguiSys "$gpguiSys.disabled"
    fi
    [[ -f "$gpDesktopUser" ]] || { echo "$gpDesktopUser missing; ensure pangp home-manager module has applied" >&2; return 1; }
    sudo cp $gpDesktopUser $gpDesktopSys
    sudo update-desktop-database $sysApps
  }
  cmd installPangpDesktop
}

# enablePangpDefaultBrowserTask flips the <default-browser> setting in
# pangps.xml so PanGPS asks the OS to launch a browser for SAML auth
# (vs the embedded WebKit form, which fails Okta's modern policy). The
# script auto-detects the active pangps.xml (the /opt path now that the
# .deb is extracted there); idempotent on re-runs.
enablePangpDefaultBrowserTask() {
