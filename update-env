# hash verification

# verifySha256 checks that a file matches an expected SHA-256 hash.
# Uses $sha256sum (injectable -- wraps shasum -a 256 on macOS).
verifySha256() {
  local hash=$1 file=$2
  printf '%s  %s\n' "$hash" "$file" | $sha256sum -c - >/dev/null 2>&1
}

# nix

# nixInstallerAsset maps OS/arch to the Determinate Nix installer binary name
# and pinned SHA-256 hash. Pure decision function -- no side effects.
nixInstallerAsset() {
  local os=$1 arch=$2
  case $os/$arch in
    Linux/x86_64 )
      echo "nix-installer-x86_64-linux 4a84424a0a598b671de21fca1602ea3e74af214d823020afe7aac0056dc032ac"
      ;;
    Linux/aarch64 )
      echo "nix-installer-aarch64-linux 2f0a61cd3ff25cb8827448d942b5296073d8c86b5386d48fe623d9b0cda1fc78"
      ;;
    Darwin/arm64 )
      echo "nix-installer-aarch64-darwin 5153414f03eea4267eb66e93dade574daba86506ee5fd3afc1b9de836fce5751"
      ;;
    * )
      echo "unsupported platform: $os/$arch" >&2
      return 1
      ;;
  esac
}

# installNix downloads, hash-verifies, and runs the Determinate Nix installer.
# Extracted from the task wrapper for testability. Platform auto-detected via
# uname_s/uname_m (injectable for testing).
installNix() {
  local version=3.17.3
  local asset
  asset=$(nixInstallerAsset "${uname_s:-$(uname -s)}" "${uname_m:-$(uname -m)}") || return 1
  local binary sha256
  binary=${asset%% *}
  sha256=${asset##* }
  local url="https://github.com/DeterminateSystems/nix-installer/releases/download/v${version}/${binary}"
  local tmp
  tmp=$(mktemp -d) || { echo "failed to create temp directory" >&2; return 1; }
  $curl -fsSL "$url" -o "$tmp/$binary" || {
    rm -rf "$tmp"
    echo "failed to download nix-installer" >&2
    return 1
  }
  verifySha256 "$sha256" "$tmp/$binary" || {
    rm -rf "$tmp"
    echo "nix-installer hash mismatch -- possible tampering" >&2
    return 1
  }
  chmod +x "$tmp/$binary"
  local os=${uname_s:-$(uname -s)}
  case $os in
    Linux )  "$tmp/$binary" install linux --no-confirm --init none;;
    Darwin ) "$tmp/$binary" install --no-confirm;;
  esac
  local rc=$?
  rm -rf "$tmp"
  return $rc
}

installNixTask() {
  desc   'install nix (Determinate installer, hash-verified)'
  exist  /nix/var/nix/profiles/default/bin/nix-env
  prog   on

  cmd installNix
}

# nixConfContent returns the declarative nix.conf content.
# Enables flakes, auto-optimise, max-jobs. Trusts only cache.nixos.org.
# No third-party caches (see security.md).
nixConfContent() {
  cat <<'EOF'
experimental-features = nix-command flakes
auto-optimise-store = true
max-jobs = auto
EOF
}

writeNixConfTask() {
  local path=${1:-/etc/nix/nix.conf}
  local tmp
  tmp=$(mktemp)
  nixConfContent >"$tmp"

  desc  'write declarative nix.conf'
  runas root

  nixConfUpToDate() { [[ -f $path ]] && diff -q "$path" "$tmp" >/dev/null 2>&1; }
  ok nixConfUpToDate

  local cmd_
  printf -v cmd_ 'install -m 644 -- %q %q' "$tmp" "$path"
  cmd "$cmd_"
}

# chownRTask recursively chowns $path with $user:$group.
# $user and $group are the numbered versions, e.g. 1000:1000, not username:groupname.
chownRTask() {
  local path=$1 user=$2 group=$3

  desc    "recursively change ownership of $path to $user:$group"
  runas   root

  ifIsOwnerAndGroup() { [[ $(ownerAndGroup $path) == "$user:$group" ]]; }
  ok ifIsOwnerAndGroup

  cmd "chown -R -- $user:$group $path"
}

