SshKeyStatus=present

# sshKeyAction -- pure decision function for SSH key restore.
#
# Takes a nameref to an associative array with keys:
#   repoHasPub repoFp localExists localFp
#   cacheExists cacheFp hasTty opReady opHasItem
# All values are 0/1 (booleans) or strings (fingerprints, "" if absent).
#
# Returns 0 always. Prints exactly one action from this closed set:
#   present | collision | capture_to_repo
#   backup_then_cache | backup_then_op | backup_then_fail
#   restore_from_cache | restore_from_op | generate
#   missing_noninteractive
#   error_malformed_pub
#
# Decision table (abbreviated, see tests for full coverage):
#   local exists + repo match       -> present
#   local exists + repo mismatch    -> collision
#   local exists + repo unverifiable -> backup_then_{cache|op|fail}
#   local exists + no repo          -> capture_to_repo
#   cache valid + repo match/absent -> restore_from_cache
#   op ready + item exists          -> restore_from_op
#   nothing + tty                   -> generate
#   nothing + no tty                -> missing_noninteractive
sshKeyAction() {
  local -n STATE=$1

  # Pub sidecar validation
  if (( STATE[repoHasPub] )) && [[ -z ${STATE[repoFp]} ]]; then echo error_malformed_pub; return 0; fi

  # Tier 1: local key exists
  if (( STATE[localExists] )); then
    if [[ -n ${STATE[repoFp]} ]]; then
      if [[ -n ${STATE[localFp]} && ${STATE[localFp]} == "${STATE[repoFp]}" ]]; then echo present; return 0; fi
      if [[ -n ${STATE[localFp]} && ${STATE[localFp]} != "${STATE[repoFp]}" ]]; then echo collision; return 0; fi
      # localFp empty = unverifiable -- backup, then try cache/op/fail
      if (( STATE[cacheExists] )) && [[ -n ${STATE[cacheFp]} ]]; then
        if [[ -z ${STATE[repoFp]} || ${STATE[cacheFp]} == "${STATE[repoFp]}" ]]; then
          echo backup_then_cache; return 0
        fi
      fi
      if (( STATE[opReady] && STATE[opHasItem] )); then
        echo backup_then_op; return 0
      fi
      echo backup_then_fail; return 0
    else
      echo capture_to_repo; return 0
    fi
  fi

  # Tier 2: mount cache
  if (( STATE[cacheExists] )) && [[ -n ${STATE[cacheFp]} ]]; then
    if [[ -n ${STATE[repoFp]} && ${STATE[cacheFp]} != "${STATE[repoFp]}" ]]; then
      : # stale, fall through
    else
      echo restore_from_cache; return 0
    fi
  fi

  # Tier 3: 1Password
  if (( STATE[opReady] && STATE[opHasItem] )); then
    echo restore_from_op; return 0
  fi

  # Tier 4: generate
  if (( !STATE[hasTty] )); then echo missing_noninteractive; return 0; fi
  echo generate; return 0
}

restoreSshKeyImpl() {
  local hostname
  hostname=$(lib.MachineHostname)
  lib.ValidateHostname $hostname || return 1

  local repoPub="$HOME/dotfiles/ssh/id_ed25519_${hostname}.pub"
  local localKey="$HOME/.ssh/id_ed25519"
  local cacheDir="$CrostiniDir/ssh/$hostname"
  local cacheKey="$cacheDir/id_ed25519"
  local opItem
  opItem=$(opAuthKeyItem "$hostname")

  mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
  rm -f "$CrostiniDir/np_id_ed25519" "$CrostiniDir/np_id_ed25519.pub"

  # Classify filesystem state into decision inputs
  local -A state=(
    [repoHasPub]=0 [repoFp]=""
    [localExists]=0 [localFp]=""
    [cacheExists]=0 [cacheFp]=""
    [hasTty]=0
    [opReady]=0 [opHasItem]=0
  )

  [[ -f $repoPub ]] && state[repoHasPub]=1
  (( state[repoHasPub] )) && state[repoFp]=$(pubFingerprint "$repoPub")
  [[ -f $localKey && -s $localKey ]] && state[localExists]=1
  (( state[localExists] )) && [[ -f $localKey.pub && -s $localKey.pub ]] && state[localFp]=$(pubFingerprint "$localKey.pub")
  [[ -f $cacheKey && -f $cacheKey.pub ]] && state[cacheExists]=1
  (( state[cacheExists] )) && state[cacheFp]=$(pubFingerprint "$cacheKey.pub")
  [[ -t 0 ]] && state[hasTty]=1
  if command -v -- $op >/dev/null 2>&1 && $op whoami >/dev/null 2>&1; then
    state[opReady]=1
    $op item get "$opItem" --vault $OpVault >/dev/null 2>&1 && state[opHasItem]=1
  fi

  local action
  action=$(sshKeyAction state)

  # Dispatch
  case $action in
    error_*)
      echo ERROR: ${action#error_} >&2
      return 1
      ;;

    present)
      chmod 600 "$localKey"
      if [[ -d $CrostiniDir ]]; then
        mkdir -p "$cacheDir" 2>/dev/null
        installKey $localKey $cacheKey
      fi 2>/dev/null || true
      SshKeyStatus=present
      return 0
      ;;

    collision)
      echo "ERROR: hostname collision -- local (${state[localFp]}) != repo (${state[repoFp]})." >&2
      SshKeyStatus=collision
      return 1
      ;;

    backup_then_cache)
      sshKeyBackupLocal $localKey || return 1
      echo "Restoring SSH key from mount cache ($hostname)..."
      if ! installKey $cacheKey $localKey; then
        echo "ERROR: cache restore failed after backup." >&2
        return 1
      fi
      SshKeyStatus=restored
      return 0
      ;;

    backup_then_op)
      sshKeyBackupLocal $localKey || return 1
      sshKeyRestoreFromOp "$opItem" "$localKey" "$repoPub" "$cacheDir" "$cacheKey"
      return
      ;;

    backup_then_fail)
      sshKeyBackupLocal $localKey || return 1
      echo "ERROR: cannot restore key (no cache or 1Password available after backup)." >&2
      return 1
      ;;

    capture_to_repo)
      # Local key usable regardless of capture outcome.
      # Copy .pub sidecar to repo for fingerprint validation.
      chmod 600 "$localKey"
      if [[ -f $localKey.pub && -s $localKey.pub ]]; then
        cp "$localKey.pub" "$repoPub" 2>/dev/null || true
      fi
      SshKeyStatus=present
      return 0
      ;;

    restore_from_cache)
      echo "Restoring SSH key from mount cache ($hostname)..."
      if ! installKey $cacheKey $localKey; then
        echo "ERROR: cache restore failed." >&2
        return 1
      fi
      SshKeyStatus=restored
      ;;

    restore_from_op)
      sshKeyRestoreFromOp "$opItem" "$localKey" "$repoPub" "$cacheDir" "$cacheKey"
      return
      ;;

    generate)
      sshKeyGenerate $localKey $repoPub $hostname $cacheDir $cacheKey
      return
      ;;

    missing_noninteractive)
      echo "No SSH key available and no TTY. Run update-env interactively."
      SshKeyStatus=missing_noninteractive
      return 0
      ;;

    *)
      echo ERROR: unexpected sshKeyAction result: $action >&2
      return 1
      ;;
  esac
}

# sshKeyRestoreFromOp -- retrieve SSH key from 1Password, install, cache.
# Same pattern as restoreSigningKey's restore_from_op dispatch.
sshKeyRestoreFromOp() {
  local opItem=$1 localKey=$2 repoPub=$3 cacheDir=$4 cacheKey=$5
  echo "Restoring SSH key from 1Password ($opItem)..."
  $op read --out-file "$localKey" "op://$OpVault/$opItem/private key?ssh-format=openssh" || {
    echo "ERROR: 1Password SSH key retrieval failed." >&2
    return 1
  }
  chmod 600 "$localKey"
  $ssh_keygen -y -f "$localKey" >"$localKey.pub" 2>/dev/null
  chmod 644 "$localKey.pub"
  # Copy .pub sidecar to repo for fingerprint validation
  cp "$localKey.pub" "$repoPub" 2>/dev/null || true
  # Cache to mount
  if [[ -d $CrostiniDir ]]; then
    mkdir -p "$cacheDir" 2>/dev/null
    installKey $localKey $cacheKey
  fi 2>/dev/null || echo "WARNING: mount cache write failed" >&2
  SshKeyStatus=restored
}

# sshKeyBackupLocal -- back up local key before overwriting. Returns 1 on failure.
sshKeyBackupLocal() {
  local localKey=$1
  echo "WARNING: local key exists but .pub is missing/invalid. Cannot verify." >&2
  local bakFile
  bakFile=$(mktemp "$localKey.bak.XXXXXX") || { echo "ERROR: cannot create backup"; return 1; } >&2
  echo "  Backing up to $bakFile before restoring from repo."
  if ! cp "$localKey" "$bakFile" || ! chmod 600 "$bakFile"; then
    echo "ERROR: backup failed. Will not overwrite local key." >&2
    return 1
  fi
  [[ -f $localKey.pub ]] && cp "$localKey.pub" "$bakFile.pub" 2>/dev/null
  return 0
}



# sshKeyGenerate -- tier 4 implementation: generate new key, copy .pub to repo, cache.
sshKeyGenerate() {
  local localKey=$1 repoPub=$2 hostname=$3 cacheDir=$4 cacheKey=$5
  command -v -- $ssh_keygen >/dev/null 2>&1 || { echo $ssh_keygen not found; return 1; }
  echo No SSH key for $hostname. Generating...
  echo "(SSH key passphrase -- protects the key on disk)"
  if ! sshKeygenTask $localKey; then
    echo "ERROR: key generation failed." >&2
    return 1
  fi
  chmod 644 "$localKey.pub"

  # Copy .pub sidecar to repo for fingerprint validation
  cp "$localKey.pub" "$repoPub" 2>/dev/null || true

  if [[ -d $CrostiniDir ]]; then
    mkdir -p "$cacheDir" 2>/dev/null
    installKey $localKey $cacheKey
  fi 2>/dev/null || echo "WARNING: mount cache write failed" >&2

  SshKeyStatus=generated
}

restoreSshKey() { restoreSshKeyImpl; }

# restoreSecrets -- two-tier restore for per-machine secrets.
# Secrets are flat files in ~/secrets/. Backed up to 1Password, not the repo.
# Restore: local -> mount cache -> manual from 1Password.
restoreSecrets() {
  local hostname
  hostname=$(lib.MachineHostname)
  lib.ValidateHostname $hostname || return 1
  local secretsDir="$HOME/secrets"
  local cacheDir="$CrostiniDir/secrets/$hostname"

  mkdirp $secretsDir && chmod 700 "$secretsDir"

  # Tier 1: local secrets exist
  if [[ -n $(lib.Glob $secretsDir/*) ]]; then
    return 0
  fi

  # Tier 2: mount cache (namespaced by hostname)
  if [[ -d $cacheDir ]] && [[ -n $(lib.Glob $cacheDir/*) ]]; then
    echo "Restoring secrets from mount cache ($hostname)..."
    local stageDir
    stageDir=$(mktemp -d "$secretsDir.stage.XXXXXX")
    chmod 700 "$stageDir"
    if cp "$cacheDir"/* "$stageDir"/ 2>/dev/null; then
      chmod 600 "$stageDir"/* 2>/dev/null
      mv "$stageDir"/* "$secretsDir"/ 2>/dev/null
      rmdir "$stageDir" 2>/dev/null
      return 0
    fi
    rm -rf "$stageDir"
    echo "WARNING: cache restore failed." >&2
  fi

  echo No secrets for $hostname. Create ~/secrets/ files, then run scripts/encrypt-secrets.
  return 0
}

loadSshKey() {
  [[ -f $HOME/.ssh/id_ed25519 ]] || return 0
  command -v -- $keychain >/dev/null 2>&1 || { echo WARNING: $keychain not found; return 0; } >&2
  eval "$(SSH_ASKPASS_REQUIRE=never $keychain --eval id_ed25519)" || {
    echo "WARNING: keychain failed to load SSH key." >&2
  }
}

# signingKeyAction -- pure function mapping filesystem state to action.
# Same pattern as sshKeyAction. Input: associative array name with state flags.
# Output: action string to stdout. No side effects.
signingKeyAction() {
  local -n STATE=$1

  if (( STATE[localExists] )); then
    if (( STATE[repoHasPub] )); then
      if [[ ${STATE[localFp]} != "${STATE[repoFp]}" ]]; then
        echo collision; return 0
      fi
      echo present; return 0
    fi
    echo present_no_sidecar; return 0
  fi

  if (( STATE[opReady] && STATE[opHasItem] )); then
    echo restore_from_op; return 0
  fi

  echo generate; return 0
}

# restoreSigningKey -- ensure a per-machine git commit signing key exists.
# Separate from auth key per crypto practice (keys not reused across purposes).
# No passphrase (used on every commit), no mount cache (trivially regenerated).
# Restore priority: local -> 1Password -> generate.
restoreSigningKey() {
  local hostname
  hostname=$(lib.MachineHostname)
  lib.ValidateHostname $hostname || return 1
  local localKey=$HOME/.ssh/id_ed25519_signing
  local repoPub=$HOME/dotfiles/ssh/id_ed25519_signing_${hostname}.pub

  # Classify filesystem state into decision inputs
  local -A state=(
    [localExists]=0 [localFp]=""
    [repoHasPub]=0 [repoFp]=""
    [opReady]=0 [opHasItem]=0
  )

  [[ -f $localKey ]] && state[localExists]=1
  (( state[localExists] )) && [[ -f $localKey.pub ]] && state[localFp]=$($ssh_keygen -lf "$localKey.pub" 2>/dev/null | awk '{print $2}')
  [[ -f $repoPub ]] && state[repoHasPub]=1
  (( state[repoHasPub] )) && state[repoFp]=$($ssh_keygen -lf "$repoPub" 2>/dev/null | awk '{print $2}')
  if command -v -- $op >/dev/null 2>&1 && $op whoami >/dev/null 2>&1; then
    state[opReady]=1
    local opItem
    opItem=$(opSigningKeyItem "$hostname")
    $op item get "$opItem" --vault $OpVault >/dev/null 2>&1 && state[opHasItem]=1
  fi

  local action
  action=$(signingKeyAction state)

  # Dispatch
  case $action in
    present )
      chmod 600 "$localKey"
      if (( state[opReady] && !state[opHasItem] )); then
        echo "Signing key exists locally but not in 1Password."
        echo "  Store as: $opItem ($OpVault vault)"
      fi
      ;;

    present_no_sidecar )
      chmod 600 "$localKey"
      cp "$localKey.pub" "$repoPub" 2>/dev/null || true
      echo "Signing key .pub sidecar added to repo. Commit and push."
      if (( state[opReady] && !state[opHasItem] )); then
        echo "  Also store in 1Password as: $opItem ($OpVault vault)"
      fi
      ;;

    collision )
      echo "ERROR: signing key fingerprint mismatch -- local (${state[localFp]}) != repo (${state[repoFp]})" >&2
      return 1
      ;;

    restore_from_op )
      echo "Restoring signing key from 1Password ($opItem)..."
      $op read --out-file "$localKey" "op://$OpVault/$opItem/private key?ssh-format=openssh" || {
        echo "ERROR: 1Password signing key retrieval failed." >&2
        return 1
      }
      chmod 600 "$localKey"
      $ssh_keygen -y -f "$localKey" >"$localKey.pub" 2>/dev/null
      chmod 644 "$localKey.pub"
      cp "$localKey.pub" "$repoPub" 2>/dev/null || true
      echo "Signing key restored from 1Password."
      echo "Register via 1Password browser extension if not already registered:"
      echo "  https://github.com/settings/keys (Signing Key)"
      ;;

    generate )
      echo "Generating git commit signing key for $hostname..."
      $ssh_keygen -t ed25519 -f "$localKey" -N "" -C "ted@${hostname}-signing" || {
        echo "ERROR: signing key generation failed." >&2
        return 1
      }
      chmod 600 "$localKey"
      chmod 644 "$localKey.pub"
      cp "$localKey.pub" "$repoPub" 2>/dev/null || true
      echo "Signing key generated."
      echo
      echo "1. Store in 1Password as: $(opSigningKeyItem $hostname) ($OpVault vault)"
      echo
      echo "2. Register via 1Password browser extension:"
      echo "     https://github.com/settings/keys (Signing Key)"
      echo
      echo "3. Commit and push:"
      echo "     cd ~/dotfiles && git add ssh/ && git commit && git push"
      ;;
  esac
}

# runSigningKeyPreflight -- controller that classifies signing key state and
# calls the pure signingKeyPreflight function. Prints any warnings.
runSigningKeyPreflight() {
  local hostname
  hostname=$(lib.MachineHostname)
  local localKey=$HOME/.ssh/id_ed25519_signing
  local repoPub=$HOME/dotfiles/ssh/id_ed25519_signing_${hostname}.pub
  local opItem
    opItem=$(opSigningKeyItem "$hostname")

  local -A skState=(
    [localExists]=0 [sidecarTracked]=0
    [opReady]=0 [opHasItem]=0
  )

  [[ -f $localKey ]] && skState[localExists]=1
  if [[ -f $repoPub ]]; then
    git -C ~/dotfiles ls-files --error-unmatch "$repoPub" >/dev/null 2>&1 && skState[sidecarTracked]=1
  fi
  if command -v -- $op >/dev/null 2>&1 && $op whoami >/dev/null 2>&1; then
    skState[opReady]=1
    $op item get "$opItem" --vault $OpVault >/dev/null 2>&1 && skState[opHasItem]=1
  fi

  signingKeyPreflight skState "$hostname"
}

# signingKeyPreflight -- pure function that checks whether the signing key
# registration workflow is complete. Takes a nameref to a state associative
# array with keys: localExists, sidecarTracked, opReady, opHasItem.
# Prints warnings to stdout. No side effects.
signingKeyPreflight() {
  local -n STATE=$1
  local hostname=$2

  (( STATE[localExists] )) || return 0

  if (( !STATE[sidecarTracked] )); then
    echo "WARNING: signing key .pub sidecar not committed to repo."
    echo "  Complete the registration workflow:"
    echo "  1. Store in 1Password as: $(opSigningKeyItem $hostname) ($OpVault vault)"
    echo "  2. Register via 1Password browser extension:"
    echo "       https://github.com/settings/keys (Signing Key)"
    echo "  3. Commit: cd ~/dotfiles && git add ssh/ && git commit && git push"
  fi

  if (( STATE[opReady] && !STATE[opHasItem] )); then
    echo "WARNING: signing key not in 1Password."
    echo "  Store as: $(opSigningKeyItem $hostname) ($OpVault vault)"
  fi
}

authPreflight() {
  local keyFile=$HOME/.ssh/id_ed25519
  local -a sshopts=(-o BatchMode=yes -o PreferredAuthentications=publickey
    -o IdentitiesOnly=yes -i "$keyFile" -o ConnectTimeout=10
    -o StrictHostKeyChecking=accept-new)

  [[ -f $keyFile ]] || { echo "  No SSH key -- all private repos will be skipped"; return; }

  # Guard: check that THIS key is in the agent before testing registries.
  # BatchMode SSH fails identically whether the key was rejected by the
  # registry or never offered -- without this guard, a missing or wrong
  # key produces misleading "key not registered" for all providers.
  local keyFp
  keyFp=$($ssh_keygen -lf "$keyFile.pub" 2>/dev/null | awk '{print $2}')
  if [[ -z $keyFp ]] || ! $ssh_add -l 2>/dev/null | grep -qF $keyFp; then
    echo "  key not in agent -- run 'ssh-add ~/.ssh/id_ed25519' after exec bash"
    return
  fi

  checkProvider() {
    local provider=$1 rc output_
    if output_=$($ssh -T "${sshopts[@]}" "git@$provider" 2>&1); then rc=0; else rc=$?; fi
    if (( rc == 0 || rc == 1 )); then
      :
    elif echo "$output_" | grep -qi 'permission denied\|publickey'; then
      echo "  $provider: key not registered"
      [[ -f $keyFile.pub ]] && echo "    Register: cat $keyFile.pub"
    else
      echo "  $provider: unreachable"
    fi
  }
  each checkProvider <<'  END'
    github.com
    codeberg.org
    bitbucket.org
  END

  if $ip link show tun0 >/dev/null 2>&1; then
    local rc output_
    if output_=$($ssh -T "${sshopts[@]}" git@stash.digi.com 2>&1); then rc=0; else rc=$?; fi
    (( rc == 0 || rc == 1 )) || echo "  stash.digi.com: SSH auth failed"
  fi
}

## helpers

fatal() {
  local msg=$1 rc=${2:-$?}
  echo fatal: $msg
  exit $rc
}

# mkdirp -- mkdir -p that follows symlinks. Plain mkdir -p fails on a
# symlink to a nonexistent directory; this resolves first.
mkdirp() { mkdir -p "$(readlink -f "$1" 2>/dev/null || echo "$1")"; }

# crostiniHostnameSetup -- verify ChromeOS backing storage, create
# $CrostiniDir, and write hostname file. Fatal on first run without
# hostname arg or without backing storage.
# Reads: $CrostiniBacking (parent of $CrostiniDir), $CrostiniDir, $Hostname.
crostiniHostnameSetup() {
  local backing=${CrostiniBacking:-/mnt/chromeos/MyFiles/Downloads}
  [[ -d $backing ]] || { echo fatal: ChromeOS shared storage not mounted at $backing >&2; echo "Enable file sharing in ChromeOS Settings > Linux" >&2; return 1; }
  mkdir -p "$CrostiniDir"
  if [[ -n $Hostname ]]; then
    lib.ValidateHostname $Hostname || return 1
    echo $Hostname >$CrostiniDir/hostname
  elif [[ ! -e $CrostiniDir/hostname ]]; then
    echo "fatal: no Crostini hostname configured" >&2
    echo "First run requires: update-env -1 <hostname>" >&2
    return 1
  fi
}

# convergeTaskBash -- after home-manager switch, re-source session vars to
# pick up TASK_BASH_LIB from the new generation, then re-source task.bash
# from the pinned store path. Ensures the rest of this run uses the
# nix-pinned version, not the curl bootstrap.
# Unsets __HM_SESS_VARS_SOURCED first -- hm-session-vars.sh guards against
# double-sourcing, but we need the new generation's values.
# Non-NixOS only (called inside the crostini|debian|linux|macos case block).
convergeTaskBash() {
  local hmVars=$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh
  unset -v __HM_SESS_VARS_SOURCED
  [[ -r $hmVars ]] || { echo fatal: hm-session-vars.sh not found at $hmVars >&2; exit 1; }
  loosely source $hmVars
  if [[ -n ${TASK_BASH_LIB:-} ]]; then
    [[ -r $TASK_BASH_LIB ]] || { echo fatal: TASK_BASH_LIB unreadable after switch: $TASK_BASH_LIB >&2; exit 1; }
    source $TASK_BASH_LIB || { echo "fatal: failed to source converged task.bash: $TASK_BASH_LIB (rc=$?)" >&2; exit 1; }
  fi
}

# resolveSourceDir -- resolve the directory of the calling script, following
# symlink chains. Works when update-env is at ~/.local/bin/update-env.
resolveSourceDir() {
  local src=${BASH_SOURCE[1]:-${BASH_SOURCE[0]}}
  local dir
  while [[ -L $src ]]; do
    dir=$(cd -P -- "$(dirname -- "$src")" 2>/dev/null && pwd) || return 1
    src=$(readlink -- "$src") || return 1
    [[ $src != /* ]] && src=$dir/$src
  done
  cd -P -- "$(dirname -- "$src")" 2>/dev/null && pwd
}

# Shared helpers -- sourced from lib.bash to avoid duplication.
# lib.bash provides: lib.Glob, lib.MachineHostname, lib.ValidateHostname, lib.ValidSecretName
LibDir=$(resolveSourceDir) 2>/dev/null
if [[ -n ${LibDir:-} && -f $LibDir/scripts/lib.bash ]]; then
  source $LibDir/scripts/lib.bash
else
  eval "$($curl -fsSL https://raw.githubusercontent.com/binaryphile/dotfiles/main/scripts/lib.bash)" || { echo "fatal: scripts/lib.bash not found" >&2; exit 1; }
fi
unset -v LibDir

pubFingerprint() {
  [[ -f $1 && -s $1 ]] || return 0
  $ssh_keygen -lf "$1" 2>/dev/null | awk '{print $2}'
}

# installKey SRC DST -- install key pair from SRC to DST.
# Contract: destination reflects source pair state exactly.
# If source has .pub, destination gets it. If not, stale dst.pub is removed.
# On partial failure, prior destination state is restored (best-effort).
# Private key trust model: we trust .pub matches private key if they were
# produced together by ssh-keygen or extracted from the same age bundle.
# Manual .pub replacement is unsupported. See design docs.
installKey() {
  local src=$1 dst=$2 tmpPriv tmpPub="" bakPriv=""

  # Stage new private key
  tmpPriv=$(mktemp "$dst.XXXXXX")       || return 1
  cp "$src" "$tmpPriv"                  || { rm -f "$tmpPriv"; return 1; }
  chmod 600 "$tmpPriv"                  || { rm -f "$tmpPriv"; return 1; }

  # Stage new .pub if source has one
  if [[ -f $src.pub ]]; then
    tmpPub=$(mktemp "$dst.pub.XXXXXX")  || { rm -f "$tmpPriv"; return 1; }
    cp "$src.pub" "$tmpPub"             || { rm -f "$tmpPriv" "$tmpPub"; return 1; }
    chmod 644 "$tmpPub"                 || { rm -f "$tmpPriv" "$tmpPub"; return 1; }
  fi

  # Back up existing private key for rollback
  if [[ -f $dst ]]; then
    bakPriv=$(mktemp "$dst.rollback.XXXXXX") && cp "$dst" "$bakPriv" || bakPriv=""
  fi

  # Commit private key
  mv "$tmpPriv" "$dst" || {
    rm -f "$tmpPriv" "$tmpPub" "$bakPriv"
    return 1
  }

  # Commit .pub -- rollback private on failure
  if [[ -n $tmpPub ]]; then
    if ! mv "$tmpPub" "$dst.pub"; then
      # Restore prior private key or remove new one
      if [[ -n $bakPriv ]]; then
        mv "$bakPriv" "$dst" 2>/dev/null || rm -f "$dst"
      else
        rm -f "$dst"
      fi
      rm -f "$tmpPub" "$bakPriv"
      return 1
    fi
  elif [[ -f $dst.pub && ! -f $src.pub ]]; then
    # Source has no .pub -- remove stale dst.pub for pair consistency
    if ! rm -f "$dst.pub"; then
      # Can't remove stale .pub -- rollback private key
      if [[ -n $bakPriv ]]; then
        mv "$bakPriv" "$dst" 2>/dev/null || rm -f "$dst"
      else
        rm -f "$dst"
      fi
      rm -f "$bakPriv"
      return 1
    fi
  fi

  # Success -- clean up rollback backup
  rm -f "$bakPriv"
  return 0
}

isFile() { [[ -f $1 ]]; }

loosely() {
  local IFS=$' \t\n'
  local prevOpts_
  prevOpts_=$(set +o)
  set +eufo pipefail
  "$@"
  eval "$prevOpts_"
}

ownerAndGroup() {
  local path=$1
  [[ $OSTYPE == darwin* && $(type -p stat) == /usr/bin/stat ]] && local flag=f || local flag=c
  echo "$(stat -$flag %u "$path"):$(stat -$flag %g "$path")"
}

detectPlatform() {
  [[ $OSTYPE != darwin* ]] || { echo macos; return; }
  [[ $HOSTNAME != penguin ]] || { echo crostini; return; }
  if [[ -e /etc/NIXOS ]]; then
    [[ ! -d ~/dotfiles/contexts/$HOSTNAME ]] || { echo $HOSTNAME; return; }
    echo nixos; return
  fi
  ! [[ -e /etc/debian_version ]] || { echo debian; return; }
  echo linux
}


## fp

# each applies its arguments as a command to each argument from stdin.
# stream prints each argument on its own line.
stream() { printf '%s\n' "$@"; }

each() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg"
  done
}

# keepIf filters lines from stdin using command.
keepIf() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg" && echo "$arg"
  done
  return 0
}

# map returns $EXPRESSION evaluated with the value of stdin as $VARNAME.
# $EXPRESSION must respect double-quoting rules and so can't contain naked quotes.
# $VARNAME may not be "VARNAME" or "EXPRESSION".
map() {
  local VARNAME=$1 EXPRESSION=$2
  case $VARNAME in VARNAME|EXPRESSION ) fatal "map: VARNAME may not be 'VARNAME' or 'EXPRESSION'";; esac
  local $VARNAME
  while IFS='' read -r $VARNAME; do
    eval "echo \"$EXPRESSION\""
  done
}

