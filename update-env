isFile() { [[ -f $1 ]]; }

loosely() {
  local oldIfs_=$IFS
  local hadE=0 hadU=0 hadF=0 hadPipefail=0
  [[ $- == *e* ]] && hadE=1
  [[ $- == *u* ]] && hadU=1
  [[ $- == *f* ]] && hadF=1
  shopt -qo pipefail && hadPipefail=1

  IFS=$' \t\n'
  set +eufo pipefail
  "$@"

  (( hadE )) && set -e
  (( hadU )) && set -u
  (( hadF )) && set -f
  (( hadPipefail )) && set -o pipefail
  IFS=$oldIfs_
}

ownerAndGroup() {
  local path=$1
  [[ $OSTYPE == darwin* && $(type -p stat) == /usr/bin/stat ]] && local flag=f || local flag=c
  echo "$(stat -$flag %u $path):$(stat -$flag %g $path)"
}

detectPlatform() {
  [[ $OSTYPE != darwin* ]] || { echo macos; return; }
  [[ $HOSTNAME != penguin ]] || { echo crostini; return; }
  if [[ -e /etc/NIXOS ]]; then
    [[ ! -d ~/dotfiles/contexts/$HOSTNAME ]] || { echo $HOSTNAME; return; }
    echo nixos; return
  fi
  ! [[ -e /etc/debian_version ]] || { echo debian; return; }
  echo desktop
