#!/usr/bin/env bash
# pre-commit -- reject credentials in tracked files (claude/settings.json env)
#
# Naming Policy:
#
# This is a standalone script -- no namespace prefix on functions, no suffix on globals.
# Function names use camelCase (one-off tool; not mk.bash framework).
# Local variable names begin with lowercase, e.g. localVariable.
# Global variable names begin with uppercase, e.g. GlobalVariable.
# Variables ending in *List or _ contain IFS characters and must be quoted on use.

checkSettingsJson() {
    git diff --cached --name-only | grep -q 'claude/settings.json' || return 0

    if jq -e '(.mcpServers // {}) | to_entries[] | select(.value.env != null)' claude/settings.json >/dev/null 2>&1; then
        cat <<'END'
BLOCKED: claude/settings.json contains env vars in mcpServers.
MCP servers requiring credentials must use op-run.
See docs/design.md for the op-run pattern.
END
        exit 1
    fi
}

main() {
    checkSettingsJson
}

# IFS / noglob / -u / pipefail apply at source time so functions tested via
# `source .githooks/pre-commit` behave the same as during direct invocation.
# Caller's shell inherits these (the price of test fidelity).
IFS=$'\n'
set -o noglob
set -uo pipefail

# Sourced execution returns before set -e + main. set -e is deferred because
# it would terminate an interactive shell on any failed command after sourcing.
return 2>/dev/null

set -e
main "$@"
