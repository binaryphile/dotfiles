#!/usr/bin/env bash
# pre-commit -- four gates:
#   (a) Reject env vars in claude/settings.json mcpServers
#       (MCP servers requiring credentials must use op-run)
#   (b) Reject staged binary file additions/modifications (UC-14)
#   (c) Reject op-run-hashed file changes without a matching
#       op-run/checksums update (UC-11, #2906)
#   (d) Reject staged flake.lock whose nixpkgs rev disagrees with
#       era's canonical rev (cross-project alignment drift)
#
# All gates can be bypassed with: git commit --no-verify.
#
# Naming Policy:
#
# This is a standalone script -- no namespace prefix on functions, no suffix on globals.
# Function names use camelCase (one-off tool; not mk.bash framework).
# Local variable names begin with lowercase, e.g. localVariable.
# Global variable names begin with uppercase, e.g. GlobalVariable.

checkSettingsJson() {
    git diff --cached --name-only | grep -q 'claude/settings.json' || return 0

    if jq -e '(.mcpServers // {}) | to_entries[] | select(.value.env != null)' claude/settings.json >/dev/null 2>&1; then
        cat <<'END'
BLOCKED: claude/settings.json contains env vars in mcpServers.
MCP servers requiring credentials must use op-run.
See docs/design.md for the op-run pattern.
END
        exit 1
    fi
}

checkBinary() {
    local -a binary=()
    local add del path
    while IFS=$'\t' read -r add del path; do
        [[ $add == '-' && $del == '-' ]] && binary+=("$path")
    done < <(git diff --cached --numstat --no-renames)

    (( ${#binary[@]} > 0 )) || return 0
    {
        echo "pre-commit: refusing to commit binary file(s):"
        printf '  %s\n' "${binary[@]}"
        echo
        echo "Options:"
        echo "  - Add the path to .gitignore"
        echo "  - Unstage:  git restore --staged <path>"
        echo "  - Override: git commit --no-verify (use sparingly)"
    } >&2
    exit 1
}

checkOpRunDrift() {
    # Manifest MIRRORS scripts/op-run-checksum-update. A tesht case asserts
    # both produce the same set against the live tree.
    # Locally disable noglob (the file-level default) for *.allow expansion;
    # restore on the success-return path. On exit 1 the script terminates anyway.
    set +f
    shopt -s nullglob
    local -a Manifest=(
        scripts/op-run
        op-run/projects.bash
        op-run/machines/*.allow
    )
    set -f

    # Skip-fast: did any manifest path change in this commit?
    local -a staged=()
    mapfile -t staged < <(git diff --cached --name-only)
    local needCheck=0 p s
    for p in "${Manifest[@]}"; do
        for s in "${staged[@]}"; do
            [[ $s == "$p" ]] && { needCheck=1; break 2; }
        done
    done
    (( needCheck == 0 )) && return 0

    # Compute the canonical checksums file from staged content of each
    # manifest entry. git cat-file -e gates each entry against the index
    # (handles the delete-from-index edge case by skipping that entry; the
    # regenerator does the same via shopt -s nullglob over working-tree refs).
    local expected actual hash
    expected=$(
        for p in "${Manifest[@]}"; do
            git cat-file -e ":$p" 2>/dev/null || continue
            hash=$(git show ":$p" | sha256sum | awk '{print $1}')
            printf '%s  %s\n' "$hash" "$p"
        done | LC_ALL=C sort -k 2
    )

    # Read the staged checksums file (empty if not in index, including the
    # delete-from-index case).
    actual=$(git show :op-run/checksums 2>/dev/null || true)

    [[ $expected == "$actual" ]] && return 0
    {
        echo "pre-commit: op-run/checksums not updated for staged hashed-file change(s)."
        echo
        echo "  Fix:"
        echo "    bash scripts/op-run-checksum-update"
        echo "    git add op-run/checksums"
        echo
        echo "  Bypass: git commit --no-verify (use sparingly)"
        echo
        echo "  See ~/projects/jeeves/security/threat-model.md \"Tamper-evident launcher\""
        echo "  and op-run/README.md \"Integrity check\"."
    } >&2
    exit 1
}

checkFlakeLockPin() {
    git diff --cached --name-only -- flake.lock | grep -qxF flake.lock || return 0

    local canonical=$HOME/projects/era/flake.lock
    [[ -f $canonical ]] || return 0   # canonical not present -- cannot enforce

    local canonicalRev stagedRev
    canonicalRev=$(jq -r '.nodes.nixpkgs.locked.rev // empty' "$canonical")
    [[ -n $canonicalRev ]] || return 0

    stagedRev=$(git show :flake.lock 2>/dev/null | jq -r '.nodes.nixpkgs.locked.rev // empty')
    [[ $stagedRev == "$canonicalRev" ]] && return 0

    {
        echo "pre-commit: flake.lock nixpkgs rev does not match era canonical"
        echo "  staged:    ${stagedRev:-<missing or unparsable>}"
        echo "  canonical: $canonicalRev  (from ~/projects/era/flake.lock)"
        echo
        echo "  Fix:    update-env       (re-pins all managed flake.lock files)"
        echo "    or:   git restore flake.lock  (discard the drift)"
        echo "  Bypass: git commit --no-verify (only when advancing canonical;"
        echo "                                  update era first)"
    } >&2
    exit 1
}

main() {
    checkSettingsJson
    checkBinary
    checkOpRunDrift
    checkFlakeLockPin
}

# IFS / noglob / -u / pipefail apply at source time so functions tested via
# `source .githooks/pre-commit` behave the same as during direct invocation.
# Caller's shell inherits these (the price of test fidelity).
IFS=$'\n'
set -o noglob
set -uo pipefail

# Sourced execution returns before set -e + main. set -e is deferred because
# it would terminate an interactive shell on any failed command after sourcing.
return 2>/dev/null

set -e
main "$@"
