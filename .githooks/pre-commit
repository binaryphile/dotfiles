#!/usr/bin/env bash
# pre-commit -- reject secrets in tracked config files
#
# Naming Policy:
#
# This is a standalone script -- no namespace prefix on functions, no suffix on globals.
# Function names use PascalCase.
# Local variable names begin with lowercase, e.g. localVariable.
# Global variable names begin with uppercase, e.g. GlobalVariable.

CheckSettingsJson() {
    git diff --cached --name-only | grep -q 'claude/settings.json' || return 0

    if jq -e '(.mcpServers // {}) | to_entries[] | select(.value.env != null)' claude/settings.json >/dev/null 2>&1; then
        echo "BLOCKED: claude/settings.json contains env vars in mcpServers."
        echo "MCP servers requiring credentials must use op-run."
        echo "See docs/design.md for the op-run pattern."
        exit 1
    fi
}

Main() {
    CheckSettingsJson
}

# strict mode
IFS=$'\n'
set -o noglob
set -euo pipefail

Main "$@"
